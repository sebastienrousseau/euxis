{
  "id": "swarm-research",
  "name": "Collaborative Swarm Research",
  "description": "Orchestrates a researcher and a writer in parallel to produce a report.",
  "phases": [
    {
      "phase": 1,
      "name": "Information Gathering",
      "mode": "parallel",
      "delegates": [
        {
          "agent": "researcher",
          "task_template": "Gather raw data on: ${goal}"
        },
        {
          "agent": "analyst",
          "task_template": "Identify trends in: ${goal}"
        }
      ],
      "checkpoint": "Data and trends gathered"
    },
    {
      "phase": 2,
      "name": "Synthesis",
      "mode": "sequential",
      "delegates": [
        {
          "agent": "writer",
          "task_template": "Write a summary based on the research results: ${history}"
        }
      ]
    }
  ]
}
