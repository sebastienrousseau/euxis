#!/usr/bin/env bash
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
PROJECTS_DIR="${EUXIS_HOME}/euxis-runtime/data/projects"
SCAN_INTERVAL="${EUXIS_CONTEXT_SCAN_INTERVAL:-15}"
CONTEXT_BUDGET_TOKENS="${EUXIS_CONTEXT_BUDGET_TOKENS:-120000}"
TRIGGER_PCT="${EUXIS_CONTEXT_TRIGGER_PCT:-70}"
TARGET_PCT="${EUXIS_CONTEXT_TARGET_PCT:-45}"
RECENT_LINES="${EUXIS_CONTEXT_RECENT_LINES:-120}"

usage() {
  cat <<'EOF'
Usage:
  euxis-context-worker once
  euxis-context-worker run

Description:
  Monitors memory files and performs recursive context compaction when token
  usage exceeds trigger threshold. Writes:
  - memory.compacted.md
  - context-state.json
  - todo.md (structured milestone offload template)
EOF
}

estimate_tokens() {
  local txt="$1"
  echo $(( (${#txt} / 4) + 1 ))
}

head_tail_compact() {
  local text="$1"
  local max_chars="$2"
  if [[ ${#text} -le ${max_chars} ]]; then
    printf '%s' "${text}"
    return
  fi
  local half=$(( max_chars / 2 ))
  printf '%s\n%s\n%s' "${text:0:half}" "... [RECURSIVELY COMPACTED] ..." "${text: -half}"
}

process_memory_file() {
  local memory_file="$1"
  [[ -f "${memory_file}" ]] || return 0

  local dir
  dir="$(dirname "${memory_file}")"
  local summary_file="${dir}/memory.summary.md"
  local compacted_file="${dir}/memory.compacted.md"
  local state_file="${dir}/context-state.json"
  local todo_file="${dir}/todo.md"

  local raw
  raw="$(cat "${memory_file}" 2>/dev/null || true)"
  [[ -n "${raw}" ]] || return 0

  local tokens trigger_tokens target_tokens target_chars
  tokens=$(estimate_tokens "${raw}")
  trigger_tokens=$(( CONTEXT_BUDGET_TOKENS * TRIGGER_PCT / 100 ))
  target_tokens=$(( CONTEXT_BUDGET_TOKENS * TARGET_PCT / 100 ))
  target_chars=$(( target_tokens * 4 ))

  if (( tokens < trigger_tokens )); then
    return 0
  fi

  local previous_summary recent_chunk merged compacted ratio
  previous_summary="$(cat "${summary_file}" 2>/dev/null || true)"
  recent_chunk="$(tail -n "${RECENT_LINES}" "${memory_file}" 2>/dev/null || true)"
  merged="${previous_summary}"$'\n\n'"${recent_chunk}"
  compacted="$(head_tail_compact "${merged}" "${target_chars}")"

  printf '%s\n' "${compacted}" > "${summary_file}"
  cat > "${compacted_file}" <<EOF
## Compact Summary
${compacted}

## Just-In-Time Refs
- Source memory file: ${memory_file}
- Load full history only if required for correctness.
EOF

  if [[ ! -f "${todo_file}" ]]; then
    cat > "${todo_file}" <<'EOF'
## Milestones
- [ ] milestone: 
  decision: 
  artifact_refs: []
  next_step: 
EOF
  fi

  ratio="1:1"
  if (( target_tokens > 0 )); then
    ratio="1:$(( tokens / target_tokens + 1 ))"
  fi

  jq -n \
    --arg ts "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
    --argjson before "${tokens}" \
    --argjson trigger "${trigger_tokens}" \
    --argjson target "${target_tokens}" \
    --arg ratio "${ratio}" \
    --arg source "${memory_file}" \
    --arg summary "${summary_file}" \
    --arg compacted "${compacted_file}" \
    '{
      last_compacted_at: $ts,
      tokens_before: $before,
      trigger_tokens: $trigger,
      target_tokens: $target,
      estimated_compression_ratio: $ratio,
      source_memory: $source,
      summary_file: $summary,
      compacted_file: $compacted
    }' > "${state_file}"

  echo "[euxis-context-worker] compacted: ${memory_file} (${tokens} tokens)" >&2
}

scan_once() {
  find "${PROJECTS_DIR}" -type f -name "memory.md" 2>/dev/null | while read -r f; do
    process_memory_file "${f}"
  done
}

cmd="${1:-once}"
case "${cmd}" in
  once)
    scan_once
    ;;
  run)
    while true; do
      scan_once
      sleep "${SCAN_INTERVAL}"
    done
    ;;
  -h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 1
    ;;
esac
