#!/usr/bin/env bash
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/core.sh" ]]; then
  # shellcheck source=core/lib/core.sh
  source "${EUXIS_HOME}/euxis-core/lib/core.sh"
  ui_auto_header
fi


BUS_DIR="$HOME/.euxis/euxis-runtime/data/bus/pipes"

usage() {
  cat <<'EOF'
euxis-bus — Pub/sub message bus for inter-agent async communication

Usage:
  euxis-bus publish <topic> <message> [--sender <agent>] [--priority P0|P1|P2|P3]
  euxis-bus subscribe <topic> [--timeout N]
  euxis-bus list-topics
  euxis-bus drain <topic>
  euxis-bus status

Commands:
  publish       Publish a JSON message envelope to a topic
  subscribe     Subscribe and print messages from a topic (blocking, default 10s timeout)
  list-topics   List all active topics
  drain         Clear all pending messages from a topic
  status        Show bus status (active topics, pending message counts)

Options:
  --sender      Agent name to include in envelope (default: "unknown")
  --priority    Message priority: P0 (critical), P1 (high), P2 (normal), P3 (low) (default: P2)
  --timeout     Seconds to wait for new messages before exiting (default: 10)
  -h, --help    Show this help text
EOF
}

validate_topic() {
  local topic="$1"
  if [[ ! "$topic" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Error: Invalid topic name '$topic'. Must match [a-zA-Z0-9_-]+" >&2
    return 1
  fi
}

cmd_publish() {
  if [[ $# -lt 2 ]]; then
    echo "Error: publish requires <topic> and <message>" >&2
    usage >&2
    return 1
  fi

  local topic="$1"; shift
  local message="$1"; shift
  local sender="unknown"
  local priority="P2"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --sender)
        sender="$2"; shift 2 ;;
      --priority)
        priority="$2"; shift 2 ;;
      *)
        echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  validate_topic "$topic" || return 1

  # Validate sender name (same allowlist as topic)
  if [[ ! "$sender" =~ ^[a-zA-Z0-9_-]+$ ]]; then
    echo "Error: Invalid sender name '$sender'. Must match [a-zA-Z0-9_-]+" >&2
    return 1
  fi

  if [[ ! "$priority" =~ ^P[0-3]$ ]]; then
    echo "Error: Priority must be P0, P1, P2, or P3" >&2
    return 1
  fi

  local topic_dir="$BUS_DIR/$topic"
  mkdir -p "$topic_dir"

  local ts
  ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
  local correlation_id
  correlation_id="$(date +%s)-$$-$RANDOM"
  local filename
  filename="$(date +%s%N)-$RANDOM.msg"

  # Build JSON envelope (using jq for safe escaping — prevents shell injection)
  local envelope
  if command -v jq &>/dev/null; then
    envelope=$(jq -n \
      --arg sender "$sender" \
      --arg topic "$topic" \
      --arg priority "$priority" \
      --arg payload "$message" \
      --arg timestamp "$ts" \
      --arg correlation_id "$correlation_id" \
      '{sender:$sender,topic:$topic,priority:$priority,payload:$payload,timestamp:$timestamp,correlation_id:$correlation_id}')
  else
    # Fallback: sanitize inputs by stripping shell metacharacters
    local safe_sender safe_message
    safe_sender=$(printf '%s' "$sender" | tr -d '\\"`$(){}[]|;&<>!')
    safe_message=$(printf '%s' "$message" | tr -d '\\"`$(){}[]|;&<>!')
    envelope=$(printf '{"sender":"%s","topic":"%s","priority":"%s","payload":"%s","timestamp":"%s","correlation_id":"%s"}' \
      "$safe_sender" "$topic" "$priority" "$safe_message" "$ts" "$correlation_id")
  fi

  printf '%s\n' "$envelope" > "$topic_dir/$filename"
  echo "Published to $topic: $filename"
}

cmd_subscribe() {
  if [[ $# -lt 1 ]]; then
    echo "Error: subscribe requires <topic>" >&2
    usage >&2
    return 1
  fi

  local topic="$1"; shift
  local timeout=10

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --timeout)
        timeout="$2"; shift 2 ;;
      *)
        echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  validate_topic "$topic" || return 1

  local topic_dir="$BUS_DIR/$topic"
  mkdir -p "$topic_dir"

  local deadline=$(( $(date +%s) + timeout ))

  # First, drain any existing messages in order
  _read_pending "$topic_dir"

  # Then watch for new ones until timeout
  if command -v inotifywait &>/dev/null; then
    # inotifywait-based watching
    while [[ $(date +%s) -lt $deadline ]]; do
      local remaining=$(( deadline - $(date +%s) ))
      [[ $remaining -le 0 ]] && break
      if inotifywait -q -t "$remaining" -e create "$topic_dir" &>/dev/null; then
        _read_pending "$topic_dir"
        deadline=$(( $(date +%s) + timeout ))
      fi
    done
  else
    # Polling fallback
    while [[ $(date +%s) -lt $deadline ]]; do
      local found=0
      for f in "$topic_dir"/*.msg; do
        [[ -f "$f" ]] || continue
        found=1
        break
      done
      if [[ $found -eq 1 ]]; then
        _read_pending "$topic_dir"
        deadline=$(( $(date +%s) + timeout ))
      fi
      sleep 0.5
    done
  fi
}

_read_pending() {
  local dir="$1"
  local f
  for f in $(ls "$dir"/*.msg 2>/dev/null | sort); do
    [[ -f "$f" ]] || continue
    cat "$f"
    rm -f "$f"
  done
}

cmd_list_topics() {
  if [[ ! -d "$BUS_DIR" ]]; then
    echo "No active topics."
    return 0
  fi

  local found=0
  for d in "$BUS_DIR"/*/; do
    [[ -d "$d" ]] || continue
    found=1
    basename "$d"
  done

  if [[ $found -eq 0 ]]; then
    echo "No active topics."
  fi
}

cmd_drain() {
  if [[ $# -lt 1 ]]; then
    echo "Error: drain requires <topic>" >&2
    usage >&2
    return 1
  fi

  local topic="$1"
  validate_topic "$topic" || return 1

  local topic_dir="$BUS_DIR/$topic"
  if [[ ! -d "$topic_dir" ]]; then
    echo "Topic '$topic' does not exist." >&2
    return 1
  fi

  local count
  count=$(find "$topic_dir" -name '*.msg' 2>/dev/null | wc -l)
  rm -f "$topic_dir"/*.msg
  echo "Drained $count message(s) from $topic"
}

cmd_status() {
  if [[ ! -d "$BUS_DIR" ]]; then
    echo "Bus directory not initialized."
    return 0
  fi

  local total_topics=0
  local total_messages=0

  printf "%-25s %s\n" "TOPIC" "PENDING"
  printf "%-25s %s\n" "-----" "-------"

  for d in "$BUS_DIR"/*/; do
    [[ -d "$d" ]] || continue
    local tname
    tname=$(basename "$d")
    local count
    count=$(find "$d" -name '*.msg' 2>/dev/null | wc -l)
    printf "%-25s %d\n" "$tname" "$count"
    total_topics=$(( total_topics + 1 ))
    total_messages=$(( total_messages + count ))
  done

  if [[ $total_topics -eq 0 ]]; then
    echo "No active topics."
  else
    echo ""
    echo "Total: $total_topics topic(s), $total_messages pending message(s)"
  fi
}

cmd_cleanup() {
  local retention_hours="${1:-24}"

  if [[ ! -d "$BUS_DIR" ]]; then
    echo "No bus directory to clean."
    return 0
  fi

  local total_removed=0
  for d in "$BUS_DIR"/*/; do
    [[ -d "$d" ]] || continue
    local tname
    tname=$(basename "$d")
    local count=0
    while IFS= read -r f; do
      [[ -f "$f" ]] || continue
      rm -f "$f"
      count=$((count + 1))
    done < <(find "$d" -name '*.msg' -mmin +"$((retention_hours * 60))" 2>/dev/null)
    if [[ $count -gt 0 ]]; then
      echo "Cleaned $count message(s) from $tname (older than ${retention_hours}h)"
      total_removed=$((total_removed + count))
    fi
  done

  if [[ $total_removed -eq 0 ]]; then
    echo "No stale messages found (retention: ${retention_hours}h)."
  else
    echo "Total: removed $total_removed stale message(s)."
  fi
}

# --- Main ---

mkdir -p "$BUS_DIR"

if [[ $# -eq 0 ]]; then
  usage
  exit 1
fi

case "$1" in
  publish)
    shift; cmd_publish "$@" ;;
  subscribe)
    shift; cmd_subscribe "$@" ;;
  list-topics)
    cmd_list_topics ;;
  drain)
    shift; cmd_drain "$@" ;;
  cleanup)
    shift; cmd_cleanup "$@" ;;
  status)
    cmd_status ;;
  -h|--help|help)
    usage ;;
  *)
    echo "Error: Unknown command '$1'" >&2
    usage >&2
    exit 1 ;;
esac
