#!/usr/bin/env python3
"""
Euxis Certify - Cryptographic Provenance Tool for Wasm Agents
"""

import sys
import os
import argparse
from pathlib import Path

# Add crypto lib to path to import the rust extension
repo_root = Path(__file__).resolve().parents[2]
crypto_lib_path = repo_root / "euxis-crypto" / "target" / "release"
if str(crypto_lib_path) not in sys.path:
    sys.path.insert(0, str(crypto_lib_path))

try:
    import libcrypto_lib_rs as crypto
except ImportError:
    try:
        import crypto_lib_rs as crypto
    except ImportError as e:
        print(f"Error: Could not load euxis-crypto-rs. Ensure it is compiled. ({e})")
        sys.exit(1)

def generate_keys(args):
    sk, pk = crypto.generate_ed25519_keypair()
    sk_path = Path("architect.key")
    pk_path = Path("architect.pub")
    
    sk_path.write_bytes(bytes(sk))
    pk_path.write_bytes(bytes(pk))
    
    print(f"✓ Generated Ed25519 Keypair.")
    print(f"  Secret Key: {sk_path.resolve()} (KEEP THIS SAFE)")
    print(f"  Public Key: {pk_path.resolve()}")

def sign_agent(args):
    sk_path = Path(args.key)
    if not sk_path.exists():
        print(f"Error: Secret key not found at {sk_path}")
        sys.exit(1)
        
    sk = sk_path.read_bytes()
    if len(sk) != 32:
        print("Error: Secret key must be exactly 32 bytes (Ed25519).")
        sys.exit(1)
        
    agent_path = Path(args.agent)
    if not agent_path.exists():
        print(f"Error: Agent not found at {agent_path}")
        sys.exit(1)
        
    message = agent_path.read_bytes()
    signature = crypto.ed25519_sign(list(sk), list(message))
    
    sig_path = agent_path.with_suffix(".sig")
    sig_path.write_bytes(bytes(signature))
    
    print(f"✓ Agent Signed Successfully: {agent_path.name}")
    print(f"  Signature written to: {sig_path.resolve()}")

def verify_agent(args):
    pk_path = Path(args.pubkey)
    if not pk_path.exists():
        print(f"Error: Public key not found at {pk_path}")
        sys.exit(1)
        
    pk = pk_path.read_bytes()
    
    agent_path = Path(args.agent)
    sig_path = agent_path.with_suffix(".sig")
    
    if not agent_path.exists() or not sig_path.exists():
        print("Error: Both agent binary and .sig file must exist.")
        sys.exit(1)
        
    message = agent_path.read_bytes()
    signature = sig_path.read_bytes()
    
    try:
        is_valid = crypto.ed25519_verify(list(pk), list(message), list(signature))
        if is_valid:
            print(f"✓ VERIFIED: {agent_path.name} signature is valid.")
            sys.exit(0)
        else:
            print(f"✗ REJECTED: {agent_path.name} signature is INVALID.")
            sys.exit(1)
    except Exception as e:
        print(f"✗ REJECTED: Verification failed: {e}")
        sys.exit(1)

def main():
    parser = argparse.ArgumentParser(description="Euxis Cryptographic Provenance")
    subparsers = parser.add_subparsers(dest="command", required=True)
    
    keygen_parser = subparsers.add_parser("keygen", help="Generate Ed25519 Architect Keys")
    keygen_parser.set_defaults(func=generate_keys)
    
    sign_parser = subparsers.add_parser("sign", help="Sign a Wasm agent binary")
    sign_parser.add_argument("agent", help="Path to the .wasm file")
    sign_parser.add_argument("--key", required=True, help="Path to architect.key")
    sign_parser.set_defaults(func=sign_agent)
    
    verify_parser = subparsers.add_parser("verify", help="Verify a signed Wasm agent")
    verify_parser.add_argument("agent", help="Path to the .wasm file")
    verify_parser.add_argument("--pubkey", required=True, help="Path to architect.pub")
    verify_parser.set_defaults(func=verify_agent)
    
    args = parser.parse_args()
    args.func(args)

if __name__ == "__main__":
    main()
