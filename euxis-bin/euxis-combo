#!/usr/bin/env bash
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/core.sh" ]]; then
  # shellcheck source=euxis-core/lib/core.sh
  source "${EUXIS_HOME}/euxis-core/lib/core.sh"
  ui_auto_header
fi


EUXIS_DIR="$HOME/.euxis"
SQUADS_FILE="$EUXIS_DIR/euxis-core/agents/squads.json"

usage() {
  local c_usage=$'\033[1m\033[38;5;255m'
  local c_group=$'\033[1m\033[38;5;87m'
  local dim=$'\033[2m'
  local r=$'\033[0m'
  local bullet="▸"
  if type _ui_colors_enabled &>/dev/null && ! _ui_colors_enabled; then c_usage=""; c_group=""; dim=""; r=""; bullet=">"; fi
  echo -e "  ${dim}Sequential agent chain execution${r}\n"
  echo -e "  ${c_usage}USAGE${r}"
  echo -e "    $ euxis-combo list"
  echo -e "    $ euxis-combo info <combo-id>"
  echo -e "    $ euxis-combo run <combo-id> \"<task>\" [--provider PROVIDER]\n"
  echo -e "  ${c_group}${bullet} COMMANDS${r}"
  echo -e "    list        Table of combos with chains"
  echo -e "    info        Chain detail with agent roles"
  echo -e "    run         Execute chain sequentially, passing context between agents\n"
  echo -e "  ${c_group}${bullet} OPTIONS${r}"
  echo -e "    --provider  Override provider for all agents in the chain"
  echo -e "    -h, --help  Show this help text"
  if type ui_signature &>/dev/null; then ui_signature; fi
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
  fi
}

require_squads_file() {
  if [[ ! -f "$SQUADS_FILE" ]]; then
    echo "Error: euxis-core/agents/squads.json not found at $SQUADS_FILE" >&2
    exit 1
  fi
}

validate_combo_id() {
  local id="$1"
  local exists
  exists=$(jq -r --arg id "$id" '.combos[] | select(.id == $id) | .id' "$SQUADS_FILE")
  if [[ -z "$exists" ]]; then
    echo "Error: Unknown combo '$id'. Run 'euxis-combo list' to see available combos." >&2
    exit 1
  fi
}

cmd_list() {
  require_jq
  require_squads_file

  jq -r '.combos[] | [.id, .description] | @tsv' "$SQUADS_FILE" |
    while IFS=$'\t' read -r id desc; do
      local cyan reset
      cyan=$(ui_cyan)
      reset=$(ui_reset)
      printf "%s✓%s %s%s%s — %s\n" "$cyan" "$reset" "$cyan" "$id" "$reset" "$desc"
    done

  local cyan reset
  cyan=$(ui_cyan)
  reset=$(ui_reset)
  printf "\n%s✓ Combos ready%s\n" "$cyan" "$reset"
}

cmd_info() {
  local id="$1"
  ui_progress_begin 3 "Loading combo"
  require_jq
  ui_progress_step "Dependencies ready"
  require_squads_file
  ui_progress_step "Combos loaded"
  validate_combo_id "$id"
  ui_progress_step "Combo validated"
  ui_progress_done "Combo ready"

  local combo
  combo=$(jq --arg id "$id" '.combos[] | select(.id == $id)' "$SQUADS_FILE")

  echo "Combo: $(echo "$combo" | jq -r '.name')"
  echo "ID:          $(echo "$combo" | jq -r '.id')"
  echo "Description: $(echo "$combo" | jq -r '.description')"
  echo "Chain:       $(echo "$combo" | jq -r '.chain | join(" → ")')"
  echo "Steps:       $(echo "$combo" | jq -r '.chain | length')"
  echo ""
  echo "Execution order:"

  local step=1
  while IFS= read -r agent; do
    echo "  $step. $agent"
    ((step++)) || true
  done < <(echo "$combo" | jq -r '.chain[]')
}

cmd_run() {
  local id="$1"; shift
  local task="$1"; shift
  local provider=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider) provider="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  ui_progress_begin 3 "Preparing combo"
  require_jq
  ui_progress_step "Dependencies ready"
  require_squads_file
  ui_progress_step "Combos loaded"
  validate_combo_id "$id"
  ui_progress_step "Combo validated"
  ui_progress_done "Combo ready"

  local combo
  combo=$(jq --arg id "$id" '.combos[] | select(.id == $id)' "$SQUADS_FILE")
  local combo_name
  combo_name=$(echo "$combo" | jq -r '.name')

  echo "═══════════════════════════════════════════════════════"
  echo "  Combo: $combo_name"
  echo "  Task: $task"
  echo "═══════════════════════════════════════════════════════"
  echo ""

  local context="$task"
  local step=1
  local total
  total=$(echo "$combo" | jq -r '.chain | length')

  while IFS= read -r agent; do
    echo "──────────────────────────────────────────────────────"
    echo "  Step $step/$total: $agent"
    echo "──────────────────────────────────────────────────────"

    # Build prompt: original task + previous context (capped at 4000 chars)
    local full_prompt
    if [[ $step -eq 1 ]]; then
      full_prompt="$task"
    else
      local truncated_context="${context:0:4000}"
      full_prompt="Original task: $task

Previous agent output:
$truncated_context

Continue the chain. Build on the previous output."
    fi

    # Invoke agent
    local output
    if [[ -n "$provider" ]]; then
      output=$(euxis "$agent" "$full_prompt" "$provider" 2>&1) || true
    else
      output=$(euxis "$agent" "$full_prompt" 2>&1) || true
    fi

    if [[ -z "$output" ]]; then
      echo "  Warning: $agent produced no output." >&2
      output="[No output from $agent]"
    fi

    echo "$output"
    echo ""
    context="$output"
    ((step++)) || true
  done < <(echo "$combo" | jq -r '.chain[]')

  echo "═══════════════════════════════════════════════════════"
  echo "  Combo '$combo_name' complete."
  echo "═══════════════════════════════════════════════════════"

  # Publish event to bus
  if command -v euxis-bus &>/dev/null; then
    euxis-bus publish combo-events "Combo '$id' completed for: $task" --sender "euxis-combo" --priority P2
  fi
}

# Main
case "${1:-}" in
  list)       cmd_list ;;
  info)
    if [[ -z "${2:-}" ]]; then echo "Error: info requires <combo-id>" >&2; usage >&2; exit 1; fi
    cmd_info "$2" ;;
  run)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then echo "Error: run requires <combo-id> and <task>" >&2; usage >&2; exit 1; fi
    cmd_run "$2" "$3" "${@:4}" ;;
  -h|--help)  usage ;;
  *)          usage >&2; exit 1 ;;
esac
