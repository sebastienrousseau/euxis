#!/usr/bin/env bash
#
# Euxis Cross-Platform Verification Script
# Verifies build/package/runtime parity for macOS, Linux, and WSL
#
# Usage: euxis-cross-platform-verify [--local-only] [--version VERSION]
#        euxis-cross-platform-verify --help
#

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/core.sh" ]]; then
  # shellcheck source=core/lib/core.sh
  source "${EUXIS_HOME}/euxis-core/lib/core.sh"
  ui_auto_header
fi


VERSION="${VERSION:-v0.0.8}"
LOCAL_ONLY=false
_self="$0"
while [ -L "$_self" ]; do
    _dir="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    [[ "$_self" != /* ]] && _self="$_dir/$_self"
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
EUXIS_ROOT="$(dirname "$SCRIPT_DIR")"

usage() {
    cat << EOF
Euxis Cross-Platform Verification

USAGE:
    euxis-cross-platform-verify [OPTIONS]

OPTIONS:
    --local-only        Only verify current platform (no CI trigger)
    --version VERSION   Specify version to verify (default: $VERSION)
    --help             Show this help message

DESCRIPTION:
    Verifies Euxis build/package/runtime parity across macOS, Linux, and WSL.

    Local mode tests:
    - Current platform compatibility
    - Python environment validation
    - Core script functionality
    - Dependency resolution

    CI mode (default) triggers GitHub Actions workflow for full 3-platform verification.

EXAMPLES:
    euxis-cross-platform-verify --local-only
    euxis-cross-platform-verify --version v0.0.8

VERIFICATION GATES:
    1. Build Parity      - Scripts execute on all platforms
    2. Package Parity    - Dependencies install correctly
    3. Runtime Parity    - Core functionality works consistently
    4. Integration Tests - Agent discovery and basic operations

EOF
}

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() { echo -e "${BLUE}[INFO]${NC} $*"; }
log_success() { echo -e "${GREEN}[SUCCESS]${NC} $*"; }
log_warning() { echo -e "${YELLOW}[WARNING]${NC} $*"; }
log_error() { echo -e "${RED}[ERROR]${NC} $*"; }

# Parse command line arguments
while [[ $# -gt 0 ]]; do
    case $1 in
        --local-only)
            LOCAL_ONLY=true
            shift
            ;;
        --version)
            VERSION="$2"
            shift 2
            ;;
        --help)
            usage
            exit 0
            ;;
        *)
            log_error "Unknown option: $1"
            usage
            exit 1
            ;;
    esac
done

detect_platform() {
    local os_name
    os_name="$(uname -s 2>/dev/null || echo 'unknown')"

    case "$os_name" in
        Linux*)
            if grep -qi microsoft /proc/version 2>/dev/null; then
                echo "wsl"
            else
                echo "linux"
            fi
            ;;
        Darwin*)
            echo "macos"
            ;;
        MINGW*|MSYS*|CYGWIN*)
            echo "windows"
            ;;
        *)
            echo "unknown"
            ;;
    esac
}

verify_python_environment() {
    log_info "Verifying Python environment..."

    if ! command -v python3 &> /dev/null; then
        log_error "Python 3 not found"
        return 1
    fi

    local py_version
    py_version="$(python3 --version 2>&1 | cut -d' ' -f2)"
    log_info "Python version: $py_version"

    # Check if version is 3.11+
    local major minor
    major="$(echo "$py_version" | cut -d. -f1)"
    minor="$(echo "$py_version" | cut -d. -f2)"

    if [[ "$major" -lt 3 ]] || [[ "$major" -eq 3 && "$minor" -lt 11 ]]; then
        log_error "Python 3.11+ required, found $py_version"
        return 1
    fi

    log_success "Python environment verified"
    return 0
}

verify_dependencies() {
    log_info "Verifying Python dependencies..."

    local deps_failed=0

    # Test chromadb
    if python3 -c "import chromadb" 2>/dev/null; then
        log_success "chromadb: Available"
    else
        log_warning "chromadb: Not available (attempting install)"
        if python3 -m pip install chromadb --quiet; then
            log_success "chromadb: Installed successfully"
        else
            log_error "chromadb: Installation failed"
            deps_failed=$((deps_failed + 1))
        fi
    fi

    # Test sentence-transformers
    if python3 -c "import sentence_transformers" 2>/dev/null; then
        log_success "sentence_transformers: Available"
    else
        log_warning "sentence_transformers: Not available (attempting install)"
        if python3 -m pip install sentence-transformers --quiet; then
            log_success "sentence_transformers: Installed successfully"
        else
            log_error "sentence_transformers: Installation failed"
            deps_failed=$((deps_failed + 1))
        fi
    fi

    if [[ $deps_failed -gt 0 ]]; then
        log_error "$deps_failed dependency installation(s) failed"
        return 1
    fi

    log_success "All dependencies verified"
    return 0
}

verify_core_scripts() {
    log_info "Verifying core Euxis scripts..."

    # Check if bin directory exists
    if [[ ! -d "$EUXIS_ROOT/bin" ]]; then
        log_error "Euxis bin directory not found at $EUXIS_ROOT/bin"
        return 1
    fi

    # Count executable scripts
    local script_count
    script_count="$(find "$EUXIS_ROOT/bin" -name "euxis*" -executable | wc -l)"
    log_info "Found $script_count Euxis scripts"

    if [[ $script_count -lt 10 ]]; then
        log_warning "Expected more Euxis scripts (found $script_count)"
    fi

    # Test main euxis script
    if [[ -x "$EUXIS_ROOT/cli/bin/euxis" ]]; then
        log_success "Main euxis script: Executable"
    else
        log_error "Main euxis script: Not executable"
        return 1
    fi

    # Test basic script execution (with timeout)
    if timeout 10 "$EUXIS_ROOT/cli/bin/euxis" --help >/dev/null 2>&1; then
        log_success "Euxis help command: Working"
    else
        log_warning "Euxis help command: Timed out or failed (this may be normal)"
    fi

    log_success "Core scripts verified"
    return 0
}

verify_agent_registry() {
    log_info "Verifying agent registry..."

    # SQLite-first, JSON fallback
    if [[ -f "$EUXIS_ROOT/agents/registry.db" ]]; then
        local agent_count
        agent_count=$(sqlite3 -init /dev/null "$EUXIS_ROOT/agents/registry.db" "SELECT COUNT(*) FROM agents" 2>/dev/null) || agent_count=""
        if [[ -n "$agent_count" && "$agent_count" -gt 0 ]]; then
            log_success "Agent registry: SQLite database with $agent_count agents"
            return 0
        fi
    fi

    if [[ ! -f "$EUXIS_ROOT/agents/registry.json" ]]; then
        log_error "Agent registry not found (neither agents/registry.db nor agents/registry.json)"
        return 1
    fi

    # Test JSON validity
    if python3 -c "import json; json.load(open('$EUXIS_ROOT/agents/registry.json'))" 2>/dev/null; then
        local agent_count
        agent_count="$(python3 -c "import json; data=json.load(open('$EUXIS_ROOT/agents/registry.json')); print(len(data.get('agents',[])))")"
        log_success "Agent registry: Valid JSON with $agent_count agents"
    else
        log_error "Agent registry: Invalid JSON"
        return 1
    fi

    return 0
}

run_integration_tests() {
    log_info "Running basic integration tests..."

    # Test file I/O
    local test_file="$EUXIS_ROOT/.cross_platform_test_tmp"
    echo "cross-platform-test" > "$test_file"
    if [[ "$(cat "$test_file")" == "cross-platform-test" ]]; then
        log_success "File I/O: Working"
        rm -f "$test_file"
    else
        log_error "File I/O: Failed"
        return 1
    fi

    # Test shell integration
    if echo "test" | grep -q "test" 2>/dev/null; then
        log_success "Shell integration: Working"
    else
        log_error "Shell integration: Failed"
        return 1
    fi

    log_success "Integration tests passed"
    return 0
}

run_local_verification() {
    local platform
    platform="$(detect_platform)"

    log_info "Starting local verification for platform: $platform"
    log_info "Euxis root: $EUXIS_ROOT"
    log_info "Version: $VERSION"

    echo "========================================="
    echo "   EUXIS CROSS-PLATFORM VERIFICATION"
    echo "   Platform: $platform"
    echo "   Version: $VERSION"
    echo "========================================="
    echo

    local failed_gates=0

    # Gate 1: Python Environment
    echo "── Gate 1: Python Environment ──"
    if ! verify_python_environment; then
        failed_gates=$((failed_gates + 1))
    fi
    echo

    # Gate 2: Dependencies
    echo "── Gate 2: Dependencies ──"
    if ! verify_dependencies; then
        failed_gates=$((failed_gates + 1))
    fi
    echo

    # Gate 3: Core Scripts
    echo "── Gate 3: Core Scripts ──"
    if ! verify_core_scripts; then
        failed_gates=$((failed_gates + 1))
    fi
    echo

    # Gate 4: Agent Registry
    echo "── Gate 4: Agent Registry ──"
    if ! verify_agent_registry; then
        failed_gates=$((failed_gates + 1))
    fi
    echo

    # Gate 5: Integration Tests
    echo "── Gate 5: Integration Tests ──"
    if ! run_integration_tests; then
        failed_gates=$((failed_gates + 1))
    fi
    echo

    # Summary
    echo "========================================="
    if [[ $failed_gates -eq 0 ]]; then
        log_success "All verification gates passed on $platform"
        echo "✅ PLATFORM VERIFIED: $platform"
    else
        log_error "$failed_gates verification gate(s) failed on $platform"
        echo "❌ PLATFORM FAILED: $platform"
        return 1
    fi
    echo "========================================="

    return 0
}

trigger_ci_verification() {
    log_info "Triggering GitHub Actions cross-platform CI workflow..."

    if ! command -v gh &> /dev/null; then
        log_error "GitHub CLI (gh) not found. Install from: https://cli.github.com/"
        log_info "Alternative: Push to branch to trigger CI automatically"
        return 1
    fi

    # Check if we're in a git repo
    if ! git rev-parse --git-dir >/dev/null 2>&1; then
        log_error "Not in a git repository"
        return 1
    fi

    # Trigger workflow dispatch
    if gh workflow run cross-platform-ci.yml --field version="$VERSION"; then
        log_success "Cross-platform CI workflow triggered"
        log_info "Monitor progress: gh run list"
        log_info "View workflow: gh workflow view cross-platform-ci.yml --web"
    else
        log_error "Failed to trigger CI workflow"
        return 1
    fi

    return 0
}

main() {
    cd "$EUXIS_ROOT"

    if [[ "$LOCAL_ONLY" == "true" ]]; then
        run_local_verification
    else
        log_info "Running local verification first..."
        if run_local_verification; then
            echo
            trigger_ci_verification
        else
            log_error "Local verification failed. Fix issues before triggering CI."
            exit 1
        fi
    fi
}

main "$@"
