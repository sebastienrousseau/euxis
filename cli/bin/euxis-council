#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS COUNCIL: Multi-Agent Consensus Protocol with Debate
# Usage: euxis-council "Topic"
#
# Implements a 3-round debate protocol (ACL 2025 pattern):
#   Round 1: Independent opinions from each expert
#   Round 2: Rebuttals — each expert sees all Round 1 opinions and responds
#   Round 3: Chairman synthesizes both rounds into a binding decision

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/core/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-council — Multi-agent consensus protocol

Usage:
  euxis-council "<topic>"

Implements a 3-round debate protocol:
  Round 1: Independent opinions from each expert
  Round 2: Rebuttals with cross-expert feedback
  Round 3: Chairman synthesizes a binding decision

Options:
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

export PATH="$PATH:$HOME/bin"

# Sanitize input: reject shell metacharacters to prevent injection
sanitize_input() {
    local input="$1"
    if [[ "$input" =~ [\`\$\;\|\&\>\<\(\)\{\}] ]]; then
        echo "ERROR: Input contains forbidden characters. Remove: \` \$ ; | & > < ( ) { }" >&2
        exit 1
    fi
    printf '%s' "$input"
}

TOPIC=$(sanitize_input "${1:-}")
SESSION_ID=$(openssl rand -hex 4)

if [[ -z "$TOPIC" ]]; then
    echo "Usage: euxis-council \"<topic for debate>\""
    exit 1
fi

echo ""
echo "╔═══════════════════════════════════════════════════╗"
echo "║         COUNCIL OF EUXIS — CONVENED              ║"
echo "╠═══════════════════════════════════════════════════╣"
echo "║  Topic:   $TOPIC"
echo "║  Session: $SESSION_ID"
echo "╚═══════════════════════════════════════════════════╝"

# ──────────────────────────────────────────────────────────
# Round 1: Independent Opinions
# ──────────────────────────────────────────────────────────
echo ""
echo "━━━ [Round 1] Independent Perspectives ━━━"
echo ""

echo "  >> Architect speaking..."
ARCH_R1=$(euxis architect "$TOPIC. Provide your architectural perspective." claude)

echo "  >> Security Officer speaking..."
SEC_R1=$(euxis pentester "$TOPIC. Review this for security risks." claude)

echo "  >> Performance Engineer speaking..."
PERF_R1=$(euxis optimizer "$TOPIC. Review for performance bottlenecks." claude)

# ──────────────────────────────────────────────────────────
# Round 2: Rebuttals (the debate step)
# ──────────────────────────────────────────────────────────
echo ""
echo "━━━ [Round 2] Rebuttals ━━━"
echo ""

REBUTTAL_CONTEXT="You are participating in a multi-expert debate. Below are the Round 1 opinions from all three council members. Read them carefully.

TOPIC: $TOPIC

OPINION A (Architect): $ARCH_R1

OPINION B (Security): $SEC_R1

OPINION C (Performance): $PERF_R1"

echo "  >> Architect rebuttal..."
ARCH_R2=$(euxis architect "$REBUTTAL_CONTEXT

You are the Architect. You have read the Security and Performance opinions above.
TASK: Write a rebuttal (max 300 words). For each other expert's opinion:
1. STATE whether you AGREE, DISAGREE, or PARTIALLY AGREE.
2. EXPLAIN why with specific technical reasoning.
3. AMEND your own position if their arguments changed your view.
Do NOT repeat your Round 1 opinion. Focus only on points of disagreement or refinement." claude)

echo "  >> Security Officer rebuttal..."
SEC_R2=$(euxis pentester "$REBUTTAL_CONTEXT

You are the Security Officer. You have read the Architect and Performance opinions above.
TASK: Write a rebuttal (max 300 words). For each other expert's opinion:
1. STATE whether you AGREE, DISAGREE, or PARTIALLY AGREE.
2. EXPLAIN why with specific security reasoning.
3. AMEND your own position if their arguments changed your view.
Do NOT repeat your Round 1 opinion. Focus only on points of disagreement or refinement." claude)

echo "  >> Performance Engineer rebuttal..."
PERF_R2=$(euxis optimizer "$REBUTTAL_CONTEXT

You are the Performance Engineer. You have read the Architect and Security opinions above.
TASK: Write a rebuttal (max 300 words). For each other expert's opinion:
1. STATE whether you AGREE, DISAGREE, or PARTIALLY AGREE.
2. EXPLAIN why with specific performance reasoning.
3. AMEND your own position if their arguments changed your view.
Do NOT repeat your Round 1 opinion. Focus only on points of disagreement or refinement." claude)

# ──────────────────────────────────────────────────────────
# Round 3: Chairman Synthesis
# ──────────────────────────────────────────────────────────
echo ""
echo "━━━ [Round 3] Chairman Synthesis ━━━"
echo ""

SYNTHESIS_PROMPT="You are the Chairman of the Euxis Council. A structured debate has concluded. Review ALL opinions from BOTH rounds and issue a FINAL BINDING DECISION.

TOPIC: $TOPIC

═══ ROUND 1: INITIAL POSITIONS ═══

ARCHITECT (Round 1): $ARCH_R1

SECURITY (Round 1): $SEC_R1

PERFORMANCE (Round 1): $PERF_R1

═══ ROUND 2: REBUTTALS ═══

ARCHITECT (Rebuttal): $ARCH_R2

SECURITY (Rebuttal): $SEC_R2

PERFORMANCE (Rebuttal): $PERF_R2

═══ YOUR TASK ═══

Issue your FINAL BINDING DECISION with:
1. A clear YES / NO / CONDITIONAL verdict
2. Points where experts CONVERGED during debate (changed their minds)
3. Points where experts remained in DISAGREEMENT and your ruling on each
4. The reasoning behind your ruling on each disagreement
5. Ordered action items with assigned responsible agents"

euxis orchestrator "$SYNTHESIS_PROMPT" claude
