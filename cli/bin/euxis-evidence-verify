#!/usr/bin/env python3
"""
Euxis Evidence Verification CLI Tool

Command-line interface for the evidence verification framework.
Validates strategic analysis outputs against evidence requirements.

Usage:
    euxis-evidence-verify validate <file>...     # Validate analysis files
    euxis-evidence-verify store <evidence-json>  # Store evidence manually
    euxis-evidence-verify report <hours-back>    # Generate verified performance report
    euxis-evidence-verify check-decay           # Check for decayed evidence

Examples:
    # Validate a strategic analysis report
    euxis-evidence-verify validate $EUXIS_HOME/metrics/reports/performance_report.json

    # Generate a verified performance report
    euxis-evidence-verify report 24

    # Check for decayed evidence
    euxis-evidence-verify check-decay
"""

import sys
import json
import argparse
from pathlib import Path
from datetime import datetime, timezone, timedelta

# Add the repository root to Python path
sys.path.insert(0, str(Path(__file__).parent.parent))

try:
    from metrics.verification.evidence_framework import (
        EvidenceFramework,
        Evidence,
        EvidenceGrade,
        Claim,
        VerifiedPerformanceAnalyzer
    )
    from metrics.verification.validation_pipeline import ValidationPipeline
except ImportError as e:
    print(f"Error importing evidence framework: {e}", file=sys.stderr)
    print("Make sure you're running from the Euxis root directory", file=sys.stderr)
    sys.exit(1)

def cmd_validate(args):
    """Validate analysis files against evidence requirements"""
    pipeline = ValidationPipeline()
    results = []

    for file_path in args.files:
        try:
            result = pipeline.process_analysis_file(Path(file_path))
            results.append(result)

            print(f"File: {file_path}")
            print(f"  Score: {result['overall_score']:.2f}")
            print(f"  Status: {'PASS' if result['passed'] else 'FAIL'}")

            if args.verbose:
                claims = result["validation_steps"]["claim_extraction"]["claims_found"]
                citations = result["validation_steps"]["citation_check"]["cited_claims"]
                print(f"  Claims: {claims}, Citations: {citations}")

                if not result['passed']:
                    # Show specific issues
                    uncited = result["validation_steps"]["citation_check"]["uncited_claims"]
                    if uncited:
                        print(f"  Uncited claims: {len(uncited)}")

                    forbidden = result["validation_steps"]["forbidden_terms"]["forbidden_terms_found"]
                    if forbidden > 0:
                        print(f"  Forbidden terms: {forbidden}")
            print()

        except Exception as e:
            print(f"ERROR validating {file_path}: {e}")
            results.append({"file_path": file_path, "error": str(e), "passed": False})

    # Generate summary report
    if len(results) > 1:
        report = pipeline.generate_validation_report(results)
        print("SUMMARY:")
        print(f"  Files analyzed: {report['files_analyzed']}")
        print(f"  Passed: {report['summary']['files_passed']}")
        print(f"  Failed: {report['summary']['files_failed']}")
        print(f"  Average score: {report['summary']['average_score']:.2f}")

        if report["recommendations"]:
            print("\nRECOMMENDATIONS:")
            for rec in report["recommendations"]:
                print(f"  - {rec}")

    # Exit with appropriate code
    failed_count = sum(1 for r in results if not r.get("passed", False))
    return 0 if failed_count == 0 else 1

def cmd_store_evidence(args):
    """Store evidence from JSON input"""
    framework = EvidenceFramework()

    try:
        with open(args.evidence_file, 'r') as f:
            evidence_data = json.load(f)

        evidence = Evidence(
            source_file=evidence_data["source_file"],
            source_line=evidence_data.get("source_line"),
            evidence_type=evidence_data["evidence_type"],
            grade=EvidenceGrade(evidence_data["grade"]),
            content=evidence_data["content"],
            timestamp=datetime.now(timezone.utc),
            verification_cmd=evidence_data.get("verification_cmd"),
            metadata=evidence_data.get("metadata", {})
        )

        evidence_hash = framework.store_evidence(evidence)
        print(f"Stored evidence: {evidence_hash}")

        # Verify if possible
        if evidence.verification_cmd:
            if framework.verify_evidence(evidence):
                print("Evidence verification: PASS")
            else:
                print("Evidence verification: FAIL")
                return 1

        return 0

    except Exception as e:
        print(f"ERROR storing evidence: {e}")
        return 1

def cmd_generate_report(args):
    """Generate verified performance report"""
    try:
        analyzer = VerifiedPerformanceAnalyzer()
        report = analyzer.generate_verified_report(args.hours)

        if args.output:
            with open(args.output, 'w') as f:
                json.dump(report, f, indent=2)
            print(f"Verified report saved to: {args.output}")
        else:
            print(json.dumps(report, indent=2))

        # Show verification status
        if "evidence_validation" in report:
            validation = report["evidence_validation"]
            print(f"\nVerification Status: {'VERIFIED' if validation['overall_valid'] else 'UNVERIFIED'}")
            print(f"Claims validated: {validation['claims_valid']}/{validation['claims_total']}")

        return 0 if report.get("verified", False) else 1

    except Exception as e:
        print(f"ERROR generating report: {e}")
        return 1

def cmd_check_decay(args):
    """Check for decayed evidence in the database"""
    framework = EvidenceFramework()

    try:
        if not framework.evidence_db.exists():
            print("No evidence database found")
            return 0

        decayed_count = 0
        total_count = 0

        with open(framework.evidence_db, 'r') as f:
            for line in f:
                try:
                    data = json.loads(line.strip())
                    total_count += 1

                    # Reconstruct evidence to check decay
                    evidence = Evidence(
                        source_file=data["source_file"],
                        source_line=data.get("source_line"),
                        evidence_type=data["evidence_type"],
                        grade=EvidenceGrade(data["grade"]),
                        content=data["content"],
                        timestamp=datetime.fromisoformat(data["timestamp"]),
                        verification_cmd=data.get("verification_cmd"),
                        metadata=data.get("metadata", {})
                    )

                    if framework.check_evidence_decay(evidence):
                        decayed_count += 1
                        if args.verbose:
                            age = datetime.now(timezone.utc) - evidence.timestamp.replace(tzinfo=timezone.utc)
                            print(f"DECAYED: {evidence.get_hash()} - {evidence.source_file} (age: {age.days} days)")

                except (json.JSONDecodeError, ValueError, KeyError):
                    continue

        print(f"Evidence decay check complete:")
        print(f"  Total evidence: {total_count}")
        print(f"  Decayed evidence: {decayed_count}")

        if decayed_count > 0:
            print(f"\nWarning: {decayed_count} evidence items have exceeded decay thresholds")
            return 1
        else:
            print("All evidence is within acceptable age limits")
            return 0

    except Exception as e:
        print(f"ERROR checking evidence decay: {e}")
        return 1

def main():
    parser = argparse.ArgumentParser(
        description="Euxis Evidence Verification CLI",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        epilog=__doc__
    )

    subparsers = parser.add_subparsers(dest='command', help='Available commands')

    # Validate command
    validate_parser = subparsers.add_parser('validate', help='Validate analysis files')
    validate_parser.add_argument('files', nargs='+', help='Analysis files to validate')
    validate_parser.add_argument('-v', '--verbose', action='store_true', help='Verbose output')

    # Store evidence command
    store_parser = subparsers.add_parser('store', help='Store evidence from JSON')
    store_parser.add_argument('evidence_file', help='JSON file containing evidence data')

    # Generate report command
    report_parser = subparsers.add_parser('report', help='Generate verified performance report')
    report_parser.add_argument('hours', type=int, default=24, nargs='?', help='Hours back to analyze (default: 24)')
    report_parser.add_argument('-o', '--output', help='Output file for report')

    # Check decay command
    decay_parser = subparsers.add_parser('check-decay', help='Check for decayed evidence')
    decay_parser.add_argument('-v', '--verbose', action='store_true', help='Show decayed evidence details')

    args = parser.parse_args()

    if not args.command:
        parser.print_help()
        return 1

    # Route to appropriate command handler
    if args.command == 'validate':
        return cmd_validate(args)
    elif args.command == 'store':
        return cmd_store_evidence(args)
    elif args.command == 'report':
        return cmd_generate_report(args)
    elif args.command == 'check-decay':
        return cmd_check_decay(args)
    else:
        print(f"Unknown command: {args.command}")
        return 1

if __name__ == "__main__":
    sys.exit(main())
