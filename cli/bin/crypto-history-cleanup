#!/bin/bash

# Crypto Service Emergency Response: Git History Cleanup
# Removes private keys from git history per security incident protocol

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
PROJECT_ROOT="$(dirname "$SCRIPT_DIR")"

# Security validation
if [[ "${EUXIS_EMERGENCY_MODE:-}" != "true" ]]; then
    echo "ERROR: This script requires EUXIS_EMERGENCY_MODE=true"
    echo "This is a destructive operation that rewrites git history"
    exit 1
fi

# Backup current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD)
BACKUP_BRANCH="backup-before-key-cleanup-$(date +%Y%m%d-%H%M%S)"

echo "Creating backup branch: $BACKUP_BRANCH"
git branch "$BACKUP_BRANCH"

# Define patterns for private keys and secrets
KEY_PATTERNS=(
    "*.key"
    "*.pem"
    "*_rsa*"
    "*private*"
    "*.p12"
    "*.pfx"
    "id_*"
    "*.crt"
    "*.cer"
)

# Create filter script for git filter-branch
FILTER_SCRIPT=$(mktemp)
cat > "$FILTER_SCRIPT" << 'EOF'
#!/bin/bash
# Remove sensitive files from git index
git rm --cached --ignore-unmatch \
    packages/crypto-lib/src/key/*.key \
    packages/crypto-lib/src/key/*.pem \
    packages/crypto-lib/src/key/*private* \
    crypto_lib/*.key \
    crypto_lib/*.pem \
    *.key \
    *.pem \
    *_rsa* \
    *private* \
    2>/dev/null || true
EOF
chmod +x "$FILTER_SCRIPT"

echo "Removing private keys from git history..."
echo "WARNING: This will rewrite git history permanently"

# Use git filter-branch to remove sensitive files
git filter-branch --force --index-filter "$FILTER_SCRIPT" --prune-empty --tag-name-filter cat -- --all

# Clean up filter-branch refs
git for-each-ref --format="%(refname)" refs/original/ | xargs -n 1 git update-ref -d

# Force garbage collection
git reflog expire --expire=now --all
git gc --prune=now --aggressive

# Clean up
rm -f "$FILTER_SCRIPT"

echo "✓ Git history cleanup completed"
echo "✓ Backup created: $BACKUP_BRANCH"
echo "✓ Private keys removed from git history"
echo ""
echo "IMPORTANT: All team members must re-clone the repository"
echo "IMPORTANT: Force push required: git push --force-with-lease origin main"
echo ""
echo "Audit trail:"
echo "- Backup branch: $BACKUP_BRANCH"
echo "- Cleanup time: $(date -u +%Y-%m-%dT%H:%M:%SZ)"
echo "- Patterns removed: ${KEY_PATTERNS[*]}"