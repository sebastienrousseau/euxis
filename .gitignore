# ============================================================================
# EUXIS .gitignore - 2026 Agent OS Standard
# ============================================================================

# --- Build Artifacts ---
cmake-build/
build/cmake-build/
build/out/
*.o
*.a
*.so
*.dylib
*.exe
*.cwasm

# --- System & IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*~

# --- Data & Runtime (Ignore volatile execution data) ---
data/runtime/context/*
data/runtime/lifecycle/*
data/runtime/metrics/events.jsonl
data/runtime/memory/cortex/db/*
!data/runtime/README.md
!data/runtime/gateway.json

# --- Dependencies ---
node_modules/
_deps/

# --- Secrets & Credentials ---
.env
.env.*
*.key
*.pem
!data/docs/**/*.pem
credentials*
*.p12
*.pfx
*.keystore

# --- Coverage ---
*.gcda
*.gcno
coverage.info
coverage-report/
