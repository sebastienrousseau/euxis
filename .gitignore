# ============================================================================
# EUXIS .gitignore - 2026 Agent OS Standard
# ============================================================================

# --- Build Artifacts ---
cmake-build/
build/cmake-build/
build/out/
*.o
*.a
*.so
*.dylib
*.exe
*.cwasm

# --- System & IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*~
.aider.*

# --- Data & Runtime (Ignore volatile execution data) ---
data/runtime/context/*
data/runtime/lifecycle/*
data/runtime/manifests/*
data/runtime/memory/cortex/*
data/runtime/metrics/*
data/runtime/perf/*
data/runtime/sessions/*
data/runtime/verdicts/*
data/runtime/data/*
data/projects/.euxis/
!data/runtime/README.md
!data/runtime/gateway.json

# --- SQLite ---
*.db-shm
*.db-wal
data/agents/registry.db
data/agents/registry.db.backup.*

# --- Gateway runtime logs ---
data/gateway/**/*.jsonl

# --- Unused root dirs ---
# These are legacy or transient on-disk directories that must never be
# tracked. Some predate the C++23 rewrite (the Python TUI in tui/ was
# superseded by apps/cli/src/tui/); others are tool caches that
# shouldn't be re-introduced. See docs/architecture/legacy-cleanup-2026.md
# for the full rationale.
/bin/
/metrics/
/tui/
/bus/
/packages/
/prompts/
/codex/
/.venv/
/.venv-voice/
/.pytest_cache/
__pycache__/
*.pyc

# --- Dependencies ---
node_modules/
_deps/

# --- Secrets & Credentials ---
.env
.env.*
*.key
*.pem
!docs/**/*.pem
credentials*
*.p12
*.pfx
*.keystore
auth_profiles.json
data/runtime/auth_profiles.json

# --- Coverage ---
*.gcda
*.gcno
coverage.info
coverage-report/
