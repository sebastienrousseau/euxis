# Runtime state (data/ is mostly gitignored)
data/projects/
data/cortex/db/
data/lifecycle/
data/perf/
data/bus/pipes/

# Vector database (runtime data)
cortex_db/

# Audit artifacts (session-specific, not committed)
docs/audits/
docs/audits/v4.5-readiness-report.md

# Voice/TTS
.venv-voice/
.piper-voices/
.tts-cache/

# OS/Editor/Build
.DS_Store
*.log
tmp/
.pytest_cache/
**/.pytest_cache/
.hypothesis/
.coverage
htmlcov/

# Security-sensitive manifests (never commit)
internal_manifest.json
edge-hunter-fixes.json

# Secrets and credentials (never commit)
.env
.env.*
*.key
*.pem
*.p12
*.pfx
credentials.json
config.ini
secrets.yaml
secrets.yml
*.secret

# Override global gitignore that excludes /bin/ (Rust/Go convention)
!bin/
