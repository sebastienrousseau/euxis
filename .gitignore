# ============================================================================
# EUXIS .gitignore - 2026 Agent OS Standard
# ============================================================================

# --- Build Artifacts ---
cmake-build/
build/cmake-build/
build/out/
*.o
*.a
*.so
*.dylib
*.exe
*.cwasm

# --- System & IDE ---
.DS_Store
.vscode/
.idea/
*.swp
*~
.aider.*

# --- Data & Runtime (Ignore volatile execution data) ---
data/runtime/context/*
data/runtime/lifecycle/*
data/runtime/manifests/*
data/runtime/memory/cortex/*
data/runtime/metrics/*
data/runtime/perf/*
data/runtime/sessions/*
data/runtime/verdicts/*
data/runtime/data/*
data/projects/.euxis/
!data/runtime/README.md
!data/runtime/gateway.json

# --- SQLite ---
*.db-shm
*.db-wal
data/agents/registry.db
data/agents/registry.db.backup.*

# --- Gateway runtime logs ---
data/gateway/**/*.jsonl

# --- Unused root dirs ---
metrics/

# --- Dependencies ---
node_modules/
_deps/

# --- Secrets & Credentials ---
.env
.env.*
*.key
*.pem
!docs/**/*.pem
credentials*
*.p12
*.pfx
*.keystore

# --- Coverage ---
*.gcda
*.gcno
coverage.info
coverage-report/
