# ============================================================================
# EUXIS .gitignore - Cross-Platform (macOS, Linux, WSL)
# ============================================================================

# ============================================================================
# PYTHON
# ============================================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
/lib/
/lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.venv/
.venv-*/
venv/
ENV/
env/
.env/

# Testing & Coverage
.pytest_cache/
.hypothesis/
.coverage
.coverage.*
htmlcov/
coverage/
**/coverage/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.cache
nosetests.xml

# Type checkers
.mypy_cache/
.dmypy.json
dmypy.json
.pytype/
.pyre/

# Linters
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ============================================================================
# NODE.JS (if applicable)
# ============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.npm/
.yarn/

# ============================================================================
# IDE & EDITORS
# ============================================================================
# VS Code
.vscode/
*.code-workspace

# JetBrains (PyCharm, IntelliJ, WebStorm)
.idea/
*.iml
*.ipr
*.iws
out/

# Vim/Neovim
*.swp
*.swo
*~
.netrwhist
Session.vim
.vim/

# Emacs
*~
\#*\#
.#*
*.elc
auto-save-list

# Sublime Text
*.sublime-project
*.sublime-workspace

# ============================================================================
# OS-SPECIFIC
# ============================================================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory
.Trash-*

# ============================================================================
# EUXIS RUNTIME DATA
# ============================================================================
# Runtime project data (agent outputs, memory, audits)
runtime/data/**
runtime/memory/cortex/db/
runtime/locks/
runtime/locales/
runtime/baseline/
projects/

# Monorepo runtime paths
euxis-runtime/data/provider-usage/
euxis-runtime/history/
euxis-runtime/mesh/
euxis-runtime/metrics/events.jsonl
euxis-runtime/memory/cortex/db/
euxis-runtime/memory/cortex/db/*.sqlite3
euxis-runtime/memory/cortex/db/*.sqlite3-*
euxis-runtime/memory/cortex/db/*.db
euxis-runtime/memory/cortex/db/*.db-*

# SQLite transient files
*.db-wal
*.db-shm
euxis-core/agents/registry.db-wal
euxis-core/agents/registry.db-shm

# Keep runtime schemas/config that are meant to be tracked
!runtime/data/bus/
!runtime/data/bus/topics.json

# Vector database (ChromaDB runtime)
cortex_db/

# Metrics runtime data (code is tracked, data is not)
metrics/events.jsonl
metrics/sessions.jsonl
metrics/reports/

# Observability runtime
observability/

# Runtime locks
runtime/locks/

# Audit artifacts (session-specific)
docs/audits/

# Generated docs
euxis-docs/_build/

# Voice/TTS (large binary models)
.piper-voices/
.tts-cache/

# Runtime baseline snapshots (regenerated)
baseline_*.json
current/

# Agent work outputs (regenerated)
*_architecture.md
*_analysis.md
*_review.md
*_framework.md
*_sources.md
capability_audit.json
quality-gates.json

# ============================================================================
# BUILD & PACKAGING
# ============================================================================
*.tar.gz
*.zip
*.dmg
*.pkg
*.deb
*.rpm
*.msi
*.exe

# ============================================================================
# SECURITY-SENSITIVE (NEVER COMMIT)
# ============================================================================
.env
.env.*
!.env.example
*.key
*.pem
*.p12
*.pfx
*.crt
credentials.json
config.ini
secrets.yaml
secrets.yml
*.secret
internal_manifest.json
edge-hunter-fixes.json

# ============================================================================
# LOGS & TEMP
# ============================================================================
*.log
tmp/
temp/
*.tmp
*.bak
*.orig

# ============================================================================
# EXCEPTIONS (Explicit includes)
# ============================================================================
# Override global gitignore for bin/ (contains Euxis scripts, not build output)
!bin/

# Keep example env file
!.env.example
tests/*_report.md

# Shell test generated artifacts
euxis-core/tests/coverage/shell/*.tap

# Rust / Cargo
target/
**/*.rs.bk

# Rust test coverage 
*.profraw
*.profdata
*.gcda
*.gcno

# Application specific cache 
euxis-runtime/data/projects/.euxis/
data/gateway/
