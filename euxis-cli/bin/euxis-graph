#!/Users/seb/.euxis/.venv/bin/python3
"""
Euxis Graph Memory (GraphRAG) — Relationship-Aware Knowledge Graph

Usage:
    euxis-graph add-entity <name> --type <type> [--metadata '{"key":"val"}']
    euxis-graph add-edge <src> <dst> --relation <type>
    euxis-graph remove-entity <name>
    euxis-graph remove-edge <src> <dst>
    euxis-graph neighbors <entity> [--depth N]
    euxis-graph shortest-path <src> <dst>
    euxis-graph subgraph <entity> --depth N
    euxis-graph query <pattern>
    euxis-graph stats
    euxis-graph export [--format json|dot]

Node types:  entity | memory | agent | session
Edge relations:  related_to | produced_by | depends_on | contradicts | references | part_of | delegates_to | escalates_to

Requires: pip install networkx
"""

import sys
import os
import json
from datetime import datetime, timezone

try:
    import networkx as nx
    from networkx.readwrite.json_graph import node_link_data, node_link_graph
except ImportError:
    print(json.dumps({"error": "networkx required. Install: pip install networkx"}))
    sys.exit(1)

# ============================================================================
# Configuration
# ============================================================================

GRAPH_DIR = os.path.expanduser("~/.euxis/runtime/memory/cortex")
GRAPH_FILE = os.path.join(GRAPH_DIR, "graph.json")

VALID_NODE_TYPES = {"entity", "memory", "agent", "session"}
VALID_RELATIONS = {
    "related_to", "produced_by", "depends_on", "contradicts",
    "references", "part_of", "delegates_to", "escalates_to",
}


# ============================================================================
# Persistence
# ============================================================================

def ensure_dir():
    """Create graph directory if missing."""
    os.makedirs(GRAPH_DIR, exist_ok=True)


def load_graph():
    """Load the graph from disk, or return an empty DiGraph."""
    ensure_dir()
    if os.path.isfile(GRAPH_FILE):
        with open(GRAPH_FILE, "r") as f:
            data = json.load(f)
        return node_link_graph(data, directed=True, multigraph=False)
    return nx.DiGraph()


def save_graph(G):
    """Persist the graph to disk."""
    ensure_dir()
    data = node_link_data(G)
    with open(GRAPH_FILE, "w") as f:
        json.dump(data, f, indent=2, default=str)


# ============================================================================
# Helpers
# ============================================================================

def now_iso():
    return datetime.now(timezone.utc).isoformat()


def output(obj):
    print(json.dumps(obj, indent=2, default=str))


def err(msg):
    output({"error": msg})
    sys.exit(1)


def parse_flag(args, flag, default=None):
    """Extract --flag value from args list."""
    if flag in args:
        idx = args.index(flag)
        if idx + 1 < len(args):
            return args[idx + 1]
    return default


# ============================================================================
# Commands
# ============================================================================

def cmd_add_entity(args):
    if len(args) < 1:
        err("Usage: euxis-graph add-entity <name> --type <type> [--metadata '{...}']")
    name = args[0]
    ntype = parse_flag(args, "--type", "entity")
    if ntype not in VALID_NODE_TYPES:
        err(f"Invalid node type '{ntype}'. Valid: {sorted(VALID_NODE_TYPES)}")
    meta_raw = parse_flag(args, "--metadata", "{}")
    try:
        metadata = json.loads(meta_raw)
    except json.JSONDecodeError:
        err("Invalid JSON in --metadata")

    G = load_graph()
    if G.has_node(name):
        err(f"Entity '{name}' already exists")
    G.add_node(name, name=name, type=ntype, metadata=metadata, created_at=now_iso())
    save_graph(G)
    output({"status": "ok", "action": "add-entity", "entity": name, "type": ntype})


def cmd_add_edge(args):
    if len(args) < 2:
        err("Usage: euxis-graph add-edge <src> <dst> --relation <type>")
    src, dst = args[0], args[1]
    relation = parse_flag(args, "--relation", "related_to")
    if relation not in VALID_RELATIONS:
        err(f"Invalid relation '{relation}'. Valid: {sorted(VALID_RELATIONS)}")

    G = load_graph()
    if not G.has_node(src):
        err(f"Source entity '{src}' not found")
    if not G.has_node(dst):
        err(f"Destination entity '{dst}' not found")
    if G.has_edge(src, dst):
        err(f"Edge '{src}' -> '{dst}' already exists")
    G.add_edge(src, dst, relation=relation, created_at=now_iso())
    save_graph(G)
    output({"status": "ok", "action": "add-edge", "src": src, "dst": dst, "relation": relation})


def cmd_remove_entity(args):
    if len(args) < 1:
        err("Usage: euxis-graph remove-entity <name>")
    name = args[0]
    G = load_graph()
    if not G.has_node(name):
        err(f"Entity '{name}' not found")
    G.remove_node(name)
    save_graph(G)
    output({"status": "ok", "action": "remove-entity", "entity": name})


def cmd_remove_edge(args):
    if len(args) < 2:
        err("Usage: euxis-graph remove-edge <src> <dst>")
    src, dst = args[0], args[1]
    G = load_graph()
    if not G.has_edge(src, dst):
        err(f"Edge '{src}' -> '{dst}' not found")
    G.remove_edge(src, dst)
    save_graph(G)
    output({"status": "ok", "action": "remove-edge", "src": src, "dst": dst})


def cmd_neighbors(args):
    if len(args) < 1:
        err("Usage: euxis-graph neighbors <entity> [--depth N]")
    entity = args[0]
    depth = int(parse_flag(args, "--depth", "1"))
    if depth < 1:
        err("Depth must be >= 1")

    G = load_graph()
    if not G.has_node(entity):
        err(f"Entity '{entity}' not found")

    # BFS up to depth N
    visited = {}
    queue = [(entity, 0)]
    visited[entity] = 0
    while queue:
        current, d = queue.pop(0)
        if d >= depth:
            continue
        for neighbor in set(list(G.successors(current)) + list(G.predecessors(current))):
            if neighbor not in visited:
                visited[neighbor] = d + 1
                queue.append((neighbor, d + 1))

    # Remove the source entity itself
    visited.pop(entity, None)
    results = [
        {"entity": n, "distance": dist, **G.nodes[n]}
        for n, dist in sorted(visited.items(), key=lambda x: x[1])
    ]
    output({"entity": entity, "depth": depth, "neighbors": results})


def cmd_shortest_path(args):
    if len(args) < 2:
        err("Usage: euxis-graph shortest-path <src> <dst>")
    src, dst = args[0], args[1]
    G = load_graph()
    if not G.has_node(src):
        err(f"Entity '{src}' not found")
    if not G.has_node(dst):
        err(f"Entity '{dst}' not found")
    try:
        path = nx.shortest_path(G, src, dst)
        output({"src": src, "dst": dst, "path": path, "length": len(path) - 1})
    except nx.NetworkXNoPath:
        output({"src": src, "dst": dst, "path": None, "length": -1, "message": "No path found"})


def cmd_subgraph(args):
    if len(args) < 1:
        err("Usage: euxis-graph subgraph <entity> --depth N")
    entity = args[0]
    depth = int(parse_flag(args, "--depth", "1"))

    G = load_graph()
    if not G.has_node(entity):
        err(f"Entity '{entity}' not found")

    undirected = G.to_undirected()
    ego = nx.ego_graph(undirected, entity, radius=depth)
    sub = G.subgraph(ego.nodes()).copy()
    data = node_link_data(sub)
    output({"center": entity, "depth": depth, "nodes": len(sub.nodes), "edges": len(sub.edges), "graph": data})


def cmd_query(args):
    if len(args) < 1:
        err("Usage: euxis-graph query <pattern>")
    pattern = args[0].lower()

    G = load_graph()
    results = []
    for node, attrs in G.nodes(data=True):
        node_name = str(attrs.get("name", node)).lower()
        node_type = str(attrs.get("type", "")).lower()
        if pattern in node_name or pattern in node_type:
            results.append({"entity": node, **attrs})
    output({"pattern": args[0], "count": len(results), "results": results})


def cmd_stats(args):
    G = load_graph()
    undirected = G.to_undirected()
    n_nodes = G.number_of_nodes()
    n_edges = G.number_of_edges()
    components = nx.number_connected_components(undirected) if n_nodes > 0 else 0
    density = nx.density(G) if n_nodes > 0 else 0.0
    output({
        "nodes": n_nodes,
        "edges": n_edges,
        "connected_components": components,
        "density": round(density, 6),
    })


def cmd_export(args):
    fmt = parse_flag(args, "--format", "json")
    G = load_graph()
    if fmt == "json":
        output(node_link_data(G))
    elif fmt == "dot":
        lines = ["digraph euxis_graph {"]
        for n, attrs in G.nodes(data=True):
            label = f'{n}\\n({attrs.get("type", "?")})'
            lines.append(f'  "{n}" [label="{label}"];')
        for src, dst, attrs in G.edges(data=True):
            rel = attrs.get("relation", "related_to")
            lines.append(f'  "{src}" -> "{dst}" [label="{rel}"];')
        lines.append("}")
        output({"format": "dot", "content": "\n".join(lines)})
    else:
        err(f"Unknown format '{fmt}'. Valid: json, dot")


# ============================================================================
# Dispatch
# ============================================================================

COMMANDS = {
    "add-entity": cmd_add_entity,
    "add-edge": cmd_add_edge,
    "remove-entity": cmd_remove_entity,
    "remove-edge": cmd_remove_edge,
    "neighbors": cmd_neighbors,
    "shortest-path": cmd_shortest_path,
    "subgraph": cmd_subgraph,
    "query": cmd_query,
    "stats": cmd_stats,
    "export": cmd_export,
}


def main():
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help", "help"):
        print(__doc__.strip())
        sys.exit(0)

    cmd = sys.argv[1]
    if cmd not in COMMANDS:
        err(f"Unknown command '{cmd}'. Valid: {sorted(COMMANDS.keys())}")

    COMMANDS[cmd](sys.argv[2:])


if __name__ == "__main__":
    main()
