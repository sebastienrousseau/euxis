#!/usr/bin/env bash
#
# euxis-doctor - Verify Euxis installation and environment
#
# Checks:
#   - Shell completions installation
#   - Man page availability
#   - Platform detection
#   - Provider availability
#   - Core dependencies
#

# Note: We don't use set -e here because doctor needs to continue
# even when some checks fail (that's the point of a diagnostic tool)
set -uo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"

# Flags
FIX_MODE=0
ISSUES_FOUND=()

# Parse arguments
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fix)
            FIX_MODE=1
            shift
            ;;
        -h|--help)
            echo "Usage: euxis doctor [--fix]"
            echo ""
            echo "Verify Euxis installation and environment."
            echo ""
            echo "Options:"
            echo "  --fix    Automatically fix detected issues"
            echo "  --help   Show this help"
            exit 0
            ;;
        *)
            shift
            ;;
    esac
done

# Track a fixable issue
# Usage: add_issue <id> <description> <fix_command> [requires_sudo]
add_issue() {
    local id="$1"
    local desc="$2"
    local cmd="$3"
    local needs_sudo="${4:-0}"
    ISSUES_FOUND+=("${id}|${desc}|${cmd}|${needs_sudo}")
}

# Track a missing dependency with platform-specific install instructions
# Usage: add_missing_dep <name> <description>
MISSING_DEPS=()
add_missing_dep() {
    local name="$1"
    local desc="$2"
    MISSING_DEPS+=("${name}|${desc}")
}

# Detect package manager and platform
detect_platform() {
    if [[ "$(uname -s)" == "Darwin" ]]; then
        echo "macos"
    elif [[ -f /etc/debian_version ]]; then
        echo "debian"
    elif [[ -f /etc/fedora-release ]]; then
        echo "fedora"
    elif [[ -f /etc/arch-release ]]; then
        echo "arch"
    elif [[ -f /etc/alpine-release ]]; then
        echo "alpine"
    else
        echo "linux"
    fi
}

# Get install command for a package
get_install_cmd() {
    local pkg="$1"
    local platform=$(detect_platform)

    case "$platform" in
        macos)
            echo "brew install $pkg"
            ;;
        debian)
            echo "sudo apt install -y $pkg"
            ;;
        fedora)
            echo "sudo dnf install -y $pkg"
            ;;
        arch)
            echo "sudo pacman -S --noconfirm $pkg"
            ;;
        alpine)
            echo "sudo apk add $pkg"
            ;;
        *)
            echo "# Install $pkg using your package manager"
            ;;
    esac
}

# Package name mapping per platform (some packages have different names)
get_package_name() {
    local pkg="$1"
    local platform=$(detect_platform)

    case "$pkg" in
        python3)
            case "$platform" in
                arch) echo "python" ;;
                *) echo "python3" ;;
            esac
            ;;
        sqlite3)
            case "$platform" in
                macos) echo "sqlite" ;;
                *) echo "sqlite3" ;;
            esac
            ;;
        *)
            echo "$pkg"
            ;;
    esac
}

# Source UI library
if [[ -f "${EUXIS_HOME}/euxis-core/lib/core.sh" ]]; then
    source "${EUXIS_HOME}/euxis-core/lib/core.sh"
fi

# Source platform library
if [[ -f "${EUXIS_HOME}/euxis-core/lib/platform.sh" ]]; then
    source "${EUXIS_HOME}/euxis-core/lib/platform.sh"
fi

# Colors (256-color, consistent with main CLI)
setup_colors() {
    if [[ -n "${NO_COLOR:-}" ]] || [[ ! -t 1 ]]; then
        RESET="" BOLD="" DIM=""
        RED="" GREEN="" YELLOW="" CYAN="" WHITE=""
    else
        RESET='\033[0m'
        BOLD='\033[1m'
        DIM='\033[2m'
        RED='\033[38;5;203m'
        GREEN='\033[38;5;42m'
        YELLOW='\033[38;5;220m'
        CYAN='\033[38;5;87m'
        WHITE='\033[38;5;255m'
    fi
}

# Icons
setup_icons() {
    if _ui_supports_unicode 2>/dev/null; then
        ICON_OK="✓"
        ICON_WARN="⚠"
        ICON_FAIL="✗"
        ICON_INFO="●"
        ICON_BULLET="▸"
    else
        ICON_OK="+"
        ICON_WARN="!"
        ICON_FAIL="x"
        ICON_INFO="*"
        ICON_BULLET=">"
    fi
}

# Print functions
print_header() {
    echo -e "\n${BOLD}${CYAN}Euxis Doctor${RESET} ${DIM}v0.0.2${RESET}"
    echo -e "${DIM}Checking your Euxis installation...${RESET}\n"
}

print_section() {
    local title="$1"
    echo -e "\n  ${BOLD}${CYAN}${ICON_BULLET} ${title}${RESET}"
}

print_ok() {
    echo -e "    ${GREEN}${ICON_OK}${RESET} $1"
}

print_warn() {
    echo -e "    ${YELLOW}${ICON_WARN}${RESET} $1"
}

print_fail() {
    echo -e "    ${RED}${ICON_FAIL}${RESET} $1"
}

print_info() {
    echo -e "    ${CYAN}${ICON_INFO}${RESET} $1"
}

# Checks
check_platform() {
    print_section "PLATFORM"

    local platform="${EUXIS_PLATFORM:-unknown}"
    local details=""

    case "$platform" in
        macos)
            local arch=$(uname -m)
            local version=$(sw_vers -productVersion 2>/dev/null || echo "unknown")
            details="macOS $version ($arch)"
            if [[ "$arch" == "arm64" ]]; then
                local brew_prefix=$(platform_homebrew_prefix 2>/dev/null || echo "")
                if [[ -n "$brew_prefix" ]]; then
                    details="$details, Homebrew: $brew_prefix"
                fi
            fi
            print_ok "$details"
            ;;
        linux)
            if [[ -f /etc/os-release ]]; then
                local distro=$(grep PRETTY_NAME /etc/os-release | cut -d'"' -f2)
                details="Linux: $distro"
            else
                details="Linux: $(uname -r)"
            fi
            print_ok "$details"
            ;;
        wsl)
            local wsl_ver=$(_wsl_version 2>/dev/null || echo "?")
            local distro="${WSL_DISTRO_NAME:-unknown}"
            print_ok "WSL$wsl_ver: $distro"
            ;;
        *)
            print_warn "Unknown platform: $(uname -s)"
            ;;
    esac
}

check_shell() {
    print_section "SHELL"

    local shell_name=$(basename "${SHELL:-unknown}")
    local shell_version=$("$SHELL" --version 2>&1 | head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1 || echo "")
    print_info "Current shell: $shell_name ${shell_version}"

    # Check completions
    case "$shell_name" in
        bash)
            if [[ -f ~/.bash_completion.d/euxis.bash ]] || [[ -f /etc/bash_completion.d/euxis.bash ]]; then
                print_ok "Bash completions installed"
            else
                print_warn "Bash completions not installed"
                add_issue "bash_completions" "Install Bash completions" \
                    "mkdir -p ~/.bash_completion.d && cp ${EUXIS_HOME}/euxis-cli/completions/euxis.bash ~/.bash_completion.d/" "0"
            fi
            ;;
        zsh)
            # Check common Zsh completion paths
            local zsh_found=0
            local zsh_paths=(
                "$HOME/.zsh/completions/_euxis"
                "$HOME/.zfunc/_euxis"
                "/usr/local/share/zsh/site-functions/_euxis"
                "/usr/share/zsh/site-functions/_euxis"
                "/opt/homebrew/share/zsh/site-functions/_euxis"
            )
            for zpath in "${zsh_paths[@]}"; do
                if [[ -f "$zpath" ]]; then
                    zsh_found=1
                    print_ok "Zsh completions installed ($zpath)"
                    break
                fi
            done

            if [[ $zsh_found -eq 0 ]]; then
                print_warn "Zsh completions not installed"
                add_issue "zsh_completions" "Install Zsh completions" \
                    "mkdir -p ~/.zfunc && cp ${EUXIS_HOME}/euxis-cli/completions/euxis.zsh ~/.zfunc/_euxis" "0"
            fi
            ;;
        fish)
            if [[ -f ~/.config/fish/completions/euxis.fish ]]; then
                print_ok "Fish completions installed"
            else
                print_warn "Fish completions not installed"
                add_issue "fish_completions" "Install Fish completions" \
                    "mkdir -p ~/.config/fish/completions && cp ${EUXIS_HOME}/euxis-cli/completions/euxis.fish ~/.config/fish/completions/" "0"
            fi
            ;;
        *)
            print_info "Shell completions: manual check required for $shell_name"
            ;;
    esac
}

check_man_page() {
    print_section "DOCUMENTATION"

    if man -w euxis &>/dev/null; then
        print_ok "Man page installed (man euxis)"
    else
        # Check if we have the source and can generate it
        local platform=$(detect_platform)
        local pandoc_install=$(get_install_cmd "pandoc")

        if [[ -f "${EUXIS_HOME}/euxis-docs/man/euxis.1.md" ]]; then
            if command -v pandoc &>/dev/null; then
                print_warn "Man page not installed"
                add_issue "man_page" "Install man page (generate from markdown)" \
                    "pandoc ${EUXIS_HOME}/euxis-docs/man/euxis.1.md -s -t man -o /usr/local/share/man/man1/euxis.1 && mandb" "1"
            else
                print_warn "Man page not installed (requires pandoc)"
                print_info "  Install pandoc first: ${pandoc_install}"
                add_missing_dep "pandoc" "pandoc (required for man page)"
            fi
        elif [[ -f "${EUXIS_HOME}/euxis-docs/man/euxis.1" ]]; then
            # Pre-generated man page exists
            print_warn "Man page not installed"
            add_issue "man_page" "Install man page (copy pre-generated)" \
                "cp ${EUXIS_HOME}/euxis-docs/man/euxis.1 /usr/local/share/man/man1/ && mandb" "1"
        else
            print_warn "Man page source not found"
        fi
    fi
}

check_providers() {
    print_section "AI PROVIDERS"

    local providers=("claude" "gemini" "openai" "ollama" "goose")
    local found=0

    for provider in "${providers[@]}"; do
        case "$provider" in
            claude)
                if command -v claude &>/dev/null; then
                    print_ok "claude (Anthropic Claude Code)"
                    found=$((found + 1))
                fi
                ;;
            gemini)
                if command -v gemini &>/dev/null; then
                    print_ok "gemini (Google Gemini)"
                    found=$((found + 1))
                fi
                ;;
            openai)
                if [[ -n "${OPENAI_API_KEY:-}" ]] || command -v openai &>/dev/null; then
                    print_ok "openai (OpenAI)"
                    found=$((found + 1))
                fi
                ;;
            ollama)
                if command -v ollama &>/dev/null; then
                    local models=$(ollama list 2>/dev/null | tail -n +2 | wc -l || echo "0")
                    print_ok "ollama ($models models available)"
                    found=$((found + 1))
                fi
                ;;
            goose)
                if command -v goose &>/dev/null; then
                    print_ok "goose (Goose AI)"
                    found=$((found + 1))
                fi
                ;;
        esac
    done

    if [[ $found -eq 0 ]]; then
        print_fail "No AI providers found"
        print_info "  Install at least one: claude, gemini, ollama, etc."
    fi
}

check_dependencies() {
    print_section "DEPENDENCIES"

    local platform=$(detect_platform)
    local deps=("jq" "git" "python3" "sqlite3")

    for dep in "${deps[@]}"; do
        if command -v "$dep" &>/dev/null; then
            local version=$("$dep" --version 2>&1 | head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1 || echo "")
            print_ok "$dep ${version:+($version)}"
        else
            local pkg_name=$(get_package_name "$dep")
            local install_cmd=$(get_install_cmd "$pkg_name")
            print_fail "$dep not found"
            print_info "  Install: ${install_cmd}"
            add_missing_dep "$pkg_name" "$dep (required)"
        fi
    done

    # Optional dependencies with install hints
    local -A optional_deps=(
        ["pandoc"]="man page generation"
        ["docker"]="containerized deployments"
    )
    echo ""
    print_info "Optional:"
    for dep in "${!optional_deps[@]}"; do
        local purpose="${optional_deps[$dep]}"
        if command -v "$dep" &>/dev/null; then
            print_ok "$dep (available) - ${purpose}"
        else
            local pkg_name=$(get_package_name "$dep")
            local install_cmd=$(get_install_cmd "$pkg_name")
            print_info "$dep (not installed) - ${purpose}"
            echo -e "         ${DIM}Install: ${install_cmd}${RESET}"
        fi
    done
}

check_euxis_installation() {
    print_section "EUXIS INSTALLATION"

    # Check EUXIS_HOME
    if [[ -d "$EUXIS_HOME" ]]; then
        print_ok "EUXIS_HOME: $EUXIS_HOME"
    else
        print_fail "EUXIS_HOME not found: $EUXIS_HOME"
        return 1
    fi

    # Check core directories
    local core_dirs=("euxis-core" "euxis-cli" "euxis-runtime")
    for dir in "${core_dirs[@]}"; do
        if [[ -d "${EUXIS_HOME}/${dir}" ]]; then
            print_ok "$dir/"
        else
            print_warn "$dir/ missing"
        fi
    done

    # Check registry
    if [[ -f "${EUXIS_HOME}/euxis-core/agents/registry.json" ]]; then
        local agent_count=$(jq '.agents | length' "${EUXIS_HOME}/euxis-core/agents/registry.json" 2>/dev/null || echo "?")
        print_ok "Agent registry: $agent_count agents"
    else
        print_fail "Agent registry not found"
    fi

    # Check CLI schema
    if [[ -f "${EUXIS_HOME}/euxis-core/config/cli-schema.json" ]]; then
        print_ok "CLI schema present"
    else
        print_warn "CLI schema missing"
    fi
}

check_terminal_capabilities() {
    print_section "TERMINAL"

    print_info "TERM: ${TERM:-unset}"

    if _ui_supports_unicode 2>/dev/null; then
        print_ok "Unicode support"
    else
        print_warn "No Unicode support (ASCII fallback)"
    fi

    if platform_supports_256color 2>/dev/null; then
        print_ok "256-color support"
    else
        print_info "Basic color mode"
    fi

    if platform_supports_truecolor 2>/dev/null; then
        print_ok "Truecolor support"
    fi

    if _ui_is_ci 2>/dev/null; then
        print_info "CI/CD environment detected"
    fi
}

print_environment_signature() {
    # Fastfetch-style environment signature
    # ASCII logo on left, system info on right

    echo ""
    echo -e "  ${DIM}────────────────────────────────────────────────────────${RESET}"
    echo -e "  ${BOLD}${WHITE}ENVIRONMENT SIGNATURE${RESET}"
    echo ""

    # Gather system info
    local os_name arch
    if [[ -f /etc/os-release ]]; then
        os_name=$(grep "^PRETTY_NAME=" /etc/os-release 2>/dev/null | cut -d'"' -f2)
        [[ -z "$os_name" ]] && os_name=$(grep "^NAME=" /etc/os-release | cut -d'"' -f2)
    elif command -v sw_vers &>/dev/null; then
        os_name="macOS $(sw_vers -productVersion)"
    else
        os_name="$(uname -s) $(uname -r)"
    fi
    arch=$(uname -m)

    # Detect arch type with friendly names
    local arch_label="$arch"
    case "$arch" in
        arm64|aarch64)
            if [[ "$(uname -s)" == "Darwin" ]]; then
                arch_label="arm64 (Apple Silicon)"
            else
                arch_label="aarch64 (ARM)"
            fi
            ;;
        x86_64|amd64)
            arch_label="x86_64 (Intel/AMD)"
            ;;
    esac

    # Shell info
    local shell_name shell_version
    shell_name=$(basename "${SHELL:-unknown}")
    shell_version=$("$SHELL" --version 2>&1 | head -1 | grep -oE '[0-9]+\.[0-9]+(\.[0-9]+)?' | head -1 || echo "")

    # Primary provider detection
    local primary_provider="none"
    for p in claude gemini openai ollama goose; do
        if command -v "$p" &>/dev/null; then
            primary_provider="$p"
            break
        fi
    done

    # ASCII logo (Euxis stylized 'E')
    # Logo lines paired with info lines for side-by-side display
    local logo1="    ${CYAN}███████${RESET}"
    local logo2="    ${CYAN}██${RESET}     "
    local logo3="    ${CYAN}█████${RESET}  "
    local logo4="    ${CYAN}██${RESET}     "
    local logo5="    ${CYAN}███████${RESET}"

    # Build info lines
    local info1=$(printf "${CYAN}%-12s${RESET} ${WHITE}%s${RESET}" "Euxis:" "v0.0.2")
    local info2=$(printf "${CYAN}%-12s${RESET} ${WHITE}%s${RESET}" "OS:" "$os_name")
    local info3=$(printf "${CYAN}%-12s${RESET} ${WHITE}%s${RESET}" "Arch:" "$arch_label")
    local info4=$(printf "${CYAN}%-12s${RESET} ${WHITE}%s %s${RESET}" "Shell:" "$shell_name" "$shell_version")
    local info5=$(printf "${CYAN}%-12s${RESET} ${WHITE}%s${RESET} ${DIM}(Primary)${RESET}" "Provider:" "$primary_provider")

    # Print logo and info side by side
    echo -e "${logo1}    ${info1}"
    echo -e "${logo2}    ${info2}"
    echo -e "${logo3}    ${info3}"
    echo -e "${logo4}    ${info4}"
    echo -e "${logo5}    ${info5}"
    echo ""
}

print_summary() {
    print_environment_signature
    echo -e "  ${DIM}Copy the above when reporting issues at:${RESET}"
    echo -e "  ${CYAN}https://github.com/euxis/euxis/issues${RESET}"
    echo ""
}

# Fix detected issues
fix_issues() {
    local has_issues=0
    local user_cmds=()
    local sudo_cmds=()

    # Check for missing dependencies first
    if [[ ${#MISSING_DEPS[@]} -gt 0 ]]; then
        has_issues=1
        echo -e "\n  ${BOLD}${CYAN}${ICON_BULLET} MISSING DEPENDENCIES (${#MISSING_DEPS[@]})${RESET}"
        echo ""

        local platform=$(detect_platform)
        local install_cmds=()

        for dep_entry in "${MISSING_DEPS[@]}"; do
            IFS='|' read -r pkg desc <<< "$dep_entry"
            echo -e "    ${RED}${ICON_FAIL}${RESET} ${desc}"
            install_cmds+=("$pkg")
        done

        # Build combined install command
        if [[ ${#install_cmds[@]} -gt 0 ]]; then
            local combined_install=""
            case "$platform" in
                macos)
                    combined_install="brew install ${install_cmds[*]}"
                    ;;
                debian)
                    combined_install="sudo apt install -y ${install_cmds[*]}"
                    sudo_cmds+=("apt install -y ${install_cmds[*]}")
                    ;;
                fedora)
                    combined_install="sudo dnf install -y ${install_cmds[*]}"
                    sudo_cmds+=("dnf install -y ${install_cmds[*]}")
                    ;;
                arch)
                    combined_install="sudo pacman -S --noconfirm ${install_cmds[*]}"
                    sudo_cmds+=("pacman -S --noconfirm ${install_cmds[*]}")
                    ;;
                alpine)
                    combined_install="sudo apk add ${install_cmds[*]}"
                    sudo_cmds+=("apk add ${install_cmds[*]}")
                    ;;
            esac
            echo ""
            echo -e "    ${CYAN}${ICON_INFO}${RESET} Install all: ${WHITE}${combined_install}${RESET}"
        fi
    fi

    # Check for fixable issues
    if [[ ${#ISSUES_FOUND[@]} -gt 0 ]]; then
        has_issues=1
        echo -e "\n  ${BOLD}${CYAN}${ICON_BULLET} FIXABLE ISSUES (${#ISSUES_FOUND[@]})${RESET}"
        echo ""

        for issue in "${ISSUES_FOUND[@]}"; do
            IFS='|' read -r id desc cmd needs_sudo <<< "$issue"
            echo -e "    ${YELLOW}${ICON_WARN}${RESET} ${desc}"
            echo -e "       ${DIM}${cmd}${RESET}"

            if [[ "$needs_sudo" == "1" ]] || [[ "$cmd" == sudo* ]]; then
                sudo_cmds+=("${cmd#sudo }")
            else
                user_cmds+=("$cmd")
            fi
        done
    fi

    if [[ $has_issues -eq 0 ]]; then
        echo -e "\n  ${GREEN}${ICON_OK}${RESET} No fixable issues detected."
        return 0
    fi

    # In fix mode, batch and execute
    if [[ $FIX_MODE -eq 1 ]]; then
        echo ""
        echo -e "  ${BOLD}${CYAN}${ICON_BULLET} PROPOSED FIXES${RESET}"
        echo ""

        # Show all commands that will be run
        if [[ ${#user_cmds[@]} -gt 0 ]]; then
            echo -e "    ${WHITE}User commands:${RESET}"
            for cmd in "${user_cmds[@]}"; do
                echo -e "      ${DIM}\$ ${cmd}${RESET}"
            done
        fi

        if [[ ${#sudo_cmds[@]} -gt 0 ]]; then
            echo -e "    ${WHITE}Sudo commands:${RESET}"
            for cmd in "${sudo_cmds[@]}"; do
                echo -e "      ${DIM}\$ sudo ${cmd}${RESET}"
            done
        fi

        echo ""
        echo -en "  ${YELLOW}?${RESET} Execute these commands? [y/N] "
        read -r response

        if [[ "$response" =~ ^[Yy]$ ]]; then
            echo ""
            # Run user commands
            for cmd in "${user_cmds[@]}"; do
                echo -e "    ${CYAN}▸${RESET} ${cmd}"
                if eval "$cmd" 2>&1 | sed 's/^/      /'; then
                    echo -e "      ${GREEN}${ICON_OK}${RESET} Done"
                else
                    echo -e "      ${RED}${ICON_FAIL}${RESET} Failed"
                fi
            done

            # Run sudo commands (batched)
            if [[ ${#sudo_cmds[@]} -gt 0 ]]; then
                for cmd in "${sudo_cmds[@]}"; do
                    echo -e "    ${CYAN}▸${RESET} sudo ${cmd}"
                    if sudo bash -c "$cmd" 2>&1 | sed 's/^/      /'; then
                        echo -e "      ${GREEN}${ICON_OK}${RESET} Done"
                    else
                        echo -e "      ${RED}${ICON_FAIL}${RESET} Failed"
                    fi
                done
            fi

            echo ""
            echo -e "  ${GREEN}${ICON_OK}${RESET} Fix complete. Run ${CYAN}euxis doctor${RESET} again to verify."
        else
            echo -e "  ${DIM}Skipped. You can run the commands manually.${RESET}"
        fi
    else
        echo ""
        echo -e "  ${DIM}Run ${CYAN}euxis doctor --fix${RESET}${DIM} to fix these issues.${RESET}"
    fi
}

# Main
main() {
    setup_colors
    setup_icons

    print_header
    check_platform
    check_euxis_installation
    check_shell
    check_man_page
    check_providers
    check_dependencies
    check_terminal_capabilities

    # Show fixable issues
    fix_issues

    print_summary
}

main
