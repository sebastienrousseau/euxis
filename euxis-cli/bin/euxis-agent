#!/usr/bin/env bash
# Euxis Agent Management CLI

set -euo pipefail
EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
source "${EUXIS_HOME}/euxis-core/lib/common.sh"
source "${EUXIS_HOME}/euxis-core/lib/agents.sh"

cmd="${1:-}"

usage() {
    if type ui_auto_header &>/dev/null; then ui_auto_header; fi
    cat <<'EOF'
euxis-agent — Agent management and registry

Usage:
  euxis-agent list
  euxis-agent register <path/to/manifest.json>
  euxis-agent unregister <agent_id>

Commands:
  list         List all registered agents from the registry
  register     Register a custom agent using a valid JSON manifest
  unregister   Remove an agent from the registry by its identifier

Options:
  -h, --help   Show this help text
EOF
    if type ui_signature &>/dev/null; then ui_signature; fi
}

if [[ "$cmd" == "-h" || "$cmd" == "--help" ]]; then
    usage
    exit 0
fi

case "$cmd" in
    register)
        manifest="${2:-}"
        if [[ -z "$manifest" ]]; then
            log_error "Usage: euxis agent register <path/to/manifest.json>"
            exit 1
        fi
        register_agent_plugin "$manifest"
        ;;
    unregister)
        agent_id="${2:-}"
        if [[ -z "$agent_id" ]]; then
            log_error "Usage: euxis agent unregister <agent_id>"
            exit 1
        fi
        unregister_agent_plugin "$agent_id"
        ;;
    list)
        list_plugins
        ;;
    *)
        usage >&2
        exit 1
        ;;
esac
