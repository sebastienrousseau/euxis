#!/usr/bin/env bash
# Pre-commit hook for shell script quality enforcement
# Enforces ShellCheck, shfmt, and security checks before commits

set -euo pipefail

# Configuration
HOOK_NAME="pre-commit"
EUXIS_ROOT="$(git rev-parse --show-toplevel)"
TEMP_DIR="${TMPDIR:-/tmp}/euxis-pre-commit-$$"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() {
    echo -e "${BLUE}[${HOOK_NAME}]${NC} $*" >&2
}

log_success() {
    echo -e "${GREEN}[${HOOK_NAME}]${NC} $*" >&2
}

log_warning() {
    echo -e "${YELLOW}[${HOOK_NAME}]${NC} $*" >&2
}

log_error() {
    echo -e "${RED}[${HOOK_NAME}]${NC} $*" >&2
}

# Cleanup function
cleanup() {
    if [[ -d "${TEMP_DIR}" ]]; then
        rm -rf "${TEMP_DIR}"
    fi
}

trap cleanup EXIT

# Check required tools
check_tools() {
    local missing_tools=()

    if ! command -v shellcheck &>/dev/null; then
        missing_tools+=("shellcheck")
    fi

    if ! command -v shfmt &>/dev/null; then
        missing_tools+=("shfmt")
    fi

    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        log_error "Missing required tools: ${missing_tools[*]}"
        log_error "Install with: brew install ${missing_tools[*]} (macOS) or apt-get install ${missing_tools[*]} (Ubuntu)"
        return 1
    fi

    return 0
}

# Get staged shell scripts
get_staged_shell_scripts() {
    mkdir -p "${TEMP_DIR}"
    local staged_files="${TEMP_DIR}/staged_files"

    # Get staged files
    git diff --cached --name-only --diff-filter=ACM > "${staged_files}"

    # Filter for shell scripts
    {
        # .sh files
        grep '\.sh$' "${staged_files}" || true
        # Files with shell shebangs
        while IFS= read -r file; do
            if [[ -f "${EUXIS_ROOT}/${file}" ]]; then
                if head -1 "${EUXIS_ROOT}/${file}" | grep -q '^#!/.*\(bash\|sh\)'; then
                    echo "$file"
                fi
            fi
        done < "${staged_files}"
    } | sort | uniq > "${TEMP_DIR}/shell_scripts"

    if [[ ! -s "${TEMP_DIR}/shell_scripts" ]]; then
        return 1  # No shell scripts staged
    fi

    return 0
}

# Run ShellCheck on staged files
run_shellcheck() {
    log_info "Running ShellCheck analysis..."
    local failed_files=0

    while IFS= read -r file; do
        local full_path="${EUXIS_ROOT}/${file}"
        if [[ -f "${full_path}" ]]; then
            log_info "Checking: ${file}"
            if ! shellcheck -S error -o all "${full_path}"; then
                log_error "ShellCheck failed for: ${file}"
                ((failed_files++))
            fi
        fi
    done < "${TEMP_DIR}/shell_scripts"

    if [[ ${failed_files} -gt 0 ]]; then
        log_error "ShellCheck failed for ${failed_files} files"
        return 1
    fi

    log_success "ShellCheck passed for all staged scripts"
    return 0
}

# Check formatting with shfmt
check_formatting() {
    log_info "Checking shell script formatting..."
    local format_failures=0
    local files_to_fix=()

    while IFS= read -r file; do
        local full_path="${EUXIS_ROOT}/${file}"
        if [[ -f "${full_path}" ]]; then
            if ! shfmt -i 2 -bn -ci -sr -d "${full_path}" &>/dev/null; then
                log_error "Format violation: ${file}"
                files_to_fix+=("${file}")
                ((format_failures++))
            fi
        fi
    done < "${TEMP_DIR}/shell_scripts"

    if [[ ${format_failures} -gt 0 ]]; then
        log_error "Format violations found in ${format_failures} files"
        log_info "To fix formatting, run:"
        for file in "${files_to_fix[@]}"; do
            echo "  shfmt -i 2 -bn -ci -sr -w ${file}"
        done
        return 1
    fi

    log_success "All staged scripts are properly formatted"
    return 0
}

# Check for strict error handling
check_error_handling() {
    log_info "Checking for strict error handling..."
    local missing_strict=0

    while IFS= read -r file; do
        local full_path="${EUXIS_ROOT}/${file}"
        if [[ -f "${full_path}" ]]; then
            # Skip library files that are sourced
            if [[ "${file}" =~ /lib/ ]]; then
                if ! grep -q "set -euo pipefail\|set -e" "${full_path}"; then
                    log_warning "${file} lacks error handling (library file - may be acceptable)"
                fi
            else
                if ! grep -q "set -euo pipefail" "${full_path}"; then
                    log_error "${file} lacks 'set -euo pipefail'"
                    ((missing_strict++))
                fi
            fi
        fi
    done < "${TEMP_DIR}/shell_scripts"

    if [[ ${missing_strict} -gt 0 ]]; then
        log_error "${missing_strict} executable scripts lack proper error handling"
        log_info "Add 'set -euo pipefail' near the top of each script"
        return 1
    fi

    log_success "All executable scripts have proper error handling"
    return 0
}

# Quick security check for dangerous patterns
security_check() {
    log_info "Running security checks..."
    local security_issues=0

    while IFS= read -r file; do
        local full_path="${EUXIS_ROOT}/${file}"
        if [[ -f "${full_path}" ]]; then
            # Check for eval usage
            if grep -n "eval\s*\$" "${full_path}"; then
                log_error "Dangerous eval usage in ${file}"
                ((security_issues++))
            fi

            # Check for curl/wget piped to shell
            if grep -n "curl.*|.*sh\|wget.*|.*sh" "${full_path}"; then
                log_error "Dangerous pipe-to-shell pattern in ${file}"
                ((security_issues++))
            fi
        fi
    done < "${TEMP_DIR}/shell_scripts"

    if [[ ${security_issues} -gt 0 ]]; then
        log_error "${security_issues} security issues found"
        return 1
    fi

    log_success "No security issues detected"
    return 0
}

# Main execution
main() {
    log_info "Starting shell script pre-commit checks"

    # Check for required tools
    if ! check_tools; then
        exit 1
    fi

    # Get staged shell scripts
    if ! get_staged_shell_scripts; then
        log_info "No shell scripts staged, skipping checks"
        exit 0
    fi

    local script_count
    script_count=$(wc -l < "${TEMP_DIR}/shell_scripts")
    log_info "Found ${script_count} staged shell scripts"

    # Run all checks
    local failed_checks=0

    if ! run_shellcheck; then
        ((failed_checks++))
    fi

    if ! check_formatting; then
        ((failed_checks++))
    fi

    if ! check_error_handling; then
        ((failed_checks++))
    fi

    if ! security_check; then
        ((failed_checks++))
    fi

    # Final result
    if [[ ${failed_checks} -gt 0 ]]; then
        echo ""
        log_error "PRE-COMMIT FAILED: ${failed_checks} check(s) failed"
        log_error "Fix the issues above and retry the commit"
        exit 1
    else
        echo ""
        log_success "All shell script checks passed"
        log_success "✅ ShellCheck ✅ Format ✅ Error handling ✅ Security"
        exit 0
    fi
}

# Run main function
main "$@"