#!/usr/bin/env bash
# EUXIS GYM: Automated Evaluation Framework with A/B Testing
# Usage: euxis-gym <agent> <test_case_path>
#        euxis-gym --ab <agent> <test_case_path> <provider_a> <provider_b>
#
# Modes:
#   Single eval: Run one agent against a test case and score 0-100
#   A/B testing:  Run the same agent with two providers, compare scores

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/core.sh" ]]; then
  # shellcheck source=core/lib/core.sh
  source "${EUXIS_HOME}/euxis-core/lib/core.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-gym — Evaluation framework with A/B testing

Usage:
  euxis-gym <agent> <test_case_path>
  euxis-gym --ab <agent> <test_case_path> <provider_a> <provider_b>

Modes:
  Single eval: Run one agent against a test case and score 0-100
  A/B testing:  Compare the same agent across two providers

Options:
  --ab        Enable A/B testing mode
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

MODE="single"
LOG_FILE="/tmp/euxis_gym_result.md"

if [[ "${1:-}" == "--ab" ]]; then
    MODE="ab"
    shift
    AGENT="${1:-}"
    TEST_CASE="${2:-}"
    PROVIDER_A="${3:-claude}"
    PROVIDER_B="${4:-gemini}"
    if [[ -z "$AGENT" || -z "$TEST_CASE" ]]; then
        echo "Usage: euxis-gym --ab <agent> <test_case_path> <provider_a> <provider_b>"
        echo "  Example: euxis-gym --ab architect tests/architect-01.txt claude gemini"
        exit 1
    fi
else
    AGENT="${1:-}"
    TEST_CASE="${2:-}"
    PROVIDER="${3:-claude}"
    if [[ -z "$AGENT" || -z "$TEST_CASE" ]]; then
        echo "Usage: euxis-gym <agent> <test_case_path> [provider]"
        echo "       euxis-gym --ab <agent> <test_case_path> <provider_a> <provider_b>"
        exit 1
    fi
fi

if [[ ! -f "$TEST_CASE" ]]; then
    echo "ERROR: Test case not found: $TEST_CASE"
    exit 1
fi

# 1. READ THE TEST
INPUT=$(sed -n '/INPUT:/,/EXPECTED_OUTPUT:/p' "$TEST_CASE" | sed 's/INPUT://' | sed 's/EXPECTED_OUTPUT://')
EXPECTED=$(sed -n '/EXPECTED_OUTPUT:/,$p' "$TEST_CASE" | sed 's/EXPECTED_OUTPUT://')

# Judge function: scores an output 0-100
judge_output() {
    local input="$1"
    local output="$2"
    local expected="$3"
    local label="$4"

    local judge_prompt="
You are the Gym Referee. Compare the Actual Output against the Expected Criteria.
---
TASK: $input
---
ACTUAL OUTPUT:
$output
---
EXPECTED CRITERIA:
$expected
---
VERDICT:
Rate the Actual Output from 0-100.
Provide a 1-sentence explanation.
Format: SCORE: <num> | REASON: <text>
"
    local result
    result=$(claude -p "$judge_prompt")
    echo "  [$label] $result"
    echo "$result"
}

if [[ "$MODE" == "ab" ]]; then
    echo ""
    echo "╔═══════════════════════════════════════════════════╗"
    echo "║         EUXIS GYM — A/B TEST                     ║"
    echo "╠═══════════════════════════════════════════════════╣"
    echo "║  Agent:      $AGENT"
    echo "║  Test:       $TEST_CASE"
    echo "║  Provider A: $PROVIDER_A"
    echo "║  Provider B: $PROVIDER_B"
    echo "╚═══════════════════════════════════════════════════╝"
    echo ""

    # Run variant A
    echo "  Running variant A ($PROVIDER_A)..."
    OUTPUT_A=$(euxis "$AGENT" "$INPUT" "$PROVIDER_A")

    # Run variant B
    echo "  Running variant B ($PROVIDER_B)..."
    OUTPUT_B=$(euxis "$AGENT" "$INPUT" "$PROVIDER_B")

    # Judge both
    echo ""
    echo "━━━ Scoring ━━━"
    RESULT_A=$(judge_output "$INPUT" "$OUTPUT_A" "$EXPECTED" "$PROVIDER_A")
    RESULT_B=$(judge_output "$INPUT" "$OUTPUT_B" "$EXPECTED" "$PROVIDER_B")

    # Extract numeric scores
    SCORE_A=$(echo "$RESULT_A" | grep -oE 'SCORE:[[:space:]]*[0-9]+' | tail -1 | sed 's/[^0-9]*//g')
    SCORE_B=$(echo "$RESULT_B" | grep -oE 'SCORE:[[:space:]]*[0-9]+' | tail -1 | sed 's/[^0-9]*//g')
    [[ -n "$SCORE_A" ]] || SCORE_A="?"
    [[ -n "$SCORE_B" ]] || SCORE_B="?"

    echo ""
    echo "━━━ A/B Result ━━━"
    echo "  $PROVIDER_A: $SCORE_A/100"
    echo "  $PROVIDER_B: $SCORE_B/100"

    if [[ "$SCORE_A" =~ ^[0-9]+$ && "$SCORE_B" =~ ^[0-9]+$ ]]; then
        if [[ "$SCORE_A" -gt "$SCORE_B" ]]; then
            echo "  WINNER: $PROVIDER_A (+$((SCORE_A - SCORE_B)))"
        elif [[ "$SCORE_B" -gt "$SCORE_A" ]]; then
            echo "  WINNER: $PROVIDER_B (+$((SCORE_B - SCORE_A)))"
        else
            echo "  TIE"
        fi
    fi

    # Log
    {
        echo "## A/B Test: $AGENT — $(date '+%Y-%m-%d %H:%M')"
        echo "- **Test:** $TEST_CASE"
        echo "- **$PROVIDER_A:** $SCORE_A/100"
        echo "- **$PROVIDER_B:** $SCORE_B/100"
        echo ""
    } >> "$LOG_FILE"

else
    echo "EUXIS GYM: Evaluating $AGENT ($PROVIDER)..."

    # 2. RUN THE AGENT
    OUTPUT=$(euxis "$AGENT" "$INPUT" "$PROVIDER")

    # 3. EVALUATE
    RESULT=$(judge_output "$INPUT" "$OUTPUT" "$EXPECTED" "$PROVIDER")

    echo "---------------------------------------------------"
    echo "test: $TEST_CASE"
    echo "agent: $AGENT"
    echo "provider: $PROVIDER"
    echo "$RESULT"
    echo "---------------------------------------------------"

    # 4. LOG RESULT
    {
        echo "## Eval: $AGENT ($PROVIDER) — $(date '+%Y-%m-%d %H:%M')"
        echo "- **Test:** $TEST_CASE"
        echo "- **Result:** $RESULT"
        echo ""
    } >> "$LOG_FILE"
fi
