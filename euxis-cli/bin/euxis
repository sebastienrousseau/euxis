#!/bin/sh
# Ultra-fast entry point — /bin/sh for minimal startup overhead

# Fast-path: --version without any library loading
case "${1:-}" in
  --version) echo "euxis 0.1.0"; exit 0 ;;
esac

# Resolve symlinks to find the real script directory
_self="$0"
while [ -L "$_self" ]; do
    _dir="$(cd "$(dirname "$_self")" && pwd)"
    _self="$(readlink "$_self")"
    case "$_self" in /*) ;; *) _self="$_dir/$_self" ;; esac
done
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
exec "$SCRIPT_DIR/euxis.sh" "$@"
