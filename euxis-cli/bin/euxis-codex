#!/usr/bin/env bash
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/euxis-core/lib/ui.sh"
  ui_auto_header
fi


EUXIS_DIR="$HOME/.euxis"
CODEX_DIR="$EUXIS_DIR/config/codex"
CODEX_MANIFEST="$CODEX_DIR/codex.json"

usage() {
  cat <<'EOF'
euxis-codex — Prompt template library

Usage:
  euxis-codex list
  euxis-codex info <id>
  euxis-codex show <id>
  euxis-codex run <id> VAR=value [VAR=value ...] [--provider PROVIDER]

Commands:
  list    Table of all templates
  info    Template details, variables, and target agents
  show    Print raw template content
  run     Substitute variables and execute via target agent

Options:
  --provider  Override provider for execution
  -h, --help  Show this help text
EOF
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
  fi
}

require_manifest() {
  if [[ ! -f "$CODEX_MANIFEST" ]]; then
    echo "Error: codex.json not found at $CODEX_MANIFEST" >&2
    exit 1
  fi
}

validate_template_id() {
  local id="$1"
  local exists
  exists=$(jq -r --arg id "$id" '.templates[] | select(.id == $id) | .id' "$CODEX_MANIFEST")
  if [[ -z "$exists" ]]; then
    echo "Error: Unknown template '$id'. Run 'euxis-codex list' to see available templates." >&2
    exit 1
  fi
}

get_template() {
  local id="$1"
  jq --arg id "$id" '.templates[] | select(.id == $id)' "$CODEX_MANIFEST"
}

cmd_list() {
  require_jq
  require_manifest

  printf "%-18s %-22s %-12s %s\n" "ID" "NAME" "CATEGORY" "DESCRIPTION"
  printf "%-18s %-22s %-12s %s\n" "---" "---" "---" "---"

  jq -r '.templates[] | [.id, .name, .category, .description] | @tsv' "$CODEX_MANIFEST" |
    while IFS=$'\t' read -r id name category desc; do
      # Truncate description to 50 chars for table display
      if [[ ${#desc} -gt 50 ]]; then
        desc="${desc:0:47}..."
      fi
      printf "%-18s %-22s %-12s %s\n" "$id" "$name" "$category" "$desc"
    done
}

cmd_info() {
  local id="$1"
  require_jq
  require_manifest
  validate_template_id "$id"

  local tmpl
  tmpl=$(get_template "$id")

  echo "Template: $(echo "$tmpl" | jq -r '.name')"
  echo "ID:            $(echo "$tmpl" | jq -r '.id')"
  echo "Category:      $(echo "$tmpl" | jq -r '.category')"
  echo "Description:   $(echo "$tmpl" | jq -r '.description')"
  echo "Output Type:   $(echo "$tmpl" | jq -r '.output_type')"
  echo "File:          $(echo "$tmpl" | jq -r '.file')"
  echo "Target Agents: $(echo "$tmpl" | jq -r '.target_agents | join(", ")')"
  echo "Tags:          $(echo "$tmpl" | jq -r '.tags | join(", ")')"
  echo ""
  echo "Required Variables:"
  while IFS= read -r var; do
    echo "  $var"
  done < <(echo "$tmpl" | jq -r '.required_vars[]')
  echo ""
  echo "Optional Variables:"
  local opt_vars
  opt_vars=$(echo "$tmpl" | jq -r '.optional_vars[]' 2>/dev/null)
  if [[ -n "$opt_vars" ]]; then
    while IFS= read -r var; do
      echo "  $var"
    done <<< "$opt_vars"
  else
    echo "  (none)"
  fi
}

cmd_show() {
  local id="$1"
  require_jq
  require_manifest
  validate_template_id "$id"

  local tmpl
  tmpl=$(get_template "$id")
  local file
  file=$(echo "$tmpl" | jq -r '.file')

  local full_path="$CODEX_DIR/$file"
  if [[ ! -f "$full_path" ]]; then
    echo "Error: Template file not found at $full_path" >&2
    exit 1
  fi

  cat "$full_path"
}

cmd_run() {
  local id="$1"; shift
  local provider=""
  declare -A vars=()

  # Parse arguments: VAR=value pairs and --provider flag
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider)
        provider="$2"; shift 2 ;;
      *=*)
        local key="${1%%=*}"
        local val="${1#*=}"
        vars["$key"]="$val"
        shift ;;
      *)
        echo "Error: Unknown argument '$1'. Use VAR=value or --provider P." >&2
        return 1 ;;
    esac
  done

  require_jq
  require_manifest
  validate_template_id "$id"

  local tmpl
  tmpl=$(get_template "$id")
  local file
  file=$(echo "$tmpl" | jq -r '.file')
  local tmpl_name
  tmpl_name=$(echo "$tmpl" | jq -r '.name')
  local target_agent
  target_agent=$(echo "$tmpl" | jq -r '.target_agents[0]')

  local full_path="$CODEX_DIR/$file"
  if [[ ! -f "$full_path" ]]; then
    echo "Error: Template file not found at $full_path" >&2
    exit 1
  fi

  # Validate required variables
  local missing=()
  while IFS= read -r req_var; do
    if [[ -z "${vars[$req_var]:-}" ]]; then
      missing+=("$req_var")
    fi
  done < <(echo "$tmpl" | jq -r '.required_vars[]')

  if [[ ${#missing[@]} -gt 0 ]]; then
    echo "Error: Missing required variable(s): ${missing[*]}" >&2
    echo "" >&2
    echo "Usage: euxis-codex run $id ${missing[*]/%/=<value>}" >&2
    exit 1
  fi

  # Read template and substitute variables
  local content
  content=$(cat "$full_path")

  # Substitute all provided variables ({{VAR_NAME}} → value)
  for key in "${!vars[@]}"; do
    content="${content//\{\{$key\}\}/${vars[$key]}}"
  done

  # Replace unset optional variables with "(not specified)"
  local opt_vars
  opt_vars=$(echo "$tmpl" | jq -r '.optional_vars[]' 2>/dev/null)
  if [[ -n "$opt_vars" ]]; then
    while IFS= read -r opt_var; do
      if [[ -z "${vars[$opt_var]:-}" ]]; then
        content="${content//\{\{$opt_var\}\}/(not specified)}"
      fi
    done <<< "$opt_vars"
  fi

  echo "═══════════════════════════════════════════════════════"
  echo "  Codex: $tmpl_name"
  echo "  Agent: $target_agent"
  echo "═══════════════════════════════════════════════════════"
  echo ""

  # Execute via target agent
  if [[ -n "$provider" ]]; then
    euxis "$target_agent" "$content" "$provider"
  else
    euxis "$target_agent" "$content"
  fi

  # Publish bus event
  if command -v euxis-bus &>/dev/null; then
    euxis-bus publish codex-events "Codex template '$id' executed via $target_agent" --sender "euxis-codex" --priority P2
  fi
}

# Main
case "${1:-}" in
  list)       cmd_list ;;
  info)
    if [[ -z "${2:-}" ]]; then echo "Error: info requires <id>" >&2; usage >&2; exit 1; fi
    cmd_info "$2" ;;
  show)
    if [[ -z "${2:-}" ]]; then echo "Error: show requires <id>" >&2; usage >&2; exit 1; fi
    cmd_show "$2" ;;
  run)
    if [[ -z "${2:-}" ]]; then echo "Error: run requires <id> and variable assignments" >&2; usage >&2; exit 1; fi
    cmd_run "$2" "${@:3}" ;;
  -h|--help)  usage ;;
  *)          usage >&2; exit 1 ;;
esac
