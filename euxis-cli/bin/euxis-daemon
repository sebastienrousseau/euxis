#!/usr/bin/env bash
# EUXIS DAEMON: Safe, Periodic Self-Improvement
# Runs 'euxis-kaizen' every X minutes with safety stops.

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/euxis-core/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-daemon — Periodic self-improvement daemon

Usage:
  euxis-daemon [interval_seconds]

Runs euxis-kaizen on a timer with smart change detection.
Default interval: 1800 seconds (30 minutes).

Options:
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

EUXIS_HOME="$HOME/.euxis"
BIN_DIR="$EUXIS_HOME/euxis-cli/bin"
INTERVAL="${1:-1800}" # Default: 1800 seconds (30 minutes). Override via first arg.
LOG_DIR="$EUXIS_HOME/runtime/data/projects/euxis-internal/daemon-logs"
mkdir -p "$LOG_DIR"

LAST_HASH=""

echo "EUXIS DAEMON STARTED."
echo "  Interval: Every $((INTERVAL / 60)) minutes"
echo "  Log Dir:  $LOG_DIR"
echo "  Mode:     Smart (skips unchanged files)"
echo "  Press [Ctrl+C] to stop safely."
echo "---------------------------------------------------"

compute_hash() {
    find "$EUXIS_HOME/euxis-core/agents/prompts" "$EUXIS_HOME/euxis-cli/bin" -type f -exec md5 -q {} + 2>/dev/null | sort | md5 -q 2>/dev/null \
        || find "$EUXIS_HOME/euxis-core/agents/prompts" "$EUXIS_HOME/euxis-cli/bin" -type f -exec md5sum {} + 2>/dev/null | sort | md5sum 2>/dev/null
}

while true; do
    TIMESTAMP=$(date +%Y%m%d-%H%M%S)
    LOG_FILE="$LOG_DIR/run-$TIMESTAMP.log"

    # File hash check: skip expensive AI audit if nothing changed
    CURRENT_HASH=$(compute_hash)

    if [[ -n "$LAST_HASH" && "$CURRENT_HASH" == "$LAST_HASH" ]]; then
        echo "[$TIMESTAMP] No changes detected. Skipping AI audit."
        echo "Sleeping for $((INTERVAL / 60)) minutes..."
        echo "---------------------------------------------------"
        sleep $INTERVAL
        continue
    fi

    LAST_HASH="$CURRENT_HASH"

    echo -n "[$TIMESTAMP] Changes detected. Starting Kaizen Cycle... "

    # 1. Run the Kaizen Loop (Capture output to file)
    "$BIN_DIR/euxis-kaizen" > "$LOG_FILE" 2>&1
    EXIT_CODE=$?

    # 2. Safety Check
    if [ $EXIT_CODE -eq 0 ]; then
        echo "COMPLETE."
        echo "  View Report: tail -n 10 $LOG_FILE"
    else
        echo "FAILED."
        echo "  CRITICAL ERROR DETECTED. Daemon is pausing for safety."
        echo "  Check Log: $LOG_FILE"
        echo "  System Halted."
        exit 1
    fi

    # 3. The Wait (Safety Buffer)
    echo "Sleeping for $((INTERVAL / 60)) minutes..."
    echo "---------------------------------------------------"
    sleep $INTERVAL
done
