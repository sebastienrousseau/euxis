"""Euxis Device Node (Local Daemon) for Computer Using Agent (CUA) tasks."""

from __future__ import annotations

import argparse
import asyncio
import json
import logging
import os
import subprocess
import sys
from pathlib import Path
from typing import Any, Dict, Optional

try:
    import websockets
except ImportError:
    print("Error: 'websockets' is required for the device node. Install with: pip install websockets")
    sys.exit(1)

LOGGER = logging.getLogger("euxis.node")
logging.basicConfig(level=logging.INFO)

class DeviceNode:
    def __init__(self, gateway_url: str, token: str):
        self.gateway_url = gateway_url
        self.token = token
        self.ws: Optional[websockets.WebSocketClientProtocol] = None
        self.browser: Any = None
        self.context: Any = None
        self.stream_task: Optional[asyncio.Task] = None

    async def connect(self):
        headers = {"Authorization": f"Bearer {self.token}"}
        
        # 2026 Tailscale Integration: Automatic discovery via Tailscale Funnel/Serve
        if self.gateway_url.endswith(".ts.net") or self.gateway_url.endswith(".ts.net/"):
             LOGGER.info("Tailscale detected. Using secure Tailscale tunnel for connection.")

        async with websockets.connect(self.gateway_url, extra_headers=headers) as ws:
            self.ws = ws
            LOGGER.info(f"Connected to Euxis Gateway: {self.gateway_url}")
            
            # Register as a device node
            await ws.send(json.dumps({
                "type": "request",
                "id": "node_reg",
                "method": "node.register",
                "params": {
                    "hostname": os.uname().nodename,
                    "platform": sys.platform,
                    "capabilities": ["shell", "browser", "screen"]
                }
            }))
            
            while True:
                message = await ws.recv()
                await self.handle_request(json.loads(message))

    async def handle_request(self, frame: Dict[str, Any]):
        if frame.get("type") != "request":
            return
            
        req_id = frame.get("id")
        method = frame.get("method")
        params = frame.get("params", {})
        
        LOGGER.info(f"Handling request: {method} ({req_id})")
        
        try:
            if method == "node.shell":
                result = self.run_shell(params.get("command", ""))
                await self.send_result(req_id, result)
            elif method == "node.browser.open":
                result = await self.open_browser(params.get("url", "about:blank"))
                await self.send_result(req_id, result)
            elif method == "node.browser.screenshot":
                result = await self.take_screenshot()
                await self.send_result(req_id, result)
            elif method == "node.browser.stream_start":
                if self.stream_task:
                    self.stream_task.cancel()
                self.stream_task = asyncio.create_task(self.stream_screenshots())
                await self.send_result(req_id, {"status": "streaming_started"})
            elif method == "node.browser.stream_stop":
                if self.stream_task:
                    self.stream_task.cancel()
                    self.stream_task = None
                await self.send_result(req_id, {"status": "streaming_stopped"})
            else:
                await self.send_error(req_id, "UNKNOWN_METHOD", f"Method {method} not supported")
        except Exception as e:
            await self.send_error(req_id, "INTERNAL_ERROR", str(e))

    async def stream_screenshots(self):
        try:
            while True:
                if self.context and self.context.pages:
                    res = await self.take_screenshot()
                    if "screenshot" in res:
                        # Stream unprompted notification to gateway
                        await self.ws.send(json.dumps({
                            "type": "event",
                            "event": "node.browser.stream_frame",
                            "data": res
                        }))
                await asyncio.sleep(1.0) # 1 FPS
        except asyncio.CancelledError:
            pass
        except Exception as e:
            LOGGER.error(f"Stream error: {e}")

    def run_shell(self, command: str) -> Dict[str, Any]:
        try:
            res = subprocess.run(command, shell=True, capture_output=True, text=True, timeout=30)
            return {
                "stdout": res.stdout,
                "stderr": res.stderr,
                "exit_code": res.returncode
            }
        except Exception as e:
            return {"error": str(e)}

    async def open_browser(self, url: str) -> Dict[str, Any]:
        try:
            from playwright.async_api import async_playwright
            if not self.browser:
                self.playwright = await async_playwright().start()
                self.browser = await self.playwright.chromium.launch(headless=True)
                self.context = await self.browser.new_context()
            
            page = await self.context.new_page()
            await page.goto(url)
            return {"status": "ok", "url": page.url, "title": await page.title()}
        except Exception as e:
            return {"error": str(e)}

    async def take_screenshot(self) -> Dict[str, Any]:
        if not self.context or not self.context.pages:
            return {"error": "No browser page open"}
        
        import base64
        page = self.context.pages[-1]
        screenshot = await page.screenshot(type="png")
        encoded = base64.b64encode(screenshot).decode("utf-8")
        return {"screenshot": encoded, "format": "png"}

    async def send_result(self, req_id: str, result: Any):
        await self.ws.send(json.dumps({
            "type": "response",
            "id": req_id,
            "ok": True,
            "result": result
        }))

    async def send_error(self, req_id: str, code: str, message: str):
        await self.ws.send(json.dumps({
            "type": "response",
            "id": req_id,
            "ok": False,
            "error": {"code": code, "message": message}
        }))

async def main():
    parser = argparse.ArgumentParser(description="Euxis Device Node")
    parser.add_argument("--url", default="ws://localhost:18789/", help="Gateway URL")
    parser.add_argument("--token", required=True, help="Auth token")
    args = parser.parse_args()

    node = DeviceNode(args.url, args.token)
    await node.connect()

if __name__ == "__main__":
    asyncio.run(main())
