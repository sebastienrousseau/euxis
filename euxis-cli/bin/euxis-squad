#!/usr/bin/env bash
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/euxis-core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/euxis-core/lib/ui.sh"
  ui_auto_header
fi


EUXIS_DIR="$HOME/.euxis"
SQUADS_FILE="$EUXIS_DIR/euxis-core/agents/squads.json"
REGISTRY_FILE="$EUXIS_DIR/agents/registry.json"

usage() {
  local c_usage=$'\033[1m\033[38;5;255m'
  local c_group=$'\033[1m\033[38;5;87m'
  local dim=$'\033[2m'
  local r=$'\033[0m'
  local bullet="▸"
  if type _ui_colors_enabled &>/dev/null && ! _ui_colors_enabled; then c_usage=""; c_group=""; dim=""; r=""; bullet=">"; fi
  echo -e "  ${dim}Squad management and deployment${r}\n"
  echo -e "  ${c_usage}USAGE${r}"
  echo -e "    $ euxis-squad list"
  echo -e "    $ euxis-squad info <squad-id>"
  echo -e "    $ euxis-squad deploy <squad-id> \"<task>\" [--mode MODE] [--project NAME]"
  echo -e "    $ euxis-squad members <squad-id>"
  echo -e "    $ euxis-squad validate\n"
  echo -e "  ${c_group}${bullet} COMMANDS${r}"
  echo -e "    list        Table of squads with member count"
  echo -e "    info        Squad details (lead, members, purpose)"
  echo -e "    deploy      Generate dispatch manifest and invoke euxis-dispatch"
  echo -e "    members     List members with registry info"
  echo -e "    validate    Cross-check all squad members against agents/registry.json\n"
  echo -e "  ${c_group}${bullet} OPTIONS${r}"
  echo -e "    --mode      Dispatch mode: hierarchical|mesh|federated (default: hierarchical)"
  echo -e "    --project   Project name for dispatch manifest (default: squad-<id>)"
  echo -e "    -h, --help  Show this help text"
  if type ui_signature &>/dev/null; then ui_signature; fi
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
  fi
}

require_squads_file() {
  if [[ ! -f "$SQUADS_FILE" ]]; then
    echo "Error: euxis-core/agents/squads.json not found at $SQUADS_FILE" >&2
    exit 1
  fi
}

validate_squad_id() {
  local id="$1"
  local exists
  exists=$(jq -r --arg id "$id" '.squads[] | select(.id == $id) | .id' "$SQUADS_FILE")
  if [[ -z "$exists" ]]; then
    echo "Error: Unknown squad '$id'. Run 'euxis-squad list' to see available squads." >&2
    exit 1
  fi
}

cmd_list() {
  require_jq
  require_squads_file

  printf "%-12s %-20s %-14s %-8s\n" "ID" "NAME" "PURPOSE" "MEMBERS"
  printf "%-12s %-20s %-14s %-8s\n" "---" "---" "---" "---"

  jq -r '.squads[] | [.id, .name, .purpose, (.members | length | tostring)] | @tsv' "$SQUADS_FILE" |
    while IFS=$'\t' read -r id name purpose count; do
      printf "%-12s %-20s %-14s %-8s\n" "$id" "$name" "$purpose" "$count"
    done
}

cmd_info() {
  local id="$1"
  require_jq
  require_squads_file
  validate_squad_id "$id"

  local squad
  squad=$(jq --arg id "$id" '.squads[] | select(.id == $id)' "$SQUADS_FILE")

  echo "Squad: $(echo "$squad" | jq -r '.name')"
  echo "ID:      $(echo "$squad" | jq -r '.id')"
  echo "Purpose: $(echo "$squad" | jq -r '.purpose')"
  echo "Lead:    $(echo "$squad" | jq -r '.lead')"
  echo "Members: $(echo "$squad" | jq -r '.members | join(", ")')"
  echo "Size:    $(echo "$squad" | jq -r '.members | length')"
}

cmd_deploy() {
  local id="$1"; shift
  local task="$1"; shift
  local mode="hierarchical"
  local project="squad-${id}"

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode) mode="$2"; shift 2 ;;
      --project) project="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  require_jq
  require_squads_file
  validate_squad_id "$id"

  local squad
  squad=$(jq --arg id "$id" '.squads[] | select(.id == $id)' "$SQUADS_FILE")
  local lead
  lead=$(echo "$squad" | jq -r '.lead')

  # Build dispatch manifest: lead gets P0, others get P1
  local manifest_file
  manifest_file=$(mktemp /tmp/euxis_squad_manifest_XXXXXX)

  local dispatches="[]"
  while IFS= read -r member; do
    local priority="P1"
    if [[ "$member" == "$lead" ]]; then
      priority="P0"
    fi
    dispatches=$(echo "$dispatches" | jq \
      --arg agent "$member" \
      --arg priority "$priority" \
      --arg task "$task" \
      '. + [{"agent": $agent, "priority": $priority, "task": $task}]')
  done < <(echo "$squad" | jq -r '.members[]')

  jq -n \
    --arg project "$project" \
    --arg mode "$mode" \
    --argjson dispatches "$dispatches" \
    '{"project": $project, "mode": $mode, "dispatches": $dispatches}' > "$manifest_file"

  echo "Squad '$id' dispatch manifest: $manifest_file"
  echo "Mode: $mode | Lead: $lead (P0) | Members: $(echo "$squad" | jq -r '.members | length')"
  echo ""

  # Invoke dispatch
  if command -v euxis-dispatch &>/dev/null; then
    euxis-dispatch "$manifest_file" --mode "$mode"
  else
    echo "Error: euxis-dispatch not found. Manifest written to: $manifest_file" >&2
    exit 1
  fi

  # Publish event to bus
  if command -v euxis-bus &>/dev/null; then
    euxis-bus publish squad-events "Squad '$id' deployed for: $task" --sender "euxis-squad" --priority P1
  fi
}

cmd_members() {
  local id="$1"
  require_jq
  require_squads_file
  validate_squad_id "$id"

  local squad
  squad=$(jq --arg id "$id" '.squads[] | select(.id == $id)' "$SQUADS_FILE")
  local lead
  lead=$(echo "$squad" | jq -r '.lead')

  printf "%-22s %-10s %-8s\n" "AGENT" "ROLE" "TIER"
  printf "%-22s %-10s %-8s\n" "---" "---" "---"

  local registry_db="$EUXIS_DIR/agents/registry.db"

  while IFS= read -r member; do
    local role="member"
    if [[ "$member" == "$lead" ]]; then
      role="lead"
    fi
    local tier="—"
    # SECURITY: Validate agent ID format to prevent injection
    if [[ ! "$member" =~ ^[a-zA-Z0-9_-]+$ ]]; then
      tier="—"
    # SQLite-first with parameterized query, JSON fallback for tier lookup
    elif [[ -f "$registry_db" ]]; then
      # SECURITY: Use parameterized query via printf to prevent SQL injection
      tier=$(sqlite3 -init /dev/null "$registry_db" "SELECT tier FROM agents WHERE id=?" "$member" 2>/dev/null) || true
      [[ -z "$tier" ]] && tier="—"
    elif [[ -f "$REGISTRY_FILE" ]]; then
      tier=$(jq -r --arg id "$member" '.agents[] | select(.id == $id) | .tier // "—"' "$REGISTRY_FILE")
    fi
    printf "%-22s %-10s %-8s\n" "$member" "$role" "$tier"
  done < <(echo "$squad" | jq -r '.members[]')
}

cmd_validate() {
  require_jq
  require_squads_file

  local registry_db="$EUXIS_DIR/agents/registry.db"
  local registry_agents=""

  # Get agent list (SQLite-first, JSON fallback)
  if [[ -f "$registry_db" ]]; then
    registry_agents=$(sqlite3 -init /dev/null "$registry_db" "SELECT id FROM agents ORDER BY id" 2>/dev/null)
  fi
  if [[ -z "$registry_agents" ]] && [[ -f "$REGISTRY_FILE" ]]; then
    registry_agents=$(jq -r '.agents[].id' "$REGISTRY_FILE")
  fi

  if [[ -z "$registry_agents" ]]; then
    echo "Error: No registry found (neither agents/registry.db nor agents/registry.json)" >&2
    exit 1
  fi

  local errors=0

  echo "Validating squad members against registry..."
  echo ""

  while IFS= read -r squad_id; do
    local squad_name
    squad_name=$(jq -r --arg id "$squad_id" '.squads[] | select(.id == $id) | .name' "$SQUADS_FILE")

    while IFS= read -r member; do
      if ! echo "$registry_agents" | grep -qx "$member"; then
        echo "  ERROR: '$member' in squad '$squad_name' not found in registry"
        ((errors++)) || true
      fi
    done < <(jq -r --arg id "$squad_id" '.squads[] | select(.id == $id) | .members[]' "$SQUADS_FILE")
  done < <(jq -r '.squads[].id' "$SQUADS_FILE")

  echo ""
  if [[ $errors -eq 0 ]]; then
    echo "All squad members validated. No issues found."
  else
    echo "$errors error(s) found."
    exit 1
  fi
}

# Main
case "${1:-}" in
  list)        cmd_list ;;
  info)
    if [[ -z "${2:-}" ]]; then echo "Error: info requires <squad-id>" >&2; usage >&2; exit 1; fi
    cmd_info "$2" ;;
  deploy)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then echo "Error: deploy requires <squad-id> and <task>" >&2; usage >&2; exit 1; fi
    cmd_deploy "$2" "$3" "${@:4}" ;;
  members)
    if [[ -z "${2:-}" ]]; then echo "Error: members requires <squad-id>" >&2; usage >&2; exit 1; fi
    cmd_members "$2" ;;
  validate)    cmd_validate ;;
  -h|--help)   usage ;;
  *)           usage >&2; exit 1 ;;
esac
