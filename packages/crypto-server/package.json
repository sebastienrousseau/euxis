{
  "name": "@euxis/crypto-server",
  "version": "0.0.8",
  "description": "Euxis cryptographic service server with health monitoring",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./health": {
      "types": "./dist/health/crypto-health.d.ts",
      "import": "./dist/health/crypto-health.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cryptography",
    "server",
    "health-monitoring",
    "typescript",
    "esm"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@euxis/crypto-lib": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.0.0"
  },
  "vitest": {
    "test": {
      "globals": true,
      "environment": "node"
    },
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "html"],
      "reportsDirectory": "./coverage",
      "include": ["src/**/*.ts"],
      "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"],
      "thresholds": {
        "lines": 90,
        "functions": 90,
        "branches": 90,
        "statements": 90
      }
    }
  }
}