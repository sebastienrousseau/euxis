{
  "schema_version": "2026.1",
  "package": "euxis-web",
  "kind": "node",
  "module": "euxis_web",
  "required_files": [
    "package.json",
    "README.md"
  ],
  "test_paths": [
    "euxis-web/src/crypto-lib/tests"
  ],
  "docs_path": "euxis-docs/docs/modules/euxis-web.md",
  "platform_support": [
    "macos",
    "linux",
    "wsl"
  ],
  "core_platform_separation": {
    "required": false,
    "core_paths": [
      "src/euxis_web/core"
    ],
    "platform_paths": [
      "src/euxis_web/platform"
    ],
    "platform_targets": [
      "macos",
      "linux",
      "wsl"
    ],
    "notes": "Core logic should depend only on platform contracts/interfaces."
  },
  "consistency_contract": {
    "docs_required": true,
    "tests_required": true,
    "strict_naming": true
  }
}
