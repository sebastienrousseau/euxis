{
  "name": "@euxis/crypto-lib",
  "version": "0.0.1",
  "description": "Euxis cryptographic operations library with type safety",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./types": {
      "types": "./dist/types.d.ts",
      "import": "./dist/types.js"
    },
    "./crypto-operations": {
      "types": "./dist/crypto-operations.d.ts",
      "import": "./dist/crypto-operations.js"
    },
    "./config": {
      "types": "./dist/config/security.d.ts",
      "import": "./dist/config/security.js"
    }
  },
  "files": [
    "dist/**/*",
    "src/**/*"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:ci": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "cryptography",
    "encryption",
    "security",
    "typescript",
    "esm"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^9.39.2"
  },
  "overrides": {
    "minimatch": ">=10.2.1",
    "ajv": ">=8.18.0"
  },
  "vitest": {
    "test": {
      "globals": true,
      "environment": "node"
    },
    "coverage": {
      "provider": "v8",
      "reporter": ["text", "html"],
      "reportsDirectory": "./coverage",
      "include": ["src/**/*.ts"],
      "exclude": ["src/**/*.test.ts", "src/**/*.spec.ts"],
      "thresholds": {
        "lines": 95,
        "functions": 95,
        "branches": 95,
        "statements": 95
      }
    }
  }
}