{
  "schema_version": "2026.1",
  "package": "euxis-security",
  "kind": "python",
  "module": "euxis_security",
  "required_files": [
    "pyproject.toml",
    "README.md"
  ],
  "test_paths": [
    "euxis-security/tests"
  ],
  "docs_path": "euxis-docs/docs/modules/euxis-security.md",
  "platform_support": [
    "macos",
    "linux",
    "wsl"
  ],
  "core_platform_separation": {
    "required": true,
    "core_paths": [
      "src/euxis_security/core"
    ],
    "platform_paths": [
      "src/euxis_security/platform"
    ],
    "platform_targets": [
      "macos",
      "linux",
      "wsl"
    ],
    "notes": "Core logic should depend only on platform contracts/interfaces."
  },
  "consistency_contract": {
    "docs_required": true,
    "tests_required": true,
    "strict_naming": true
  }
}
