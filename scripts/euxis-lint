#!/bin/bash
# EUXIS LINT: Static Analysis for Agent Fleet
# Enforces Protocol v2.1 Compliance

EUXIS_HOME="$HOME/.euxis"
FAILURES=0

echo "STARTING STATIC ANALYSIS..."

# CHECK 1: Agent Registry Integrity
echo "[1/4] Checking Registry..."
AGENTS=("architect" "automation-engineer" "bug-fixer" "compliance-officer" "data-steward" "devrel-advocate" "edge-hunter" "globalization-lead" "growth-marketer" "legacy-maintainer" "librarian" "orchestrator" "perf-optimizer" "product-manager" "release-manager" "social-manager" "tech-writer" "unit-tester" "ux-sentinel")

for agent in "${AGENTS[@]}"; do
    FILE="$EUXIS_HOME/prompts/${agent}.txt"
    if [[ ! -f "$FILE" ]]; then
        echo "  MISSING: ${agent}.txt"
        ((FAILURES++))
    fi
done

if [[ $FAILURES -eq 0 ]]; then
    echo "  All ${#AGENTS[@]} agents present."
fi

# CHECK 2: Protocol File Exists
echo "[2/4] Checking Protocol..."
PROTOCOL_FILE="$EUXIS_HOME/prompts/_protocol.txt"
if [[ ! -f "$PROTOCOL_FILE" ]]; then
    echo "  MISSING: _protocol.txt"
    ((FAILURES++))
else
    # Verify protocol contains key sections
    for section in "EUXIS MANDATORY PROTOCOL" "AUDIT_FILE_PATH" "MEMORY_FILE_PATH" "SESSION_ID" "MODEL_NAME" "AUTHORIZED TOOL BELT" "FALLBACK BEHAVIOR"; do
        if ! grep -q "$section" "$PROTOCOL_FILE"; then
            echo "  PROTOCOL GAP: Missing section — $section"
            ((FAILURES++))
        fi
    done
    if [[ $FAILURES -eq 0 ]]; then
        echo "  Protocol contains all required sections."
    fi
fi

# CHECK 3: Version Synchronization
echo "[3/4] Checking Versions..."
VERSION_COUNT=$(grep -h 'version:' "$EUXIS_HOME/prompts/"*.txt | grep -oE '"[0-9]+\.[0-9]+"' | sort -u | wc -l | tr -d ' ')
VERSIONS=$(grep -h 'version:' "$EUXIS_HOME/prompts/"*.txt | grep -oE '"[0-9]+\.[0-9]+"' | sort -u | tr -d '"')

if [[ "$VERSION_COUNT" -ne 1 ]]; then
    echo "  VERSION MISMATCH: Found multiple versions: $VERSIONS"
    ((FAILURES++))
else
    echo "  All agents at version: $VERSIONS"
fi

# CHECK 4: Permissions
echo "[4/4] Checking Script Permissions..."
for script in "$EUXIS_HOME/scripts/"*; do
    PERMS=$(stat -c "%a" "$script" 2>/dev/null || stat -f "%Lp" "$script" 2>/dev/null)
    if [[ "$PERMS" != "755" && "$PERMS" != "700" ]]; then
        echo "  BAD PERMS: $(basename "$script") is $PERMS (expected 755 or 700)"
        ((FAILURES++))
    fi
done
echo "  Script permissions verified."

echo "---------------------------------------------------"
if [[ $FAILURES -eq 0 ]]; then
    echo "LINT PASSED. Fleet integrity: 100%."
    exit 0
else
    echo "LINT FAILED with $FAILURES error(s)."
    exit 1
fi
