#!/bin/bash

# EUXIS CONSOLE: Mission Control TUI
# Version: 2.1
# Author: Euxis System

# --- CONFIGURATION & COLORS ---
EUXIS_HOME="$HOME/.euxis"
PROJECT_ROOT=$(pwd)
CURRENT_PROVIDER="claude" # Default
LOG_FILE="/tmp/euxis_ui_last_run.log"

# ANSI Colors
BOLD="\033[1m"
RED="\033[31m"
GREEN="\033[32m"
YELLOW="\033[33m"
BLUE="\033[34m"
CYAN="\033[36m"
RESET="\033[0m"

# --- UTILS ---
header() {
    clear
    echo -e "${BLUE}${BOLD}"
    echo "  ███████╗██╗   ██╗██╗  ██╗██╗███████╗"
    echo "  ██╔════╝██║   ██║╚██╗██╔╝██║██╔════╝"
    echo "  █████╗  ██║   ██║ ╚███╔╝ ██║███████╗"
    echo "  ██╔══╝  ██║   ██║ ██╔██╗ ██║╚════██║"
    echo "  ███████╗╚██████╔╝██╔╝ ██╗██║███████║"
    echo "  ╚══════╝ ╚═════╝ ╚═╝  ╚═╝╚═╝╚══════╝"
    echo -e "${RESET}"
    echo -e "  ${BOLD}:: ENTERPRISE AGENT FLEET ::${RESET}"
    echo -e "  ${CYAN}Project:${RESET} $(basename "$PROJECT_ROOT")  |  ${CYAN}Provider:${RESET} ${YELLOW}$CURRENT_PROVIDER${RESET}"
    echo "  --------------------------------------------------"
}

pause() {
    echo -e "\n  ${BOLD}Press [Enter] to return to menu...${RESET}"
    read -r
}

# --- ACTIONS ---

change_provider() {
    header
    echo -e "  ${BOLD}SELECT AI PROVIDER:${RESET}\n"
    options=("claude" "gemini" "openai" "opencode" "Cancel")

    select opt in "${options[@]}"; do
        case $opt in
            "Cancel") break ;;
            *)
                if [[ -n "$opt" ]]; then
                    CURRENT_PROVIDER=$opt
                    break
                else
                    echo "Invalid option."
                fi
                ;;
        esac
    done
}

run_agent() {
    header
    echo -e "  ${BOLD}SELECT AGENT TO DEPLOY:${RESET}\n"

    # Dynamically list agents from ~/.euxis/prompts/
    agents=($(ls "$EUXIS_HOME/prompts" | grep .txt | sed 's/.txt//'))

    if [ ${#agents[@]} -eq 0 ]; then
        echo -e "  ${RED}No agents found in $EUXIS_HOME/prompts!${RESET}"
        pause
        return
    fi

    # Display agents in 3 columns
    PS3="  > Select Agent: "
    select agent in "${agents[@]}" "Cancel"; do
        if [[ "$agent" == "Cancel" ]]; then return; fi
        if [[ -n "$agent" ]]; then
            echo -e "\n  ${BOLD}DEPLOYING AGENT:${RESET} ${GREEN}$agent${RESET}"
            echo -e "  ${BOLD}USING PROVIDER:${RESET} ${YELLOW}$CURRENT_PROVIDER${RESET}"
            echo -e "  --------------------------------------------------"
            echo -e "  ${BOLD}ENTER MISSION TASK:${RESET} (Press Ctrl+C to cancel)"
            read -e -p "  > " task

            if [[ -z "$task" ]]; then
                echo -e "  ${RED}Task cannot be empty.${RESET}"
                pause
                return
            fi

            echo -e "\n  ${CYAN}Launching Fleet Command...${RESET}"
            echo -e "  Command: euxis $agent \"$task\" $CURRENT_PROVIDER\n"

            # Execute the euxis core script
            euxis "$agent" "$task" "$CURRENT_PROVIDER"

            pause
            return
        else
            echo "Invalid selection."
        fi
    done
}

view_audit_logs() {
    header
    echo -e "  ${BOLD}SELECT AGENT LOGS TO VIEW:${RESET}\n"

    # List projects that have logs
    project_logs="$EUXIS_HOME/projects/$(basename "$PROJECT_ROOT")"
    if [[ ! -d "$project_logs" ]]; then
        echo -e "  ${RED}No logs found for this project yet.${RESET}"
        pause
        return
    fi

    agents_with_logs=($(ls "$project_logs"))

    select agent in "${agents_with_logs[@]}" "Cancel"; do
        if [[ "$agent" == "Cancel" ]]; then return; fi
        if [[ -n "$agent" ]]; then
            log_file="$project_logs/$agent/audit.md"
            if [[ -f "$log_file" ]]; then
                # Use 'glow' if available, else 'less', else 'cat'
                if command -v glow &> /dev/null; then
                    glow -p "$log_file"
                else
                    less "$log_file"
                fi
            else
                echo -e "  ${RED}Log file missing for $agent.${RESET}"
                pause
            fi
            return
        fi
    done
}

# --- MAIN LOOP ---

while true; do
    header
    echo -e "  ${BOLD}1.${RESET} Deploy Agent"
    echo -e "  ${BOLD}2.${RESET} Switch AI Provider (Current: $CURRENT_PROVIDER)"
    echo -e "  ${BOLD}3.${RESET} View Agent Audit Logs"
    echo -e "  ${BOLD}4.${RESET} Change Working Directory"
    echo -e "  ${BOLD}5.${RESET} Exit"
    echo ""
    read -p "  > Choose Option: " choice

    case $choice in
        1) run_agent ;;
        2) change_provider ;;
        3) view_audit_logs ;;
        4)
           read -e -p "  > Enter path: " new_path
           if [[ -d "$new_path" ]]; then
               cd "$new_path" || exit
               PROJECT_ROOT=$(pwd)
           else
               echo -e "  ${RED}Invalid directory.${RESET}"
               sleep 1
           fi
           ;;
        5) echo -e "\n  ${CYAN}Euxis System Shutdown.${RESET}"; exit 0 ;;
        *) echo -e "  ${RED}Invalid option.${RESET}"; sleep 1 ;;
    esac
done
