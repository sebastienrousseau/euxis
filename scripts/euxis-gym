#!/bin/bash
# EUXIS GYM: Automated Evaluation Framework
# Usage: euxis-gym [agent] [test_file]

AGENT=$1
TEST_CASE=$2
LOG_FILE="/tmp/euxis_gym_result.md"

if [[ -z "$AGENT" || -z "$TEST_CASE" ]]; then
    echo "Usage: euxis-gym <agent> <test_case_path>"
    exit 1
fi

if [[ ! -f "$TEST_CASE" ]]; then
    echo "ERROR: Test case not found: $TEST_CASE"
    exit 1
fi

echo "EUXIS GYM: Evaluating $AGENT..."

# 1. READ THE TEST
# A test file contains an 'INPUT:' and an 'EXPECTED_OUTPUT:' section
INPUT=$(sed -n '/INPUT:/,/EXPECTED_OUTPUT:/p' "$TEST_CASE" | sed 's/INPUT://' | sed 's/EXPECTED_OUTPUT://')
EXPECTED=$(sed -n '/EXPECTED_OUTPUT:/,$p' "$TEST_CASE" | sed 's/EXPECTED_OUTPUT://')

# 2. RUN THE AGENT (Sandboxed)
# We capture the output silently
OUTPUT=$(euxis "$AGENT" "$INPUT" claude)

# 3. EVALUATE (Using a Judge Model)
# We ask a "Judge" (Claude) to grade the performance 0-100
JUDGE_PROMPT="
You are the Gym Referee. Compare the Actual Output against the Expected Criteria.
---
TASK: $INPUT
---
ACTUAL OUTPUT:
$OUTPUT
---
EXPECTED CRITERIA:
$EXPECTED
---
VERDICT:
Rate the Actual Output from 0-100.
Provide a 1-sentence explanation.
Format: SCORE: <num> | REASON: <text>
"

RESULT=$(claude -p "$JUDGE_PROMPT")

echo "---------------------------------------------------"
echo "test: $TEST_CASE"
echo "agent: $AGENT"
echo "$RESULT"
echo "---------------------------------------------------"

# 4. LOG RESULT
{
    echo "## Eval: $AGENT — $(date '+%Y-%m-%d %H:%M')"
    echo "- **Test:** $TEST_CASE"
    echo "- **Result:** $RESULT"
    echo ""
} >> "$LOG_FILE"
