#!/bin/bash
# EUXIS DISPATCH: The Fleet Deployment Engine (v5.0)
# Reads an Architect Mission Manifest and fires agent loops.
#
# Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]
#
# Dispatch Modes:
#   hierarchical (default) — Central orchestrator coordinates all agents in parallel.
#   mesh                   — Agents with dispatch authority coordinate sub-workflows
#                            directly. Parent manifest spawns child manifests.
#   federated              — Agents operate autonomously on separate project scopes.
#                            Results aggregate into shared synthesis.
#
# The manifest is a JSON file with this structure:
# {
#   "project": "name",
#   "mode": "hierarchical|mesh|federated",
#   "dispatches": [
#     { "agent": "bug-fixer", "priority": "P0", "task": "...", "verify_cmd": "..." }
#   ]
# }

set -uo pipefail

export PATH="$HOME/bin:$PATH"

# Parse arguments
MANIFEST_FILE=""
DISPATCH_MODE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode)
            DISPATCH_MODE="${2:-}"
            shift 2
            ;;
        *)
            MANIFEST_FILE="$1"
            shift
            ;;
    esac
done

if [[ -z "$MANIFEST_FILE" || ! -f "$MANIFEST_FILE" ]]; then
    echo "Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]"
    echo ""
    echo "  Modes:"
    echo "    hierarchical  Central coordination, all agents report to orchestrator (default)"
    echo "    mesh          Agents with dispatch authority coordinate sub-workflows"
    echo "    federated     Agents operate autonomously across project boundaries"
    echo ""
    echo "  The manifest should be generated by the Architect agent:"
    echo "    euxis architect 'Analyze this repo and output a MISSION MANIFEST.' claude > manifest.json"
    exit 1
fi

# Verify jq is available
if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed."
    echo "  Install: sudo apt install jq  (Linux)  /  brew install jq  (macOS)"
    exit 1
fi

# Validate JSON
if ! jq empty "$MANIFEST_FILE" 2>/dev/null; then
    echo "Error: Invalid JSON in $MANIFEST_FILE"
    exit 1
fi

PROJECT=$(jq -r '.project // "unknown"' "$MANIFEST_FILE")
DISPATCH_COUNT=$(jq '.dispatches | length' "$MANIFEST_FILE")

# Resolve dispatch mode: CLI flag > manifest field > default
MANIFEST_MODE=$(jq -r '.mode // "hierarchical"' "$MANIFEST_FILE")
MODE="${DISPATCH_MODE:-$MANIFEST_MODE}"

# Validate mode
case "$MODE" in
    hierarchical|mesh|federated) ;;
    *)
        echo "Error: Invalid dispatch mode '$MODE'. Must be: hierarchical, mesh, or federated."
        exit 1
        ;;
esac

echo "EUXIS FLEET DEPLOYMENT"
echo "  Project:    $PROJECT"
echo "  Mode:       $MODE"
echo "  Dispatches: $DISPATCH_COUNT"
echo ""

if [[ "$DISPATCH_COUNT" -eq 0 ]]; then
    echo "No dispatches found in manifest."
    exit 0
fi

EUXIS_HOME="$HOME/.euxis"
LOG_DIR=$(mktemp -d /tmp/euxis_dispatch_XXXXXX)

# Agents with dispatch authority (can coordinate sub-workflows in mesh mode)
DISPATCH_AGENTS="architect qa-coordinator incident-commander release-manager"

PIDS=()
AGENTS=()

for i in $(seq 0 $((DISPATCH_COUNT - 1))); do
    AGENT=$(jq -r ".dispatches[$i].agent" "$MANIFEST_FILE")
    TASK=$(jq -r ".dispatches[$i].task" "$MANIFEST_FILE")
    VERIFY=$(jq -r ".dispatches[$i].verify_cmd" "$MANIFEST_FILE")
    PRIORITY=$(jq -r ".dispatches[$i].priority" "$MANIFEST_FILE")

    echo "---------------------------------------------------"
    echo "  [$PRIORITY] -> $AGENT ($MODE)"
    echo "  Task: $TASK"
    echo "  Verify: $VERIFY"

    LOG_FILE="$LOG_DIR/${AGENT}_${i}.log"

    case "$MODE" in
        hierarchical)
            # All agents report back to orchestrator via euxis-loop
            euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            ;;
        mesh)
            # Agents with dispatch authority get mesh context and can spawn sub-dispatches
            if echo "$DISPATCH_AGENTS" | grep -qw "$AGENT"; then
                MESH_TASK="[MESH MODE] You have dispatch authority. You MAY produce a sub-manifest to coordinate specialized agents directly. $TASK"
                euxis-loop "$AGENT" "$MESH_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            else
                # Non-dispatch agents run normally
                euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            fi
            ;;
        federated)
            # Each agent operates autonomously on its own project scope
            FED_TASK="[FEDERATED MODE] Operate autonomously on project '$PROJECT'. Produce complete output independently. $TASK"
            euxis-loop "$AGENT" "$FED_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            ;;
    esac

    PIDS+=($!)
    AGENTS+=("$AGENT")

    # Small delay to prevent API rate limiting
    sleep 2
done

echo ""
echo "---------------------------------------------------"
echo "  All $DISPATCH_COUNT agents deployed ($MODE mode). Waiting for completion..."
echo "  Logs: $LOG_DIR/"
echo ""

# Wait for all background jobs and track results
FAILED=0
for i in "${!PIDS[@]}"; do
    if wait "${PIDS[$i]}"; then
        echo "  [PASS] ${AGENTS[$i]}"
    else
        echo "  [FAIL] ${AGENTS[$i]} (see $LOG_DIR/${AGENTS[$i]}_${i}.log)"
        ((FAILED++))
    fi
done

echo ""
if [[ $FAILED -eq 0 ]]; then
    echo "ALL $DISPATCH_COUNT MISSIONS COMPLETE ($MODE mode)."
else
    echo "$FAILED of $DISPATCH_COUNT missions failed. Check logs in $LOG_DIR/"
    exit 1
fi
