#!/bin/bash
# EUXIS DISPATCH: The Fleet Deployment Engine (v6.0)
# Reads an Architect Mission Manifest and fires agent loops.
#
# Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]
#
# Dispatch Modes:
#   hierarchical (default) — Central orchestrator coordinates all agents in parallel.
#   mesh                   — Agents with dispatch authority coordinate sub-workflows
#                            directly. Parent manifest spawns child manifests.
#   federated              — Agents operate autonomously on separate project scopes.
#                            Results aggregate into shared synthesis.
#
# The manifest is a JSON file with this structure:
# {
#   "project": "name",
#   "mode": "hierarchical|mesh|federated",
#   "dispatches": [
#     { "agent": "bug-fixer", "priority": "P0", "task": "...", "verify_cmd": "..." }
#   ]
# }

set -euo pipefail

export PATH="$PATH:$HOME/bin"

# Parse arguments
MANIFEST_FILE=""
DISPATCH_MODE=""

while [[ $# -gt 0 ]]; do
    case "$1" in
        --mode)
            DISPATCH_MODE="${2:-}"
            shift 2
            ;;
        *)
            MANIFEST_FILE="$1"
            shift
            ;;
    esac
done

if [[ -z "$MANIFEST_FILE" || ! -f "$MANIFEST_FILE" ]]; then
    echo "Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]"
    echo ""
    echo "  Modes:"
    echo "    hierarchical  Central coordination, all agents report to orchestrator (default)"
    echo "    mesh          Agents with dispatch authority coordinate sub-workflows"
    echo "    federated     Agents operate autonomously across project boundaries"
    echo ""
    echo "  The manifest should be generated by the Architect agent:"
    echo "    euxis architect 'Analyze this repo and output a MISSION MANIFEST.' claude > manifest.json"
    exit 1
fi

# Verify jq is available
if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed."
    echo "  Install: sudo apt install jq  (Linux)  /  brew install jq  (macOS)"
    exit 1
fi

# Validate JSON
if ! jq empty "$MANIFEST_FILE" 2>/dev/null; then
    echo "Error: Invalid JSON in $MANIFEST_FILE"
    exit 1
fi

PROJECT=$(jq -r '.project // "unknown"' "$MANIFEST_FILE")
DISPATCH_COUNT=$(jq '.dispatches | length' "$MANIFEST_FILE")
HAS_PHASES=$(jq 'has("rollout_phases")' "$MANIFEST_FILE")
PHASE_COUNT=$(jq '.rollout_phases // [] | length' "$MANIFEST_FILE")

# Resolve dispatch mode: CLI flag > manifest field > default
MANIFEST_MODE=$(jq -r '.mode // "hierarchical"' "$MANIFEST_FILE")
MODE="${DISPATCH_MODE:-$MANIFEST_MODE}"

# Validate mode
case "$MODE" in
    hierarchical|mesh|federated) ;;
    *)
        echo "Error: Invalid dispatch mode '$MODE'. Must be: hierarchical, mesh, or federated."
        exit 1
        ;;
esac

echo "EUXIS FLEET DEPLOYMENT"
echo "  Project:    $PROJECT"
echo "  Mode:       $MODE"
echo "  Dispatches: $DISPATCH_COUNT"
if [[ "$HAS_PHASES" == "true" ]]; then
    echo "  Phases:     $PHASE_COUNT (phased rollout)"
fi
echo ""

if [[ "$DISPATCH_COUNT" -eq 0 ]]; then
    echo "No dispatches found in manifest."
    exit 0
fi

EUXIS_HOME="$HOME/.euxis"

# Validate agent names against registry
REGISTRY_FILE="$EUXIS_HOME/registry.json"
if [[ -f "$REGISTRY_FILE" ]]; then
    INVALID_AGENTS=()
    for i in $(seq 0 $((DISPATCH_COUNT - 1))); do
        AGENT_NAME=$(jq -r ".dispatches[$i].agent" "$MANIFEST_FILE")
        if ! jq -e --arg id "$AGENT_NAME" '.agents[] | select(.id == $id)' "$REGISTRY_FILE" &>/dev/null; then
            INVALID_AGENTS+=("$AGENT_NAME")
        fi
    done
    if [[ ${#INVALID_AGENTS[@]} -gt 0 ]]; then
        echo "Error: Manifest references unknown agents: ${INVALID_AGENTS[*]}" >&2
        echo "  Valid agents: $(jq -r '.agents[].id' "$REGISTRY_FILE" | tr '\n' ', ' | sed 's/,$//')" >&2
        echo "" >&2
        echo "  Hint: Re-run the architect to regenerate the manifest with valid agent names." >&2
        exit 1
    fi
fi
LOG_DIR=$(mktemp -d /tmp/euxis_dispatch_XXXXXX)

# Agents with dispatch authority (can coordinate sub-workflows in mesh mode)
DISPATCH_AGENTS="architect qa-coordinator incident-commander release-manager"

# ============================================================================
# Dispatch a single agent task
# ============================================================================
dispatch_agent() {
    local i="$1"
    local AGENT TASK VERIFY PRIORITY LOG_FILE

    AGENT=$(jq -r ".dispatches[$i].agent" "$MANIFEST_FILE")
    TASK=$(jq -r ".dispatches[$i].task" "$MANIFEST_FILE")
    VERIFY=$(jq -r ".dispatches[$i].verify_cmd" "$MANIFEST_FILE")
    PRIORITY=$(jq -r ".dispatches[$i].priority" "$MANIFEST_FILE")

    echo "  [$PRIORITY] -> $AGENT ($MODE)"
    LOG_FILE="$LOG_DIR/${AGENT}_${i}.log"

    case "$MODE" in
        hierarchical)
            euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            ;;
        mesh)
            if echo "$DISPATCH_AGENTS" | grep -qw "$AGENT"; then
                MESH_TASK="[MESH MODE] You have dispatch authority. You MAY produce a sub-manifest to coordinate specialized agents directly. $TASK"
                euxis-loop "$AGENT" "$MESH_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            else
                euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            fi
            ;;
        federated)
            FED_TASK="[FEDERATED MODE] Operate autonomously on project '$PROJECT'. Produce complete output independently. $TASK"
            euxis-loop "$AGENT" "$FED_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
            ;;
    esac

    echo "$!" "$AGENT" "$i"
}

# ============================================================================
# Wait for a group of PIDs and report results
# ============================================================================
wait_for_group() {
    local group_failed=0
    local pids=("$@")
    for entry in "${pids[@]}"; do
        local pid agent idx
        pid=$(echo "$entry" | cut -d' ' -f1)
        agent=$(echo "$entry" | cut -d' ' -f2)
        idx=$(echo "$entry" | cut -d' ' -f3)
        if wait "$pid"; then
            echo "  [PASS] $agent (dispatch #$idx)"
        else
            echo "  [FAIL] $agent (dispatch #$idx — see $LOG_DIR/${agent}_${idx}.log)"
            ((group_failed++))
        fi
    done
    return "$group_failed"
}

# ============================================================================
# Phased Rollout (v6.0)
# ============================================================================
if [[ "$HAS_PHASES" == "true" && "$PHASE_COUNT" -gt 0 ]]; then
    echo "=== PHASED ROLLOUT ==="
    echo ""

    TOTAL_FAILED=0

    for phase_idx in $(seq 0 $((PHASE_COUNT - 1))); do
        PHASE_NAME=$(jq -r ".rollout_phases[$phase_idx].name" "$MANIFEST_FILE")
        PHASE_NUM=$(jq -r ".rollout_phases[$phase_idx].phase" "$MANIFEST_FILE")
        CHECKPOINT=$(jq -r ".rollout_phases[$phase_idx].checkpoint // \"\"" "$MANIFEST_FILE")

        echo "---------------------------------------------------"
        echo "  PHASE $PHASE_NUM: $PHASE_NAME"
        echo "---------------------------------------------------"

        # Get dispatch indices for this phase
        DISPATCH_INDICES=$(jq -r ".rollout_phases[$phase_idx].parallel_group | .[]" "$MANIFEST_FILE")

        GROUP_ENTRIES=()
        for i in $DISPATCH_INDICES; do
            entry=$(dispatch_agent "$i")
            GROUP_ENTRIES+=("$entry")
            sleep 2
        done

        echo ""
        echo "  Waiting for Phase $PHASE_NUM to complete..."

        # Phase progress monitor
        _phase_monitor_pid=""
        if [[ -t 1 ]]; then
            PHASE_PID_FILE="$LOG_DIR/.phase_pids"
            : > "$PHASE_PID_FILE"
            for entry in "${GROUP_ENTRIES[@]}"; do
                echo "$entry" >> "$PHASE_PID_FILE"
            done
            (
                while true; do
                    sleep 5
                    all_done=true
                    while IFS=' ' read -r pid agent idx; do
                        kill -0 "$pid" 2>/dev/null || continue
                        all_done=false
                        log_file="$LOG_DIR/${agent}_${idx}.log"
                        if [[ -f "$log_file" ]]; then
                            size=$(du -h "$log_file" 2>/dev/null | cut -f1 | tr -d ' ')
                            echo "  ... $agent running (log ${size:-0})"
                        fi
                    done < "$PHASE_PID_FILE"
                    [[ "$all_done" == true ]] && break
                done
            ) &
            _phase_monitor_pid=$!
        fi

        phase_failed=0
        for entry in "${GROUP_ENTRIES[@]}"; do
            pid=$(echo "$entry" | cut -d' ' -f1)
            agent=$(echo "$entry" | cut -d' ' -f2)
            idx=$(echo "$entry" | cut -d' ' -f3)
            if wait "$pid"; then
                echo "  [PASS] $agent (dispatch #$idx)"
            else
                echo "  [FAIL] $agent (dispatch #$idx — see $LOG_DIR/${agent}_${idx}.log)"
                ((phase_failed++))
            fi
        done

        # Stop phase monitor
        if [[ -n "${_phase_monitor_pid:-}" ]]; then
            kill "$_phase_monitor_pid" 2>/dev/null
            wait "$_phase_monitor_pid" 2>/dev/null
        fi

        if [[ $phase_failed -gt 0 ]]; then
            echo ""
            echo "  [PHASE $PHASE_NUM FAILED] $phase_failed dispatch(es) failed."
            echo "  Checkpoint: $CHECKPOINT"
            echo "  ABORTING remaining phases."
            TOTAL_FAILED=$((TOTAL_FAILED + phase_failed))
            break
        fi

        # Evaluate checkpoint
        if [[ -n "$CHECKPOINT" ]]; then
            echo ""
            echo "  [CHECKPOINT] Phase $PHASE_NUM — $CHECKPOINT"
            echo "  [CHECKPOINT] Phase $PHASE_NUM → CONTINUE"
        fi

        echo ""
    done

    echo ""
    if [[ $TOTAL_FAILED -eq 0 ]]; then
        echo "ALL $PHASE_COUNT PHASES COMPLETE. $DISPATCH_COUNT dispatches succeeded ($MODE mode)."
    else
        echo "$TOTAL_FAILED dispatch(es) failed across phases. Check logs in $LOG_DIR/"
        exit 1
    fi

# ============================================================================
# Legacy flat dispatch (v5.0 backward compatibility)
# ============================================================================
else
    PIDS=()
    AGENTS=()

    for i in $(seq 0 $((DISPATCH_COUNT - 1))); do
        AGENT=$(jq -r ".dispatches[$i].agent" "$MANIFEST_FILE")
        TASK=$(jq -r ".dispatches[$i].task" "$MANIFEST_FILE")
        VERIFY=$(jq -r ".dispatches[$i].verify_cmd" "$MANIFEST_FILE")
        PRIORITY=$(jq -r ".dispatches[$i].priority" "$MANIFEST_FILE")

        echo "---------------------------------------------------"
        echo "  [$PRIORITY] -> $AGENT ($MODE)"
        echo "  Task: $TASK"
        echo "  Verify: $VERIFY"

        LOG_FILE="$LOG_DIR/${AGENT}_${i}.log"

        case "$MODE" in
            hierarchical)
                euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
                ;;
            mesh)
                if echo "$DISPATCH_AGENTS" | grep -qw "$AGENT"; then
                    MESH_TASK="[MESH MODE] You have dispatch authority. You MAY produce a sub-manifest to coordinate specialized agents directly. $TASK"
                    euxis-loop "$AGENT" "$MESH_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
                else
                    euxis-loop "$AGENT" "$TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
                fi
                ;;
            federated)
                FED_TASK="[FEDERATED MODE] Operate autonomously on project '$PROJECT'. Produce complete output independently. $TASK"
                euxis-loop "$AGENT" "$FED_TASK" "$VERIFY" 3 > "$LOG_FILE" 2>&1 &
                ;;
        esac

        PIDS+=($!)
        AGENTS+=("$AGENT")
        sleep 2
    done

    echo ""
    echo "---------------------------------------------------"
    echo "  All $DISPATCH_COUNT agents deployed ($MODE mode). Waiting for completion..."
    echo "  Logs: $LOG_DIR/"
    echo ""

    # Write PID manifest for progress monitor
    PID_MANIFEST="$LOG_DIR/.pids"
    for i in "${!PIDS[@]}"; do
        echo "${PIDS[$i]} ${AGENTS[$i]} ${i}" >> "$PID_MANIFEST"
    done

    # Background progress monitor: poll log files every 5s and report status
    # Uses file markers instead of associative arrays for bash 3.2 compatibility
    _monitor_pid=""
    DONE_DIR="$LOG_DIR/.done"
    mkdir -p "$DONE_DIR"
    if [[ -t 1 ]]; then
        (
            while true; do
                sleep 5
                all_done=true
                while IFS=' ' read -r pid agent idx; do
                    # Skip already reported
                    [[ -f "$DONE_DIR/${agent}_${idx}" ]] && continue

                    # Check if process finished
                    if ! kill -0 "$pid" 2>/dev/null; then
                        touch "$DONE_DIR/${agent}_${idx}"
                        continue
                    fi

                    all_done=false

                    # Show activity from log
                    log_file="$LOG_DIR/${agent}_${idx}.log"
                    if [[ -f "$log_file" ]]; then
                        attempt=$(grep -c "Loop Attempt" "$log_file" 2>/dev/null || true)
                        size=$(du -h "$log_file" 2>/dev/null | cut -f1 | tr -d ' ')
                        echo "  ... $agent running (attempt ${attempt:-0}, log ${size:-0})"
                    fi
                done < "$PID_MANIFEST"

                if [[ "$all_done" == true ]]; then break; fi
            done
        ) &
        _monitor_pid=$!
    fi

    FAILED=0
    for i in "${!PIDS[@]}"; do
        if wait "${PIDS[$i]}"; then
            echo "  [PASS] ${AGENTS[$i]}"
        else
            echo "  [FAIL] ${AGENTS[$i]} (see $LOG_DIR/${AGENTS[$i]}_${i}.log)"
            ((FAILED++))
        fi
    done

    # Stop monitor
    if [[ -n "${_monitor_pid:-}" ]]; then
        kill "$_monitor_pid" 2>/dev/null
        wait "$_monitor_pid" 2>/dev/null
    fi

    echo ""
    if [[ $FAILED -eq 0 ]]; then
        echo "ALL $DISPATCH_COUNT MISSIONS COMPLETE ($MODE mode)."
    else
        echo "$FAILED of $DISPATCH_COUNT missions failed. Check logs in $LOG_DIR/"
        exit 1
    fi
fi
