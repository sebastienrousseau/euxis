#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS DISPATCH: The Fleet Deployment Engine (v0.0.7)
# Shell wrapper for Python DispatchEngine core
#
# Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]

set -euo pipefail

usage() {
    cat <<'EOF'
euxis-dispatch — Fleet deployment engine

Usage:
  euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]

Reads an Architect Mission Manifest and deploys agent loops.

Dispatch Modes:
  hierarchical  Central orchestrator coordinates all agents (default)
  mesh          Agents with dispatch authority coordinate sub-workflows
  federated     Agents operate autonomously on separate project scopes

Options:
  -h, --help    Show this help text
  --mode MODE   Set dispatch mode
  --legacy      Use original shell implementation (for debugging)
EOF
}

# Determine Python executable
PYTHON_CMD="python3"
if ! command -v "$PYTHON_CMD" &>/dev/null; then
    echo "Error: python3 is required but not installed."
    exit 1
fi

# Parse arguments
MANIFEST_FILE=""
DISPATCH_MODE=""
USE_LEGACY=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        -h|--help)
            usage
            exit 0
            ;;
        --mode)
            DISPATCH_MODE="${2:-}"
            shift 2
            ;;
        --legacy)
            USE_LEGACY=true
            shift
            ;;
        hierarchical|mesh|federated)
            # Accept mode as positional arg (euxis dispatch manifest.json hierarchical)
            DISPATCH_MODE="$1"
            shift
            ;;
        *)
            MANIFEST_FILE="$1"
            shift
            ;;
    esac
done

# Validate arguments
if [[ -z "$MANIFEST_FILE" || ! -f "$MANIFEST_FILE" ]]; then
    echo "Usage: euxis-dispatch <manifest.json> [--mode hierarchical|mesh|federated]"
    echo ""
    echo "  Modes:"
    echo "    hierarchical  Central coordination, all agents report to orchestrator (default)"
    echo "    mesh          Agents with dispatch authority coordinate sub-workflows"
    echo "    federated     Agents operate autonomously across project boundaries"
    echo ""
    echo "  The manifest should be generated by the Architect agent:"
    echo "    euxis architect 'Analyze this repo and output a MISSION MANIFEST.' claude > manifest.json"
    exit 1
fi

# Set up environment
export PATH="$PATH:$HOME/bin"
export EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"

# Resolve script directory (follow symlinks to find real location)
SCRIPT_DIR="${EUXIS_HOME}/bin"
PYTHON_CORE="$SCRIPT_DIR/euxis_core.py"
LEGACY_DISPATCH="$SCRIPT_DIR/euxis-dispatch.bak"

# Legacy fallback for testing/debugging
if [[ "$USE_LEGACY" == true ]]; then
    echo "Using legacy shell implementation..."
    exec "$LEGACY_DISPATCH" "$MANIFEST_FILE" ${DISPATCH_MODE:+--mode "$DISPATCH_MODE"}
fi

if [[ ! -f "$PYTHON_CORE" ]]; then
    echo "Error: Python core not found at $PYTHON_CORE"
    echo "Falling back to legacy implementation..."
    exec "$LEGACY_DISPATCH" "$MANIFEST_FILE" ${DISPATCH_MODE:+--mode "$DISPATCH_MODE"}
fi

# Ensure Python environment for the project if needed
ensure_python_env() {
    # Only act for Python projects
    if [[ ! -f "pyproject.toml" && ! -f "setup.py" && ! -f "requirements.txt" ]]; then
        return 0
    fi

    # Already activated or present
    if [[ -f ".venv/bin/activate" ]]; then
        echo "  [env] Activating existing .venv"
        # shellcheck disable=SC1091
        source .venv/bin/activate
        return 0
    fi

    echo "  [env] Python project detected — setting up .venv..."

    if ! command -v uv &>/dev/null; then
        echo "  [env] WARNING: uv not found. Install via: brew install uv" >&2
        echo "  [env] Skipping automatic environment setup." >&2
        return 0
    fi

    # Create and activate venv
    if ! uv venv .venv &>/dev/null; then
        echo "  [env] WARNING: Failed to create .venv" >&2
        return 0
    fi

    # shellcheck disable=SC1091
    source .venv/bin/activate

    # Install dependencies quietly
    if [[ -f "pyproject.toml" ]]; then
        echo "  [env] Installing project dependencies..."
        uv pip install -e . &>/dev/null || echo "  [env] WARNING: Failed to install project" >&2
    elif [[ -f "requirements.txt" ]]; then
        echo "  [env] Installing from requirements.txt..."
        uv pip install -r requirements.txt &>/dev/null || echo "  [env] WARNING: Failed to install requirements" >&2
    fi

    # Install dev tools
    uv pip install pytest pytest-cov &>/dev/null || true
    echo "  [env] Environment ready: $(python --version)"
    echo ""
}

# Setup environment
ensure_python_env

# Build Python command
PYTHON_ARGS=("$PYTHON_CORE" "$MANIFEST_FILE")
if [[ -n "$DISPATCH_MODE" ]]; then
    PYTHON_ARGS+=(--mode "$DISPATCH_MODE")
fi

# Execute Python core
exec "$PYTHON_CMD" "${PYTHON_ARGS[@]}"