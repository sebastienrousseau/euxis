#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/core/lib/ui.sh"
  ui_auto_header
fi


EUXIS_DIR="$HOME/.euxis"
HOOKS_DIR="$EUXIS_DIR/bin/hooks"

SIGNATURE_FOOTER='---

> Designed by Sebastien Rousseau — https://sebastienrousseau.com
> Engineered with Euxis — Enterprise Unified Execution Intelligence System — https://euxis.co'

usage() {
  cat <<'EOF'
euxis-hooks — Install Euxis Git hooks and enforce branding

Usage:
  euxis-hooks install [--repo PATH]
  euxis-hooks uninstall [--repo PATH]
  euxis-hooks status [--repo PATH]
  euxis-hooks pr "<title>" [--body "<text>"] [gh pr create flags...]
  euxis-hooks check-pr [PR_NUMBER]

Commands:
  install     Symlink Euxis hooks into .git/hooks/ (includes PR signature enforcement on push)
  uninstall   Remove Euxis hook symlinks from .git/hooks/
  status      Show which Euxis hooks are installed
  pr          Create a PR with branding signature auto-appended
  check-pr    Verify open PR descriptions carry the branding signature

Options:
  --repo PATH   Target repository (default: current directory)
  -h, --help    Show this help text
EOF
}

resolve_repo() {
  local repo="${1:-.}"
  local git_dir
  git_dir=$(git -C "$repo" rev-parse --git-dir 2>/dev/null) || {
    echo "Error: '$repo' is not a Git repository." >&2
    exit 1
  }
  # Resolve to absolute path
  if [[ "$git_dir" == /* ]]; then
    echo "$git_dir"
  else
    echo "$(cd "$repo" && pwd)/$git_dir"
  fi
}

cmd_install() {
  local repo_path="."
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) repo_path="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  local git_dir
  git_dir=$(resolve_repo "$repo_path")
  local target_dir="$git_dir/hooks"
  mkdir -p "$target_dir"

  local installed=0
  for hook in "$HOOKS_DIR"/*; do
    [[ -f "$hook" ]] || continue
    local hook_name
    hook_name=$(basename "$hook")
    local target="$target_dir/$hook_name"

    if [[ -L "$target" ]]; then
      local existing
      existing=$(readlink "$target")
      if [[ "$existing" == "$hook" ]]; then
        echo "  SKIP: $hook_name (already installed)"
        continue
      fi
    fi

    if [[ -f "$target" && ! -L "$target" ]]; then
      # Back up existing non-Euxis hook
      cp "$target" "$target.pre-euxis"
      echo "  BACKUP: $hook_name → $hook_name.pre-euxis"
    fi

    ln -sf "$hook" "$target"
    echo "  INSTALLED: $hook_name"
    ((installed++)) || true
  done

  if [[ $installed -eq 0 ]]; then
    echo "All hooks already installed."
  else
    echo "Installed $installed hook(s) into $target_dir"
  fi
}

cmd_uninstall() {
  local repo_path="."
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) repo_path="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  local git_dir
  git_dir=$(resolve_repo "$repo_path")
  local target_dir="$git_dir/hooks"

  local removed=0
  for hook in "$HOOKS_DIR"/*; do
    [[ -f "$hook" ]] || continue
    local hook_name
    hook_name=$(basename "$hook")
    local target="$target_dir/$hook_name"

    if [[ -L "$target" ]]; then
      local existing
      existing=$(readlink "$target")
      if [[ "$existing" == "$hook" ]]; then
        rm "$target"
        echo "  REMOVED: $hook_name"
        ((removed++)) || true

        # Restore backup if it exists
        if [[ -f "$target.pre-euxis" ]]; then
          mv "$target.pre-euxis" "$target"
          echo "  RESTORED: $hook_name.pre-euxis → $hook_name"
        fi
      fi
    fi
  done

  if [[ $removed -eq 0 ]]; then
    echo "No Euxis hooks found to remove."
  else
    echo "Removed $removed hook(s) from $target_dir"
  fi
}

cmd_status() {
  local repo_path="."
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --repo) repo_path="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  local git_dir
  git_dir=$(resolve_repo "$repo_path")
  local target_dir="$git_dir/hooks"

  echo "Euxis hooks status for $target_dir:"
  echo ""

  for hook in "$HOOKS_DIR"/*; do
    [[ -f "$hook" ]] || continue
    local hook_name
    hook_name=$(basename "$hook")
    local target="$target_dir/$hook_name"

    if [[ -L "$target" ]]; then
      local existing
      existing=$(readlink "$target")
      if [[ "$existing" == "$hook" ]]; then
        echo "  $hook_name: INSTALLED (euxis)"
      else
        echo "  $hook_name: CONFLICT (symlink points to $existing)"
      fi
    elif [[ -f "$target" ]]; then
      echo "  $hook_name: CONFLICT (non-euxis hook exists)"
    else
      echo "  $hook_name: NOT INSTALLED"
    fi
  done
}

cmd_pr() {
  if ! command -v gh &>/dev/null; then
    echo "Error: gh (GitHub CLI) is required. Install via: brew install gh" >&2
    exit 1
  fi

  local title=""
  local body=""
  local extra_args=()

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --body) body="$2"; shift 2 ;;
      --title) title="$2"; shift 2 ;;
      -*) extra_args+=("$1" "$2"); shift 2 ;;
      *)
        if [[ -z "$title" ]]; then
          title="$1"; shift
        else
          extra_args+=("$1"); shift
        fi
        ;;
    esac
  done

  if [[ -z "$title" ]]; then
    echo "Error: PR title is required." >&2
    echo "Usage: euxis-hooks pr \"<title>\" [--body \"<text>\"]" >&2
    exit 1
  fi

  # Append signature if not already present
  if ! echo "$body" | grep -qF "Engineered with"; then
    if [[ -n "$body" ]]; then
      body="$body

$SIGNATURE_FOOTER"
    else
      # Use the PR template as the base body
      local template="$EUXIS_DIR/.github/pull_request_template.md"
      if [[ -f "$template" ]]; then
        body=$(cat "$template")
      else
        body="$SIGNATURE_FOOTER"
      fi
    fi
  fi

  gh pr create --title "$title" --body "$body" "${extra_args[@]}"
}

cmd_check_pr() {
  if ! command -v gh &>/dev/null; then
    echo "Error: gh (GitHub CLI) is required." >&2
    exit 1
  fi

  local pr_number="${1:-}"
  local failures=0

  if [[ -n "$pr_number" ]]; then
    # Check a specific PR
    local pr_body
    pr_body=$(gh pr view "$pr_number" --json body -q '.body' 2>/dev/null)
    if [[ -z "$pr_body" ]]; then
      echo "Error: Could not fetch PR #$pr_number" >&2
      exit 1
    fi

    echo "Checking PR #$pr_number..."
    if echo "$pr_body" | grep -qF "Sebastien Rousseau" && echo "$pr_body" | grep -qF "euxis.co"; then
      echo "  PASS: PR #$pr_number carries branding signature."
    else
      echo "  FAIL: PR #$pr_number missing branding signature."
      ((failures++)) || true
    fi
  else
    # Check all open PRs
    local pr_list
    pr_list=$(gh pr list --json number,title --jq '.[] | "\(.number)\t\(.title)"' 2>/dev/null)
    if [[ -z "$pr_list" ]]; then
      echo "No open PRs found."
      return 0
    fi

    echo "Checking open PRs for branding signature..."
    echo ""
    while IFS=$'\t' read -r num title; do
      local pr_body
      pr_body=$(gh pr view "$num" --json body -q '.body' 2>/dev/null)
      if echo "$pr_body" | grep -qF "Sebastien Rousseau" && echo "$pr_body" | grep -qF "euxis.co"; then
        echo "  PASS: #$num $title"
      else
        echo "  FAIL: #$num $title — missing branding signature"
        ((failures++)) || true
      fi
    done <<< "$pr_list"
  fi

  if [[ $failures -gt 0 ]]; then
    echo ""
    echo "$failures PR(s) missing branding signature."
    exit 1
  fi
}

# Main
case "${1:-}" in
  install)    shift; cmd_install "$@" ;;
  uninstall)  shift; cmd_uninstall "$@" ;;
  status)     shift; cmd_status "$@" ;;
  pr)         shift; cmd_pr "$@" ;;
  check-pr)   shift; cmd_check_pr "$@" ;;
  -h|--help)  usage ;;
  *)          usage >&2; exit 1 ;;
esac
