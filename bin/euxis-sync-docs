#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. Secure Documentation Sync.
# Dry-Run & Validation pattern: stage, verify, approve, execute.

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/bin/lib/ui.sh" ]]; then
  # shellcheck source=bin/lib/ui.sh
  source "${EUXIS_HOME}/bin/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-sync-docs — Secure Documentation Synchronization

Usage:
  euxis-sync-docs [OPTIONS]

Uses the Librarian agent to generate and apply documentation patches
with human-in-the-loop approval.

Options:
  -h, --help    Show this help text

Security:
  - Validates patches against destructive command patterns
  - Requires interactive approval before execution
  - Blocks: rm -rf, mkfs, dd, chmod 777, curl|bash, etc.

Examples:
  euxis-sync-docs           # Generate and review doc patches
  euxis-sync-docs --help    # Show this help
EOF
}

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
esac

export PATH="$PATH:$HOME/bin"

PATCH_FILE=$(mktemp /tmp/euxis_doc_patch.XXXXXX)
FORBIDDEN_PATTERNS='rm -rf /|mkfs|dd if=|> /dev/|chmod 777|curl.*\|.*bash|wget.*\|.*sh'

trap 'rm -f "$PATCH_FILE"' EXIT

echo "LIBRARIAN: Generating documentation and compliance patch..."

# 1. Ask Librarian for a bash patch
euxis librarian "Scan ~/.euxis. Output ONLY a valid bash script that:
1. Inserts '# (c) 2026 Euxis Fleet.' at the top of scripts missing it.
2. Updates version tags to v0.0.7 in all prompts.
3. Updates docs/user-guide.md with any new agents found in prompts/fleet/.
Do NOT include comments or conversational text outside of code." claude > "$PATCH_FILE" 2>/dev/null

if [[ ! -s "$PATCH_FILE" ]]; then
    echo "WARN: Librarian returned empty output. Nothing to apply."
    exit 0
fi

# 2. VALIDATION LAYER — block destructive patterns
if grep -qiE "$FORBIDDEN_PATTERNS" "$PATCH_FILE"; then
    echo "SECURITY ALERT: Destructive command detected in AI output. Aborting."
    echo "Blocked content:"
    grep -inE "$FORBIDDEN_PATTERNS" "$PATCH_FILE"
    exit 1
fi

# 3. HUMAN-IN-THE-LOOP (HITL) PREVIEW
echo "---------------------------------------------------"
echo "PROPOSED CHANGES (Preview):"
echo "---------------------------------------------------"
cat "$PATCH_FILE"
echo ""
echo "---------------------------------------------------"
read -p "Execute these changes? (y/N): " -n 1 -r
echo
if [[ $REPLY =~ ^[Yy]$ ]]; then
    bash "$PATCH_FILE"
    echo "Documentation synchronized."
else
    echo "Execution cancelled by user."
fi
