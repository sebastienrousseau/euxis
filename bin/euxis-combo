#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
set -euo pipefail

EUXIS_DIR="$HOME/.euxis"
SQUADS_FILE="$EUXIS_DIR/squads.json"

usage() {
  cat <<'EOF'
euxis-combo — Sequential agent chain execution

Usage:
  euxis-combo list
  euxis-combo info <combo-id>
  euxis-combo run <combo-id> "<task>" [--provider PROVIDER]

Commands:
  list    Table of combos with chains
  info    Chain detail with agent roles
  run     Execute chain sequentially, passing context between agents

Options:
  --provider  Override provider for all agents in the chain
  -h, --help  Show this help text
EOF
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
  fi
}

require_squads_file() {
  if [[ ! -f "$SQUADS_FILE" ]]; then
    echo "Error: squads.json not found at $SQUADS_FILE" >&2
    exit 1
  fi
}

validate_combo_id() {
  local id="$1"
  local exists
  exists=$(jq -r --arg id "$id" '.combos[] | select(.id == $id) | .id' "$SQUADS_FILE")
  if [[ -z "$exists" ]]; then
    echo "Error: Unknown combo '$id'. Run 'euxis-combo list' to see available combos." >&2
    exit 1
  fi
}

cmd_list() {
  require_jq
  require_squads_file

  printf "%-18s %-22s %-40s %s\n" "ID" "NAME" "DESCRIPTION" "CHAIN"
  printf "%-18s %-22s %-40s %s\n" "---" "---" "---" "---"

  jq -r '.combos[] | [.id, .name, .description, (.chain | join(" → "))] | @tsv' "$SQUADS_FILE" |
    while IFS=$'\t' read -r id name desc chain; do
      printf "%-18s %-22s %-40s %s\n" "$id" "$name" "$desc" "$chain"
    done
}

cmd_info() {
  local id="$1"
  require_jq
  require_squads_file
  validate_combo_id "$id"

  local combo
  combo=$(jq --arg id "$id" '.combos[] | select(.id == $id)' "$SQUADS_FILE")

  echo "Combo: $(echo "$combo" | jq -r '.name')"
  echo "ID:          $(echo "$combo" | jq -r '.id')"
  echo "Description: $(echo "$combo" | jq -r '.description')"
  echo "Chain:       $(echo "$combo" | jq -r '.chain | join(" → ")')"
  echo "Steps:       $(echo "$combo" | jq -r '.chain | length')"
  echo ""
  echo "Execution order:"

  local step=1
  while IFS= read -r agent; do
    echo "  $step. $agent"
    ((step++)) || true
  done < <(echo "$combo" | jq -r '.chain[]')
}

cmd_run() {
  local id="$1"; shift
  local task="$1"; shift
  local provider=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --provider) provider="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  require_jq
  require_squads_file
  validate_combo_id "$id"

  local combo
  combo=$(jq --arg id "$id" '.combos[] | select(.id == $id)' "$SQUADS_FILE")
  local combo_name
  combo_name=$(echo "$combo" | jq -r '.name')

  echo "═══════════════════════════════════════════════════════"
  echo "  Combo: $combo_name"
  echo "  Task: $task"
  echo "═══════════════════════════════════════════════════════"
  echo ""

  local context="$task"
  local step=1
  local total
  total=$(echo "$combo" | jq -r '.chain | length')

  while IFS= read -r agent; do
    echo "──────────────────────────────────────────────────────"
    echo "  Step $step/$total: $agent"
    echo "──────────────────────────────────────────────────────"

    # Build prompt: original task + previous context (capped at 4000 chars)
    local full_prompt
    if [[ $step -eq 1 ]]; then
      full_prompt="$task"
    else
      local truncated_context="${context:0:4000}"
      full_prompt="Original task: $task

Previous agent output:
$truncated_context

Continue the chain. Build on the previous output."
    fi

    # Invoke agent
    local output
    if [[ -n "$provider" ]]; then
      output=$(euxis "$agent" "$full_prompt" "$provider" 2>&1) || true
    else
      output=$(euxis "$agent" "$full_prompt" 2>&1) || true
    fi

    if [[ -z "$output" ]]; then
      echo "  Warning: $agent produced no output." >&2
      output="[No output from $agent]"
    fi

    echo "$output"
    echo ""
    context="$output"
    ((step++)) || true
  done < <(echo "$combo" | jq -r '.chain[]')

  echo "═══════════════════════════════════════════════════════"
  echo "  Combo '$combo_name' complete."
  echo "═══════════════════════════════════════════════════════"

  # Publish event to bus
  if command -v euxis-bus &>/dev/null; then
    euxis-bus publish combo-events "Combo '$id' completed for: $task" --sender "euxis-combo" --priority P2
  fi
}

# Main
case "${1:-}" in
  list)       cmd_list ;;
  info)
    if [[ -z "${2:-}" ]]; then echo "Error: info requires <combo-id>" >&2; usage >&2; exit 1; fi
    cmd_info "$2" ;;
  run)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then echo "Error: run requires <combo-id> and <task>" >&2; usage >&2; exit 1; fi
    cmd_run "$2" "$3" "${@:4}" ;;
  -h|--help)  usage ;;
  *)          usage >&2; exit 1 ;;
esac
