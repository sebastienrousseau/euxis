#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS HEALTH: Fleet Integrity & Configuration Health Check
# Validates naming, hardening, orphans, headers, and certification readiness.

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/bin/lib/ui.sh" ]]; then
  # shellcheck source=bin/lib/ui.sh
  source "${EUXIS_HOME}/bin/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-health — Fleet health check

Usage:
  euxis-health [options]

Validates naming, hardening, orphans, headers, and certification readiness.

Options:
  --silent    Exit code only, no output
  --json      JSON output (implies --silent)
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

EUXIS_HOME="${HOME}/.euxis"
BIN_DIR="${EUXIS_HOME}/bin"
REGISTRY="${EUXIS_HOME}/registry.json"
FAILURES=0
WARNINGS=0

# Silent mode: exit code only, no output (used by fast boot)
SILENT=false
JSON_OUTPUT=false
for arg in "$@"; do
    case "$arg" in
        --silent) SILENT=true ;;
        --json)   JSON_OUTPUT=true; SILENT=true ;;
    esac
done

log() {
    [[ "$SILENT" == true ]] && return
    echo "$@"
}

log "=================================================="
log "  EUXIS HEALTH CHECK"
log "=================================================="

# ────────────────────────────────────────────────────────
# CHECK 1: Naming Consistency (filename vs agent_id)
# ────────────────────────────────────────────────────────
log ""
log "[1/10] Naming Consistency..."

for dir in "${EUXIS_HOME}/prompts/core" "${EUXIS_HOME}/prompts/fleet"; do
    for f in "${dir}"/*.txt; do
        [[ -f "$f" ]] || continue
        filename=$(basename "$f" .txt)
        agent_id=$(grep -m1 '^agent_id:' "$f" | sed 's/agent_id: *//')
        if [[ "$filename" != "$agent_id" ]]; then
            log "  MISMATCH: $f — filename='${filename}' vs agent_id='${agent_id}'"
            ((FAILURES++)) || true
        fi
    done
done

if [[ $FAILURES -eq 0 ]]; then
    log "  All agent filenames match their agent_id."
fi

# ────────────────────────────────────────────────────────
# CHECK 2: Script Hardening (set -uo pipefail)
# ────────────────────────────────────────────────────────
log ""
log "[2/10] Script Hardening..."

HARDENING_FAILURES=0
for script in "${BIN_DIR}"/*; do
    [[ -f "$script" ]] || continue
    # Only check bash scripts (skip python, etc.)
    head -1 "$script" | grep -qE '(bash|sh)' || continue
    if ! grep -qE 'set -[euo]+.*pipefail|set -uo pipefail|set -euo pipefail' "$script"; then
        log "  MISSING HARDENING: $(basename "$script") — no 'set -uo pipefail' or 'set -euo pipefail'"
        ((HARDENING_FAILURES++)) || true
        ((WARNINGS++)) || true
    fi
done

if [[ $HARDENING_FAILURES -eq 0 ]]; then
    log "  All bash scripts have hardening flags."
fi

# ────────────────────────────────────────────────────────
# CHECK 3: Orphan Detection (agents not in registry)
# ────────────────────────────────────────────────────────
log ""
log "[3/10] Orphan Detection..."

REGISTRY_DB="${EUXIS_HOME}/registry.db"

# Try to get registered agent IDs (SQLite-first, JSON fallback)
REGISTERED=""
if [[ -f "$REGISTRY_DB" ]]; then
    # Use Python for SQLite access (more portable than sqlite3 CLI)
    REGISTERED=$(python3 -c "import sqlite3; conn = sqlite3.connect('$REGISTRY_DB'); print('\n'.join([r[0] for r in conn.execute('SELECT id FROM agents ORDER BY id').fetchall()]))" 2>/dev/null | sort)
fi
if [[ -z "$REGISTERED" ]] && [[ -f "$REGISTRY" ]]; then
    if command -v jq &>/dev/null; then
        REGISTERED=$(jq -r '.agents[].id' "$REGISTRY" 2>/dev/null | sort)
    fi
fi

if [[ -z "$REGISTERED" ]]; then
    log "  MISSING: No registry found (neither registry.db nor registry.json)"
    ((FAILURES++)) || true
else
    # Get actual agent files
    ACTUAL=""
    for dir in "${EUXIS_HOME}/prompts/core" "${EUXIS_HOME}/prompts/fleet"; do
        for f in "${dir}"/*.txt; do
            [[ -f "$f" ]] || continue
            name=$(basename "$f" .txt)
            ACTUAL="${ACTUAL}${name}"$'\n'
        done
    done
    ACTUAL=$(echo "$ACTUAL" | sort | sed '/^$/d')

    # Find orphans (in filesystem but not in registry)
    ORPHANS=$(comm -23 <(echo "$ACTUAL") <(echo "$REGISTERED"))
    if [[ -n "$ORPHANS" ]]; then
        log "  ORPHAN AGENTS (not in registry):"
        log "$ORPHANS" | sed 's/^/    /'
        ORPHAN_COUNT=$(echo "$ORPHANS" | wc -l | tr -d ' ')
        FAILURES=$((FAILURES + ORPHAN_COUNT))
    fi

    # Find ghosts (in registry but not in filesystem)
    GHOSTS=$(comm -13 <(echo "$ACTUAL") <(echo "$REGISTERED"))
    if [[ -n "$GHOSTS" ]]; then
        log "  GHOST ENTRIES (in registry but no file):"
        log "$GHOSTS" | sed 's/^/    /'
        GHOST_COUNT=$(echo "$GHOSTS" | wc -l | tr -d ' ')
        FAILURES=$((FAILURES + GHOST_COUNT))
    fi

    if [[ -z "$ORPHANS" && -z "$GHOSTS" ]]; then
        log "  All agents are registered. No orphans or ghosts."
    fi
fi

# ────────────────────────────────────────────────────────
# CHECK 4: Header Schema Validation
# ────────────────────────────────────────────────────────
log ""
log "[4/10] Header Schema Validation..."

REQUIRED_FIELDS=("agent_id" "role" "version" "tags" "last_updated")
HEADER_FAILURES=0

for dir in "${EUXIS_HOME}/prompts/core" "${EUXIS_HOME}/prompts/fleet"; do
    for f in "${dir}"/*.txt; do
        [[ -f "$f" ]] || continue
        # Extract frontmatter (between first --- and second ---)
        header=$(sed -n '1,/^---$/p' "$f" | tail -n +2 | sed '$d')
        for field in "${REQUIRED_FIELDS[@]}"; do
            if ! echo "$header" | grep -q "^${field}:"; then
                log "  MISSING FIELD: $(basename "$f") — '${field}'"
                ((HEADER_FAILURES++)) || true
            fi
        done
    done
done

if [[ $HEADER_FAILURES -eq 0 ]]; then
    log "  All agents have complete headers (agent_id, role, version, tags, last_updated)."
else
    FAILURES=$((FAILURES + HEADER_FAILURES))
fi

# ────────────────────────────────────────────────────────
# CHECK 5: Certification Readiness
# ────────────────────────────────────────────────────────
log ""
log "[5/10] Documentation Drift..."

USER_GUIDE="${EUXIS_HOME}/docs/user-guide.md"
if [[ -f "$USER_GUIDE" ]]; then
    LAST_DOC_SYNC=$(stat -c %Y "$USER_GUIDE" 2>/dev/null || stat -f %m "$USER_GUIDE" 2>/dev/null || echo 0)
    NOW=$(date +%s)
    if (( NOW - LAST_DOC_SYNC > 86400 )); then
        log "  STALE: docs/user-guide.md hasn't been updated in 24+ hours. Run 'euxis-sync-docs'."
        ((WARNINGS++)) || true
    else
        log "  docs/user-guide.md is current (updated within 24h)."
    fi
else
    log "  MISSING: docs/user-guide.md not found. Run 'euxis-sync-docs' to generate."
    ((WARNINGS++)) || true
fi

log ""
log "[6/10] Certification Readiness..."

CERTIFY_SCRIPT="${BIN_DIR}/euxis-certify"
if [[ -x "$CERTIFY_SCRIPT" ]]; then
    log "  euxis-certify is present and executable."
else
    log "  MISSING or NOT EXECUTABLE: euxis-certify"
    ((FAILURES++)) || true
fi

LINT_SCRIPT="${BIN_DIR}/euxis-lint"
if [[ -x "$LINT_SCRIPT" ]]; then
    log "  euxis-lint is present and executable."
else
    log "  MISSING or NOT EXECUTABLE: euxis-lint"
    ((FAILURES++)) || true
fi

TEST_SCRIPT="${BIN_DIR}/euxis-test-infra"
if [[ -x "$TEST_SCRIPT" ]]; then
    log "  euxis-test-infra is present and executable."
else
    log "  MISSING or NOT EXECUTABLE: euxis-test-infra"
    ((FAILURES++)) || true
fi

# ────────────────────────────────────────────────────────
# CHECK 6: Provider Connectivity (CLI tools)
# ────────────────────────────────────────────────────────
log ""
log "[7/10] Provider Connectivity..."

PROVIDER_WARNINGS=0
PROVIDER_CLIS=(claude gemini codex ollama opencode qwen crush kilo kiro-cli goose)
for cli in "${PROVIDER_CLIS[@]}"; do
    if command -v "$cli" &>/dev/null; then
        log "  FOUND: $cli"
    else
        log "  NOT FOUND: $cli (optional — install to enable this provider)"
        ((PROVIDER_WARNINGS++)) || true
    fi
done

TOTAL_PROVIDERS=${#PROVIDER_CLIS[@]}
FOUND_PROVIDERS=$((TOTAL_PROVIDERS - PROVIDER_WARNINGS))
if [[ $PROVIDER_WARNINGS -eq 0 ]]; then
    log "  All provider CLIs available."
elif [[ $FOUND_PROVIDERS -ge 1 ]]; then
    log "  ${FOUND_PROVIDERS} of ${TOTAL_PROVIDERS} provider CLIs available."
else
    log "  WARNING: No provider CLIs found. At least one is required."
    ((WARNINGS++)) || true
fi

# ────────────────────────────────────────────────────────
# CHECK 8: Codex Integrity (manifest + template files)
# ────────────────────────────────────────────────────────
log ""
log "[8/10] Codex Integrity..."

CODEX_DIR="${EUXIS_HOME}/config/codex"
CODEX_MANIFEST="${CODEX_DIR}/codex.json"

if [[ ! -f "$CODEX_MANIFEST" ]]; then
    log "  MISSING: codex.json not found at $CODEX_MANIFEST"
    ((FAILURES++)) || true
else
    if ! command -v jq &>/dev/null; then
        log "  SKIP: jq not installed, cannot validate codex.json"
        ((WARNINGS++)) || true
    elif ! jq empty "$CODEX_MANIFEST" 2>/dev/null; then
        log "  INVALID JSON: codex.json is not valid JSON"
        ((FAILURES++)) || true
    else
        CODEX_FAILURES=0
        while IFS=$'\t' read -r tid tfile; do
            if [[ ! -f "${CODEX_DIR}/${tfile}" ]]; then
                log "  MISSING TEMPLATE: '$tid' references '${tfile}' but file not found"
                ((CODEX_FAILURES++)) || true
            fi
        done < <(jq -r '.templates[] | [.id, .file] | @tsv' "$CODEX_MANIFEST")

        if [[ $CODEX_FAILURES -eq 0 ]]; then
            TEMPLATE_COUNT=$(jq '.templates | length' "$CODEX_MANIFEST")
            log "  Codex manifest valid. $TEMPLATE_COUNT templates verified."
        else
            FAILURES=$((FAILURES + CODEX_FAILURES))
        fi
    fi
fi

# ────────────────────────────────────────────────────────
# CHECK 9: Bus Pipe Activity
# ────────────────────────────────────────────────────────
log ""
log "[9/10] Bus Pipe Activity..."

BUS_DIR="${EUXIS_HOME}/data/bus/pipes"
if [[ -d "$BUS_DIR" ]]; then
    PIPE_COUNT=0
    MSG_COUNT=0
    STALE_PIPES=0
    NOW=$(date +%s)
    for pipe in "${BUS_DIR}"/*/; do
        [[ -d "$pipe" ]] || continue
        PIPE_COUNT=$((PIPE_COUNT + 1))
        pipe_msgs=$(find "$pipe" -name "*.msg" -type f 2>/dev/null | wc -l | tr -d ' ')
        MSG_COUNT=$((MSG_COUNT + pipe_msgs))
        # Check for stale pipes (no messages in 7 days)
        if [[ "$(uname)" == "Darwin" ]]; then
            LATEST=$(find "$pipe" -name "*.msg" -type f -exec stat -f '%m' {} \; 2>/dev/null | sort -rn | head -1)
        else
            LATEST=$(find "$pipe" -name "*.msg" -type f -exec stat -c '%Y' {} \; 2>/dev/null | sort -rn | head -1)
        fi
        if [[ -n "$LATEST" ]]; then
            LATEST_INT=${LATEST%.*}
            if (( NOW - LATEST_INT > 604800 )); then
                STALE_PIPES=$((STALE_PIPES + 1))
            fi
        fi
    done
    log "  ${PIPE_COUNT} pipe(s), ${MSG_COUNT} message(s) total."
    if [[ $STALE_PIPES -gt 0 ]]; then
        log "  ${STALE_PIPES} pipe(s) stale (no activity in 7+ days)."
        ((WARNINGS++)) || true
    else
        log "  All pipes active."
    fi
else
    log "  Bus directory not found — no message pipes configured."
    ((WARNINGS++)) || true
fi

# ────────────────────────────────────────────────────────
# CHECK 10: Cortex Connectivity
# ────────────────────────────────────────────────────────
log ""
log "[10/10] Cortex Connectivity..."

CORTEX_SCRIPT="${BIN_DIR}/euxis-cortex"
if [[ -x "$CORTEX_SCRIPT" ]]; then
    if CORTEX_OUT=$("$CORTEX_SCRIPT" stats 2>&1); then
        log "  Cortex is reachable."
        # Extract memory count if available
        MEM_COUNT=$(echo "$CORTEX_OUT" | grep -oP '\d+ memor' | head -1 | grep -oP '\d+' || true)
        if [[ -n "$MEM_COUNT" ]]; then
            log "  ${MEM_COUNT} memories stored."
        fi
    else
        log "  Cortex unreachable or not initialized."
        ((WARNINGS++)) || true
    fi
else
    log "  euxis-cortex not found — cortex integration unavailable."
    ((WARNINGS++)) || true
fi

# ────────────────────────────────────────────────────────
# SUMMARY
# ────────────────────────────────────────────────────────
log ""
log "=================================================="
if [[ $FAILURES -eq 0 && $WARNINGS -eq 0 ]]; then
    log "  HEALTH CHECK PASSED. Fleet integrity: 100%."
elif [[ $FAILURES -eq 0 ]]; then
    log "  HEALTH CHECK PASSED with $WARNINGS warning(s)."
else
    log "  HEALTH CHECK FAILED: $FAILURES error(s), $WARNINGS warning(s)."
fi
log "=================================================="

# JSON output mode
if [[ "$JSON_OUTPUT" == true ]]; then
    AGENT_COUNT=0
    for dir in "${EUXIS_HOME}/prompts/core" "${EUXIS_HOME}/prompts/fleet"; do
        for f in "${dir}"/*.txt; do [[ -f "$f" ]] && AGENT_COUNT=$((AGENT_COUNT + 1)); done
    done
    PROVIDER_FOUND=0
    for cli in "${PROVIDER_CLIS[@]}"; do
        command -v "$cli" &>/dev/null && PROVIDER_FOUND=$((PROVIDER_FOUND + 1))
    done
    STATUS="healthy"
    [[ $FAILURES -gt 0 ]] && STATUS="unhealthy"
    [[ $WARNINGS -gt 0 && $FAILURES -eq 0 ]] && STATUS="degraded"
    cat <<ENDJSON
{
  "status": "${STATUS}",
  "failures": ${FAILURES},
  "warnings": ${WARNINGS},
  "agents": ${AGENT_COUNT},
  "providers": ${PROVIDER_FOUND},
  "bus_pipes": ${PIPE_COUNT:-0},
  "bus_messages": ${MSG_COUNT:-0},
  "timestamp": "$(date -u +%Y-%m-%dT%H:%M:%SZ)"
}
ENDJSON
fi

[[ $FAILURES -eq 0 ]]
