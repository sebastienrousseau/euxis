#!/usr/bin/env python3
"""Euxis Dynamic Agent Synthesis — compose transient agents from capability primitives."""

import argparse
import json
import os
import sqlite3
import sys
from datetime import date
from pathlib import Path

EUXIS_ROOT = Path.home() / ".euxis"
CAPABILITIES_FILE = EUXIS_ROOT / "capabilities.json"
REGISTRY_FILE = EUXIS_ROOT / "agents/registry.json"
REGISTRY_DB = EUXIS_ROOT / "agents/registry.db"
SYNTHESIZED_DIR = EUXIS_ROOT / "prompts" / "synthesized"
COMMON_PROTOCOL = EUXIS_ROOT / "prompts" / "protocols" / "_common.txt"

TODAY = date.today().isoformat()


def load_capabilities():
    if not CAPABILITIES_FILE.exists():
        print(f"ERROR: Capabilities file not found: {CAPABILITIES_FILE}", file=sys.stderr)
        sys.exit(1)
    with open(CAPABILITIES_FILE) as f:
        return json.load(f)


def load_registry():
    """Load registry from SQLite-first, JSON fallback."""
    # Try SQLite first
    if REGISTRY_DB.exists():
        try:
            conn = sqlite3.connect(str(REGISTRY_DB))
            conn.row_factory = sqlite3.Row
            agents = []
            for row in conn.execute("SELECT id, path, tier, version, activation FROM agents ORDER BY id"):
                # Get tags
                tags = [r[0] for r in conn.execute(
                    "SELECT t.name FROM tags t JOIN agent_tags at ON t.id = at.tag_id WHERE at.agent_id = ?",
                    (row["id"],)
                )]
                agents.append({
                    "id": row["id"], "path": row["path"], "tier": row["tier"],
                    "version": row["version"], "tags": tags,
                })
                if row["activation"]:
                    agents[-1]["activation"] = row["activation"]
            meta = {}
            for r in conn.execute("SELECT key, value FROM registry_metadata"):
                meta[r["key"]] = r["value"]
            conn.close()
            result = {"agents": agents}
            if "protocol_version" in meta:
                result["protocol_version"] = meta["protocol_version"]
            if "schema_version" in meta:
                result["schema_version"] = meta["schema_version"]
            return result
        except sqlite3.Error:
            pass  # Fall through to JSON

    if not REGISTRY_FILE.exists():
        print(f"ERROR: Registry not found (neither agents/registry.db nor agents/registry.json)", file=sys.stderr)
        sys.exit(1)
    with open(REGISTRY_FILE) as f:
        return json.load(f)


def save_registry(registry):
    """Save registry to JSON and sync to SQLite if DB exists."""
    with open(REGISTRY_FILE, "w") as f:
        json.dump(registry, f, indent=2)
        f.write("\n")

    # Sync to SQLite if database exists
    if REGISTRY_DB.exists():
        try:
            conn = sqlite3.connect(str(REGISTRY_DB))
            for agent in registry.get("agents", []):
                conn.execute(
                    "INSERT OR REPLACE INTO agents (id, path, tier, version, activation) "
                    "VALUES (?, ?, ?, ?, ?)",
                    (agent["id"], agent.get("path", ""), agent.get("tier", "fleet"),
                     agent.get("version", "0.0.8"), agent.get("activation"))
                )
                # Sync tags
                for tag in agent.get("tags", []):
                    conn.execute("INSERT OR IGNORE INTO tags (name) VALUES (?)", (tag,))
                    conn.execute(
                        "INSERT OR IGNORE INTO agent_tags (agent_id, tag_id) "
                        "SELECT ?, id FROM tags WHERE name = ?",
                        (agent["id"], tag)
                    )
            conn.commit()
            conn.close()
        except sqlite3.Error as e:
            print(f"WARNING: Failed to sync to agents/registry.db: {e}", file=sys.stderr)


def cmd_list_capabilities(args):
    data = load_capabilities()
    caps = data["capabilities"]
    print(f"{'ID':<25} {'Name':<25} {'Compatible With':<5}")
    print("-" * 57)
    for cap in caps:
        compat_count = len(cap["compatible_with"])
        print(f"{cap['id']:<25} {cap['name']:<25} {compat_count}")


def cmd_inspect(args):
    data = load_capabilities()
    for cap in data["capabilities"]:
        if cap["id"] == args.capability_id:
            print(json.dumps(cap, indent=2))
            return
    print(f"ERROR: Capability '{args.capability_id}' not found.", file=sys.stderr)
    sys.exit(1)


def cmd_compose(args):
    data = load_capabilities()
    cap_map = {c["id"]: c for c in data["capabilities"]}

    requested_ids = [s.strip() for s in args.capabilities.split(",")]

    # Validate existence
    for cid in requested_ids:
        if cid not in cap_map:
            print(f"ERROR: Unknown capability '{cid}'. Available: {', '.join(cap_map.keys())}", file=sys.stderr)
            sys.exit(1)

    requested_caps = [cap_map[cid] for cid in requested_ids]

    # Check conflicts
    for cap in requested_caps:
        for other_id in cap["conflicts_with"]:
            if other_id in requested_ids:
                print(f"ERROR: Capability '{cap['id']}' conflicts with '{other_id}'. Cannot compose.", file=sys.stderr)
                sys.exit(1)

    # Check compatibility (warn only)
    for i, cap in enumerate(requested_caps):
        for other in requested_caps[i + 1:]:
            if other["id"] not in cap["compatible_with"] and cap["id"] not in other["compatible_with"]:
                print(f"WARNING: '{cap['id']}' and '{other['id']}' are not declared compatible. Proceeding anyway.")

    # Build the prompt
    name = args.name
    cap_names = [c["name"] for c in requested_caps]
    cap_ids = [c["id"] for c in requested_caps]
    tags_list = ", ".join(f'"{t}"' for t in ["synthesized"] + cap_ids)
    caps_list = ", ".join(f'"{c}"' for c in cap_ids)

    mandate_sections = []
    for cap in requested_caps:
        mandate_sections.append(f"### {cap['name']}\n\n{cap['prompt_fragment']}")

    mandate = "\n\n".join(mandate_sections)

    prompt = f"""---
agent_id: {name}
role: "Synthesized agent: {', '.join(cap_names)}"
version: "6.0"
tags: [{tags_list}]
last_updated: "{TODAY}"
synthesized: true
capabilities: [{caps_list}]
---

# Euxis Synthesized Agent: {name.replace('-', ' ').title()}

You are a **dynamically composed agent** within the Euxis system, synthesized from the following capabilities: {', '.join(cap_names)}.

## Mandate

{mandate}

## Scope Boundaries

- You are a transient agent. Your prompt was composed at runtime.
- You MUST operate within the combined scope of your capabilities.
- You MUST NOT exceed the union of your capability scopes.

## Output Format

Follow the standard Euxis output format with EUXIS_HANDOFF block.
"""

    # Write prompt file
    SYNTHESIZED_DIR.mkdir(parents=True, exist_ok=True)
    prompt_path = SYNTHESIZED_DIR / f"{name}.txt"

    if args.dry_run:
        print("=== DRY RUN — Generated prompt ===\n")
        print(prompt)
        print(f"Would write to: {prompt_path}")
        print("Would register agent in agents/registry.json")
        return

    with open(prompt_path, "w") as f:
        f.write(prompt)
    print(f"Prompt written: {prompt_path}")

    # Register in registry
    registry = load_registry()
    # Remove existing entry with same id if present
    registry["agents"] = [a for a in registry["agents"] if a["id"] != name]
    registry["agents"].append({
        "id": name,
        "path": f"agents/prompts/synthesized/{name}.txt",
        "tier": "synthesized",
        "version": "6.0",
        "tags": ["synthesized"] + cap_ids
    })
    save_registry(registry)
    print(f"Agent '{name}' registered in agents/registry.json (tier: synthesized)")


def cmd_dissolve(args):
    name = args.agent_name
    prompt_path = SYNTHESIZED_DIR / f"{name}.txt"

    if prompt_path.exists():
        prompt_path.unlink()
        print(f"Removed prompt: {prompt_path}")
    else:
        print(f"WARNING: Prompt file not found: {prompt_path}")

    registry = load_registry()
    before = len(registry["agents"])
    registry["agents"] = [a for a in registry["agents"] if a["id"] != name]
    after = len(registry["agents"])
    if before > after:
        save_registry(registry)
        print(f"Agent '{name}' removed from registry")
    else:
        print(f"WARNING: Agent '{name}' was not found in registry")

    # Also remove from SQLite if present
    if REGISTRY_DB.exists():
        try:
            conn = sqlite3.connect(str(REGISTRY_DB))
            conn.execute("DELETE FROM agent_tags WHERE agent_id = ?", (name,))
            conn.execute("DELETE FROM agent_capabilities WHERE agent_id = ?", (name,))
            conn.execute("DELETE FROM agents WHERE id = ?", (name,))
            conn.commit()
            conn.close()
        except sqlite3.Error:
            pass

    print(f"Dissolved agent: {name}")


def cmd_list_agents(args):
    SYNTHESIZED_DIR.mkdir(parents=True, exist_ok=True)
    files = sorted(SYNTHESIZED_DIR.glob("*.txt"))
    if not files:
        print("No synthesized agents found.")
        return

    print(f"{'Agent Name':<30} {'Capabilities'}")
    print("-" * 70)
    for f in files:
        agent_name = f.stem
        # Parse capabilities from YAML header
        caps = []
        with open(f) as fh:
            in_header = False
            for line in fh:
                line = line.rstrip()
                if line == "---" and not in_header:
                    in_header = True
                    continue
                if line == "---" and in_header:
                    break
                if in_header and line.startswith("capabilities:"):
                    # Parse the inline list
                    raw = line.split(":", 1)[1].strip()
                    raw = raw.strip("[]")
                    caps = [c.strip().strip('"') for c in raw.split(",") if c.strip()]
        print(f"{agent_name:<30} {', '.join(caps)}")


def main():
    parser = argparse.ArgumentParser(
        description="Euxis Dynamic Agent Synthesis — compose transient agents from capability primitives."
    )
    subparsers = parser.add_subparsers(dest="command", required=True)

    # compose
    p_compose = subparsers.add_parser("compose", help="Compose a new agent from capabilities")
    p_compose.add_argument("name", help="Agent name (used as identifier)")
    p_compose.add_argument("--capabilities", required=True, help="Comma-separated capability IDs")
    p_compose.add_argument("--dry-run", action="store_true", help="Preview without writing files")
    p_compose.set_defaults(func=cmd_compose)

    # list-capabilities
    p_list_caps = subparsers.add_parser("list-capabilities", help="List all available capabilities")
    p_list_caps.set_defaults(func=cmd_list_capabilities)

    # inspect
    p_inspect = subparsers.add_parser("inspect", help="Show details of a capability")
    p_inspect.add_argument("capability_id", help="Capability ID to inspect")
    p_inspect.set_defaults(func=cmd_inspect)

    # dissolve
    p_dissolve = subparsers.add_parser("dissolve", help="Remove a synthesized agent")
    p_dissolve.add_argument("agent_name", help="Agent name to dissolve")
    p_dissolve.set_defaults(func=cmd_dissolve)

    # list-agents
    p_list_agents = subparsers.add_parser("list-agents", help="List all synthesized agents")
    p_list_agents.set_defaults(func=cmd_list_agents)

    args = parser.parse_args()
    args.func(args)


if __name__ == "__main__":
    main()
