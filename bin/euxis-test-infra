#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS INFRA TEST: Branch Coverage for euxis.sh
# Uses mocked providers to verify routing logic without spending money.

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/bin/lib/ui.sh" ]]; then
  # shellcheck source=bin/lib/ui.sh
  source "${EUXIS_HOME}/bin/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-test-infra — Infrastructure test suite

Usage:
  euxis-test-infra

Runs branch coverage tests for euxis.sh using mocked providers.

Options:
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

EUXIS_HOME="$HOME/.euxis"
EUXIS_SCRIPT="$EUXIS_HOME/bin/euxis.sh"
PASS=0
FAIL=0

# Source validation library
# shellcheck source=bin/lib/validation.sh
source "$EUXIS_HOME/bin/lib/validation.sh" 2>/dev/null || {
    echo "FATAL: Cannot load validation library" >&2
    exit 1
}

report() {
    local status="$1"
    local name="$2"
    if [[ "$status" == "PASS" ]]; then
        echo "  PASS: $name"
        PASS=$((PASS + 1))
    else
        echo "  FAIL: $name"
        FAIL=$((FAIL + 1))
    fi
}

echo "=================================================="
echo "  EUXIS INFRASTRUCTURE VALIDATION & TESTING"
echo "=================================================="

# FAIL-FAST VALIDATION GATES
echo ""
echo "[GATE 0] Pre-Test Validation..."
echo "--------------------------------------------------"
if ! validate_minimal; then
    echo ""
    echo "INFRASTRUCTURE TESTS ABORTED: Pre-test validation failed."
    echo "Fix validation errors before running infrastructure tests."
    exit 1
fi

# ADDITIONAL TEST-SPECIFIC VALIDATIONS
echo ""
echo "[GATE 0a] Test-Specific Validation..."
echo "--------------------------------------------------"

# Validate main euxis script exists and is executable
if ! validate_file_executable "$EUXIS_SCRIPT" "Main Euxis script"; then
    echo "INFRASTRUCTURE TESTS ABORTED: Main script not accessible."
    exit 1
fi

# Validate registry contains test-required agents (SQLite-first, JSON fallback)
REQUIRED_TEST_AGENTS=("architect" "orchestrator")
for agent in "${REQUIRED_TEST_AGENTS[@]}"; do
    _agent_found=false
    if [[ -f "$EUXIS_HOME/registry.db" ]]; then
        [[ -n "$(python3 -c "import sqlite3; conn = sqlite3.connect('$EUXIS_HOME/registry.db'); r = conn.execute(\"SELECT 1 FROM agents WHERE id='${agent}'\").fetchone(); print('1' if r else '')" 2>/dev/null)" ]] && _agent_found=true
    fi
    if [[ "$_agent_found" != "true" ]] && [[ -f "$EUXIS_HOME/registry.json" ]]; then
        jq -e ".agents[] | select(.id == \"$agent\")" "$EUXIS_HOME/registry.json" &>/dev/null && _agent_found=true
    fi
    if [[ "$_agent_found" == "true" ]]; then
        validation_pass "Test agent '$agent' found in registry"
    else
        validation_error "Required test agent '$agent' not found in registry"
    fi
done

if [[ ${#VALIDATION_ERRORS[@]} -gt 0 ]]; then
    echo ""
    echo "INFRASTRUCTURE TESTS ABORTED: Test-specific validation failed."
    exit 1
fi

echo ""
echo "[GATE 1] Infrastructure Logic Tests..."
echo "--------------------------------------------------"
echo "TESTING INFRASTRUCTURE LOGIC..."

# TEST 1: Missing arguments shows usage
OUTPUT=$("$EUXIS_SCRIPT" 2>&1 || true)
if [[ "$OUTPUT" == *"Usage:"* ]]; then
    report "PASS" "Handles missing arguments"
else
    report "FAIL" "Handles missing arguments"
fi

# TEST 2: Invalid agent name rejected
OUTPUT=$("$EUXIS_SCRIPT" "nonexistent-agent-xyz" "test task" claude 2>&1 || true)
if [[ "$OUTPUT" == *"Unknown agent"* ]]; then
    report "PASS" "Rejects unknown agent"
else
    report "FAIL" "Rejects unknown agent"
fi

# TEST 3: Invalid provider rejected
OUTPUT=$("$EUXIS_SCRIPT" "architect" "test task" "badprovider" 2>&1 || true)
if [[ "$OUTPUT" == *"Unknown provider"* ]]; then
    report "PASS" "Rejects unknown provider"
else
    report "FAIL" "Rejects unknown provider"
fi

# TEST 4: Agent name sanitization (path traversal defense)
OUTPUT=$("$EUXIS_SCRIPT" "../../../etc/passwd" "test" claude 2>&1 || true)
if [[ "$OUTPUT" == *"Invalid agent name"* ]]; then
    report "PASS" "Rejects path traversal in agent name"
else
    report "FAIL" "Rejects path traversal in agent name"
fi

# TEST 5: Partial files (underscore prefix) rejected
OUTPUT=$("$EUXIS_SCRIPT" "_protocol" "test" claude 2>&1 || true)
if [[ "$OUTPUT" == *"Unknown agent"* ]] || [[ "$OUTPUT" == *"partial files not allowed"* ]]; then
    report "PASS" "Rejects partial files (_protocol)"
else
    report "FAIL" "Rejects partial files (_protocol)"
fi

# TEST 6: Delegate with missing args
OUTPUT=$("$EUXIS_SCRIPT" delegate 2>&1 || true)
if [[ "$OUTPUT" == *"delegate requires"* ]]; then
    report "PASS" "Delegate rejects missing arguments"
else
    report "FAIL" "Delegate rejects missing arguments"
fi

# TEST 7: Project directory creation (uses mock provider to avoid API calls)
TEMP_PROJECT="euxis_test_$$"
PROJECTS_DIR="${EUXIS_PROJECTS_DIR:-/tmp/euxis/projects}"
EUXIS_PROJECTS_DIR="$PROJECTS_DIR" EUXIS_PROJECT="$TEMP_PROJECT" EUXIS_MOCK_PROVIDER=true "$EUXIS_SCRIPT" architect "test" claude >/dev/null 2>&1 || true
if [[ -d "$PROJECTS_DIR/$TEMP_PROJECT/architect/output" ]]; then
    report "PASS" "Creates project directory structure"
    rm -rf "$PROJECTS_DIR/$TEMP_PROJECT"
else
    report "FAIL" "Creates project directory structure"
fi

echo "---------------------------------------------------"
echo "Results: $PASS passed, $FAIL failed, $((PASS + FAIL)) total"

# FINAL GATE: Configuration drift detection
echo ""
echo "[GATE 2] Configuration Drift Detection..."
echo "--------------------------------------------------"

DRIFT_ERRORS=0

# Check if registry was modified during tests (SQLite-first, JSON fallback)
REGISTRY_HASH_BEFORE=""
if [[ -f "$EUXIS_HOME/registry.db" ]]; then
    REGISTRY_HASH_BEFORE=$(md5sum "$EUXIS_HOME/registry.db" 2>/dev/null | cut -d' ' -f1 || echo "")
fi
[[ -z "$REGISTRY_HASH_BEFORE" ]] && REGISTRY_HASH_BEFORE=$(md5sum "$EUXIS_HOME/registry.json" 2>/dev/null | cut -d' ' -f1 || echo "")
if [[ -n "$REGISTRY_HASH_BEFORE" ]]; then
    validation_pass "Registry integrity maintained during tests"
else
    validation_warning "Cannot verify registry integrity"
fi

# Verify temp files were cleaned up
TEMP_FILES=$(find /tmp -maxdepth 1 \( -name "euxis_test_*" -o -name "*euxis_semantic_resp*" \) 2>/dev/null | wc -l || echo "0")
if [[ $TEMP_FILES -gt 0 ]]; then
    validation_warning "$TEMP_FILES temporary test files remain in /tmp"
    # Clean them up
    find /tmp -maxdepth 1 \( -name "euxis_test_*" -o -name "*euxis_semantic_resp*" \) 2>/dev/null | xargs rm -f 2>/dev/null || true
    validation_pass "Cleaned up temporary test files"
else
    validation_pass "No temporary test files left behind"
fi

# Verify no project directories were corrupted
if [[ -d "$EUXIS_HOME/data/projects" ]]; then
    ORPHANED_DIRS=$(find "$EUXIS_HOME/data/projects" -name "euxis_test_*" -type d 2>/dev/null | wc -l || echo "0")
    if [[ $ORPHANED_DIRS -gt 0 ]]; then
        validation_warning "$ORPHANED_DIRS test project directories need cleanup"
        find "$EUXIS_HOME/data/projects" -name "euxis_test_*" -type d 2>/dev/null | xargs rm -rf 2>/dev/null || true
        validation_pass "Cleaned up orphaned test directories"
    else
        validation_pass "No orphaned test directories found"
    fi
fi

echo "---------------------------------------------------"

if [[ $FAIL -eq 0 && $DRIFT_ERRORS -eq 0 ]]; then
    echo ""
    echo "=================================================="
    echo "  INFRASTRUCTURE VALIDATION & TESTS PASSED"
    echo "  Pre-validation: PASS"
    echo "  Logic tests: $PASS/$((PASS + FAIL))"
    echo "  Configuration drift: NONE"
    echo "=================================================="
    exit 0
else
    echo ""
    echo "=================================================="
    echo "  INFRASTRUCTURE VALIDATION & TESTS FAILED"
    echo "  Logic test failures: $FAIL"
    echo "  Configuration drift issues: $DRIFT_ERRORS"
    echo "=================================================="
    exit 1
fi
