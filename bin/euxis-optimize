#!/bin/bash
# EUXIS OPTIMIZE v4.1: System-Wide Tune-Up
# 1. Benchmarks Accuracy (Certify)
# 2. Cleans Memory (Librarian GC)
# 3. Compresses Prompts (Librarian Audit)
# 4. Quality Assurance (Architect Self-Reflection)

set -euo pipefail

# Ensure ~/bin is in PATH for euxis commands
export PATH="$PATH:$HOME/bin"

LOG_FILE="/tmp/euxis_optimize_$(date +%s).log"

echo "🏎️  STARTING EUXIS GRAND PRIX OPTIMIZATION..." | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"

# --- STEP 1: ACCURACY BASELINE (The Gym) ---
echo "🎯 [1/4] Establishing Accuracy Baseline..." | tee -a "$LOG_FILE"
if euxis-certify >> "$LOG_FILE" 2>&1; then
    echo "   ✅ Baseline: PASS" | tee -a "$LOG_FILE"
else
    echo "   ⚠️  Baseline: FAIL (continuing to see if optimization helps)" | tee -a "$LOG_FILE"
fi
echo "" | tee -a "$LOG_FILE"

# --- STEP 2: MEMORY GARBAGE COLLECTION (The Librarian) ---
echo "🧹 [2/4] Running Memory Garbage Collection..." | tee -a "$LOG_FILE"
euxis librarian "MAINTENANCE TASK:
1. Scan all memory.md files under ~/.euxis/projects/ for stale or duplicate entries.
2. COMPRESS by removing ephemeral details (temp debugging, line-number fixes, typos).
3. PRESERVE all DECISION:, LESSON:, and REFLECTION: entries.
4. OUTPUT: A summary of what was pruned and space saved." claude >> "$LOG_FILE" 2>&1
echo "   ✅ Memory GC complete." | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"

# --- STEP 3: PROMPT COMPRESSION (Token Optimization) ---
echo "⚡ [3/4] Optimizing Token Performance..." | tee -a "$LOG_FILE"
euxis librarian "AUDIT TASK:
1. Read ~/.euxis/prompts/architect.txt and ~/.euxis/prompts/debugger.txt.
2. IDENTIFY token bloat: unnecessary polite words, redundant instructions, repeated phrases.
3. SUGGEST a compressed version of each that saves tokens but keeps accuracy.
4. COUNT: How many tokens could be saved per prompt?
5. ESTIMATE the latency reduction from fewer input tokens." claude >> "$LOG_FILE" 2>&1
echo "   ✅ Token audit complete." | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"

# --- STEP 4: ARCHITECT SELF-REFLECTION ---
echo "🧠 [4/4] Quality Assurance Check..." | tee -a "$LOG_FILE"
euxis architect "SELF-REFLECTION:
1. Review the certification results from Step 1 (any failures?).
2. Review the prompt compression suggestions from Step 3.
3. PROPOSE a 'v4.1 Patch' — specific edits to apply immediately.
4. List each change as: FILE: <path>, CHANGE: <what to do>, REASON: <why>." claude >> "$LOG_FILE" 2>&1
echo "   ✅ QA review complete." | tee -a "$LOG_FILE"
echo "" | tee -a "$LOG_FILE"

echo "🏁 OPTIMIZATION COMPLETE." | tee -a "$LOG_FILE"
echo "   Report saved to: $LOG_FILE"
echo ""
echo "   Review key sections:"
echo "   grep -A 20 'AUDIT TASK' $LOG_FILE    # Token savings"
echo "   grep -A 20 'SELF-REFLECTION' $LOG_FILE  # Patch proposals"
