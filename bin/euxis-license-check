#!/bin/bash
# EUXIS LICENSE CHECK: Python Dependency License Compatibility Checker
# Validates Python dependencies against license policy
set -euo pipefail

# Source common utilities
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck source=lib/common.sh
source "${SCRIPT_DIR}/lib/common.sh"

EUXIS_HOME="${EUXIS_HOME:-${HOME}/.euxis}"
PROJECT_ROOT="${PWD}"

# License compatibility categories
declare -A LICENSE_CATEGORIES
LICENSE_CATEGORIES[COPYLEFT]="GPL-2.0,GPL-2.0-only,GPL-2.0-or-later,GPL-3.0,GPL-3.0-only,GPL-3.0-or-later,AGPL-3.0,AGPL-3.0-only,AGPL-3.0-or-later,LGPL-2.1,LGPL-3.0,MPL-2.0,SSPL-1.0"
LICENSE_CATEGORIES[PERMISSIVE]="MIT,BSD-2-Clause,BSD-3-Clause,Apache-2.0,ISC,Unlicense,WTFPL,CC0-1.0"
LICENSE_CATEGORIES[COMMERCIAL]="Commercial,Proprietary"

# Default license policy (can be overridden)
POLICY_ALLOW_COPYLEFT="${EUXIS_POLICY_ALLOW_COPYLEFT:-false}"
POLICY_PROJECT_LICENSE="${EUXIS_POLICY_PROJECT_LICENSE:-MIT}"

usage() {
    cat <<EOF
USAGE: euxis-license-check [OPTIONS] [requirements-file]

Validates Python dependency licenses against compliance policy.

OPTIONS:
  --allow-copyleft     Allow copyleft licenses (GPL, AGPL, etc.)
  --project-license    Set project license for compatibility checking (default: MIT)
  --requirements FILE  Path to requirements.txt (default: ./requirements.txt)
  --format FORMAT      Output format: table, json, markdown (default: table)
  --silent             Only show violations
  --help               Show this help

EXAMPLES:
  euxis-license-check
  euxis-license-check --allow-copyleft requirements.txt
  euxis-license-check --format json --silent

ENVIRONMENT:
  EUXIS_POLICY_ALLOW_COPYLEFT    Allow copyleft licenses (true/false)
  EUXIS_POLICY_PROJECT_LICENSE   Project license (default: MIT)
EOF
}

# Parse command line arguments
REQUIREMENTS_FILE="${PROJECT_ROOT}/requirements.txt"
OUTPUT_FORMAT="table"
SILENT_MODE=false

while [[ $# -gt 0 ]]; do
    case $1 in
        --allow-copyleft)
            POLICY_ALLOW_COPYLEFT=true
            shift
            ;;
        --project-license)
            POLICY_PROJECT_LICENSE="$2"
            shift 2
            ;;
        --requirements)
            REQUIREMENTS_FILE="$2"
            shift 2
            ;;
        --format)
            OUTPUT_FORMAT="$2"
            shift 2
            ;;
        --silent)
            SILENT_MODE=true
            shift
            ;;
        --help)
            usage
            exit 0
            ;;
        -*)
            log_error "Unknown option: $1"
            usage
            exit 1
            ;;
        *)
            REQUIREMENTS_FILE="$1"
            shift
            ;;
    esac
done

# Check if requirements file exists
if [[ ! -f "$REQUIREMENTS_FILE" ]]; then
    log_error "Requirements file not found: $REQUIREMENTS_FILE"
    exit 1
fi


# Function to categorize license
categorize_license() {
    local license="$1"
    local normalized_license

    # Normalize license name (remove version numbers, spaces, etc.)
    normalized_license=$(echo "$license" | sed 's/[[:space:]]*([^)]*)//g' | sed 's/[[:space:]]*$//g')

    # Check each category
    if echo "${LICENSE_CATEGORIES[COPYLEFT]}" | grep -q "$normalized_license"; then
        echo "COPYLEFT"
    elif echo "${LICENSE_CATEGORIES[PERMISSIVE]}" | grep -q "$normalized_license"; then
        echo "PERMISSIVE"
    elif echo "${LICENSE_CATEGORIES[COMMERCIAL]}" | grep -q "$normalized_license"; then
        echo "COMMERCIAL"
    else
        echo "UNKNOWN"
    fi
}

# Function to check license compatibility
check_compatibility() {
    local license="$1"
    local category="$2"

    case "$category" in
        COPYLEFT)
            if [[ "$POLICY_ALLOW_COPYLEFT" == "true" ]]; then
                echo "ALLOWED"
            else
                echo "VIOLATION"
            fi
            ;;
        PERMISSIVE|COMMERCIAL)
            echo "ALLOWED"
            ;;
        UNKNOWN)
            echo "MANUAL_REVIEW"
            ;;
        *)
            echo "MANUAL_REVIEW"
            ;;
    esac
}

# Extract dependencies from requirements.txt
extract_dependencies() {
    grep -v '^[[:space:]]*#' "$REQUIREMENTS_FILE" | \
    grep -v '^[[:space:]]*$' | \
    sed 's/[>=<~!].*//' | \
    sed 's/\[[^]]*\]//' | \
    sort -u
}

# Main license checking logic
main() {
    local start_time
    start_time=$(_perf_start)

    if [[ "$SILENT_MODE" != "true" ]]; then
        log_info "Checking Python dependency licenses..."
        log_info "Requirements file: $REQUIREMENTS_FILE"
        log_info "Project license: $POLICY_PROJECT_LICENSE"
        log_info "Allow copyleft: $POLICY_ALLOW_COPYLEFT"
        echo
    fi

    # Extract dependencies first
    local dependencies
    mapfile -t dependencies < <(extract_dependencies)

    if [[ ${#dependencies[@]} -eq 0 ]]; then
        log_warn "No dependencies found in $REQUIREMENTS_FILE"
        exit 0
    fi

    # Check if pip and pip-licenses are available
    if ! command -v pip3 &> /dev/null; then
        log_error "pip3 not found. Install Python 3 and pip."
        exit 1
    fi

    # Install pip-licenses if not available (temporary install)
    if ! pip3 show pip-licenses &> /dev/null; then
        log_info "Installing pip-licenses for license extraction..."
        if ! pip3 install --user pip-licenses &> /dev/null; then
            log_error "Failed to install pip-licenses. Please install manually: pip3 install pip-licenses"
            exit 1
        fi
    fi

    # Create temporary directory for dependency analysis
    local temp_dir
    temp_dir=$(mktemp -d)
    trap "rm -rf '$temp_dir'" EXIT

    # Install dependencies to temp environment for license extraction
    local venv_path="$temp_dir/venv"
    python3 -m venv "$venv_path" &> /dev/null
    source "$venv_path/bin/activate"

    # Install dependencies
    if [[ "$SILENT_MODE" != "true" ]]; then
        log_info "Installing dependencies for license analysis..."
    fi

    pip install --quiet pip-licenses &> /dev/null
    pip install --quiet -r "$REQUIREMENTS_FILE" &> /dev/null || {
        log_error "Failed to install some dependencies. Proceeding with available packages..."
    }

    # Extract license information
    local license_data
    license_data=$(pip-licenses --format=csv --with-urls 2>/dev/null || echo "")

    # Parse results and generate report
    local violations=0
    local manual_reviews=0
    local total_deps=0

    declare -a report_lines

    # Header
    case "$OUTPUT_FORMAT" in
        json)
            echo '{'
            echo '  "policy": {'
            echo "    \"project_license\": \"$POLICY_PROJECT_LICENSE\","
            echo "    \"allow_copyleft\": $POLICY_ALLOW_COPYLEFT"
            echo '  },'
            echo '  "dependencies": ['
            ;;
        markdown)
            echo "# License Compliance Report"
            echo
            echo "**Policy Configuration:**"
            echo "- Project License: $POLICY_PROJECT_LICENSE"
            echo "- Allow Copyleft: $POLICY_ALLOW_COPYLEFT"
            echo "- Requirements File: $REQUIREMENTS_FILE"
            echo
            echo "| Package | Version | License | Category | Status |"
            echo "|---------|---------|---------|----------|--------|"
            ;;
        table)
            if [[ "$SILENT_MODE" != "true" ]]; then
                printf "%-30s %-15s %-20s %-12s %-15s\n" "PACKAGE" "VERSION" "LICENSE" "CATEGORY" "STATUS"
                printf "%s\n" "$(printf '=%.0s' {1..92})"
            fi
            ;;
    esac

    local first_json=true

    # Process each dependency
    while IFS= read -r dependency; do
        [[ -n "$dependency" ]] || continue

        total_deps=$((total_deps + 1))
        local package_name="$dependency"
        local version="N/A"
        local license="Unknown"
        local url="N/A"

        # Extract license info from pip-licenses output
        if [[ -n "$license_data" ]]; then
            local line
            line=$(echo "$license_data" | grep -i "^$package_name," || true)
            if [[ -n "$line" ]]; then
                IFS=',' read -r _ version license url <<< "$line"
                license=$(echo "$license" | sed 's/"//g' | sed 's/^[[:space:]]*//' | sed 's/[[:space:]]*$//')
                version=$(echo "$version" | sed 's/"//g')
            fi
        fi

        local category
        category=$(categorize_license "$license")

        local status
        status=$(check_compatibility "$license" "$category")

        case "$status" in
            VIOLATION)
                violations=$((violations + 1))
                ;;
            MANUAL_REVIEW)
                manual_reviews=$((manual_reviews + 1))
                ;;
        esac

        # Only output violations in silent mode
        if [[ "$SILENT_MODE" == "true" && "$status" == "ALLOWED" ]]; then
            continue
        fi

        # Format output
        case "$OUTPUT_FORMAT" in
            json)
                [[ "$first_json" == "true" ]] && first_json=false || echo ","
                echo "    {"
                echo "      \"package\": \"$package_name\","
                echo "      \"version\": \"$version\","
                echo "      \"license\": \"$license\","
                echo "      \"category\": \"$category\","
                echo "      \"status\": \"$status\""
                echo -n "    }"
                ;;
            markdown)
                echo "| $package_name | $version | $license | $category | $status |"
                ;;
            table)
                printf "%-30s %-15s %-20s %-12s %-15s\n" \
                    "$package_name" "$version" "$license" "$category" "$status"
                ;;
        esac

    done < <(printf '%s\n' "${dependencies[@]}")

    # Footer
    case "$OUTPUT_FORMAT" in
        json)
            echo
            echo '  ],'
            echo "  \"summary\": {"
            echo "    \"total_dependencies\": $total_deps,"
            echo "    \"violations\": $violations,"
            echo "    \"manual_reviews\": $manual_reviews"
            echo "  }"
            echo '}'
            ;;
        markdown)
            echo
            echo "## Summary"
            echo "- Total Dependencies: $total_deps"
            echo "- License Violations: $violations"
            echo "- Manual Reviews Required: $manual_reviews"
            ;;
        table)
            if [[ "$SILENT_MODE" != "true" ]]; then
                echo
                echo "SUMMARY:"
                echo "  Total Dependencies: $total_deps"
                echo "  License Violations: $violations"
                echo "  Manual Reviews Required: $manual_reviews"
            fi
            ;;
    esac

    deactivate 2>/dev/null || true

    # Record performance metrics
    local elapsed_ms
    elapsed_ms=$(_perf_elapsed_ms "$start_time")
    _perf_record "license_check" "$elapsed_ms" "compliance-officer"

    # Exit with appropriate code
    if [[ $violations -gt 0 ]]; then
        if [[ "$SILENT_MODE" != "true" ]]; then
            log_error "Found $violations license violations!"
        fi
        exit 1
    elif [[ $manual_reviews -gt 0 ]]; then
        if [[ "$SILENT_MODE" != "true" ]]; then
            log_warn "Found $manual_reviews dependencies requiring manual license review"
        fi
        exit 2
    else
        if [[ "$SILENT_MODE" != "true" ]]; then
            log_info "All dependency licenses are compliant"
        fi
        exit 0
    fi
}

# Run main function
main "$@"