#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS VERIFY: Pre-Commit Quality Gate
# Runs: Health -> Lint -> Unit Tests -> Certify -> Doc Check
set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/bin/lib/ui.sh" ]]; then
  # shellcheck source=bin/lib/ui.sh
  source "${EUXIS_HOME}/bin/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-verify — Pre-commit quality gate

Usage:
  euxis-verify

Runs health, lint, unit tests, certification, and doc checks.

Options:
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

EUXIS_HOME="${HOME}/.euxis"
EUXIS_BIN="${EUXIS_HOME}/bin"
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:${HOME}/bin:${EUXIS_BIN}:${PATH}"

echo "INITIATING PRE-FLIGHT SEQUENCE..."
FAILURES=0

# 1. System Health
echo -n "   [1/5] Checking System Health...   "
if "${EUXIS_BIN}/euxis-health" --silent 2>/dev/null; then
    echo "PASS"
else
    echo "FAIL"
    echo "   Run 'euxis-health' to diagnose."
    FAILURES=$((FAILURES + 1))
fi

# 2. Static Analysis (Registry & Headers)
echo -n "   [2/5] Linting Fleet...            "
if OUT=$("${EUXIS_BIN}/euxis-lint" 2>&1); then
    echo "PASS"
else
    echo "FAIL"
    echo "$OUT"
    FAILURES=$((FAILURES + 1))
fi

# 3. Infrastructure Tests (Bash/Python unit tests)
echo -n "   [3/5] Running Unit Tests...       "
if "${EUXIS_BIN}/euxis-test-infra" >/dev/null 2>&1; then
    echo "PASS"
else
    echo "FAIL"
    echo "   Run 'euxis-test-infra' to debug."
    FAILURES=$((FAILURES + 1))
fi

# 4. Agent Certification (golden dataset + semantic eval)
echo -n "   [4/5] Certifying Agents...        "
"${EUXIS_BIN}/euxis-certify" >/dev/null 2>&1 && CERTIFY_RC=0 || CERTIFY_RC=$?
if [[ $CERTIFY_RC -eq 0 ]]; then
    echo "PASS"
else
    echo "FAIL"
    echo "   Run 'euxis-certify' to see which agent failed."
    FAILURES=$((FAILURES + 1))
fi

# 5. Documentation Drift
echo -n "   [5/5] Checking Documentation...   "
NEWEST_PROMPT=$(find "${EUXIS_HOME}/prompts" -name "*.txt" -print0 2>/dev/null | xargs -0 ls -t 2>/dev/null | head -n 1)
DOC_FILE="${EUXIS_HOME}/docs/user-guide.md"

if [[ ! -f "$DOC_FILE" ]]; then
    echo "MISSING (docs/user-guide.md not found)"
elif [[ -n "$NEWEST_PROMPT" ]] && [[ "$NEWEST_PROMPT" -nt "$DOC_FILE" ]]; then
    echo "DRIFT DETECTED (warning)"
    echo "   Prompts are newer than docs/user-guide.md."
else
    echo "PASS"
fi

echo "---------------------------------------------------"
if [[ "$FAILURES" -gt 0 ]]; then
    echo "BLOCKED: ${FAILURES} check(s) failed. Fix issues before committing."
    exit 1
else
    echo "ALL SYSTEMS GREEN. Ready to commit."
    exit 0
fi
