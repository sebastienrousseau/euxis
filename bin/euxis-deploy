#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS DEPLOY: Launch the Enterprise Fleet

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-$HOME/.euxis}"
if [[ -f "${EUXIS_HOME}/core/lib/ui.sh" ]]; then
  # shellcheck source=core/lib/ui.sh
  source "${EUXIS_HOME}/core/lib/ui.sh"
  ui_auto_header
fi


usage() {
    cat <<'EOF'
euxis-deploy — Launch the Euxis Enterprise Fleet

Usage:
  euxis-deploy [OPTIONS]

Starts the Euxis Enterprise stack using Docker Compose.

Options:
  -h, --help    Show this help text

Components:
  euxis-fleet   Agent orchestration service
  cortex-db     Vector memory database (port 8000)

Examples:
  euxis-deploy              # Start the fleet
  euxis-deploy --help       # Show this help

Related:
  docker compose -f ~/.euxis/deploy/docker-compose.yml logs -f   # View logs
  docker compose -f ~/.euxis/deploy/docker-compose.yml down      # Stop fleet
EOF
}

case "${1:-}" in
    -h|--help)
        usage
        exit 0
        ;;
esac

cd ~/.euxis/deploy
docker compose up -d
echo ""
echo "Euxis Enterprise is now running."
echo "   Agents: euxis-fleet"
echo "   Memory: cortex-db (port 8000)"
echo ""
echo "   Logs:   docker compose -f ~/.euxis/deploy/docker-compose.yml logs -f"
echo "   Stop:   docker compose -f ~/.euxis/deploy/docker-compose.yml down"
