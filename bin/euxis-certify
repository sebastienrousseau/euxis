#!/bin/bash
# EUXIS CERTIFY: The Final Toll Gate
# Runs all 4 gates in sequence. All must pass for certification.

set -euo pipefail

EUXIS_HOME="$HOME/.euxis"
BIN_DIR="$EUXIS_HOME/bin"
SEMANTIC_TIMEOUT="${EUXIS_SEMANTIC_TIMEOUT:-60}"

run_with_timeout() {
    local timeout="$1"
    shift
    "$@" &
    local pid=$!
    local elapsed=0

    while kill -0 "$pid" 2>/dev/null; do
        if (( elapsed >= timeout )); then
            kill "$pid" 2>/dev/null || true
            wait "$pid" 2>/dev/null || true
            return 124
        fi
        sleep 1
        elapsed=$((elapsed + 1))
    done

    wait "$pid"
}

echo "=================================================="
echo "  EUXIS CERTIFICATION PIPELINE"
echo "=================================================="

# GATE 1 & 2: Static Analysis (Structural Integrity + Protocol Compliance)
echo ""
echo "[GATE 1+2] Static Analysis (Lint)..."
echo "--------------------------------------------------"
"$BIN_DIR/euxis-lint"
if [ $? -ne 0 ]; then
    echo ""
    echo "CERTIFICATION FAILED at Gate 1+2 (Static Analysis)."
    exit 1
fi

# GATE 3: Infrastructure Code Coverage
echo ""
echo "[GATE 3] Infrastructure Tests..."
echo "--------------------------------------------------"
"$BIN_DIR/euxis-test-infra"
if [ $? -ne 0 ]; then
    echo ""
    echo "CERTIFICATION FAILED at Gate 3 (Infrastructure)."
    exit 1
fi

# GATE 4: Semantic Verification (Sample — requires live AI provider)
echo ""
echo "[GATE 4] Semantic Verification..."
echo "--------------------------------------------------"
GOLDEN_DATASET="$EUXIS_HOME/tests/golden/golden_dataset.json"
if [[ -f "$GOLDEN_DATASET" ]]; then
    echo "  Golden dataset found. Running sample eval..."

    # Test Architect output format
    resp_file=$(mktemp 2>/dev/null || echo "/tmp/euxis_semantic_resp.$$")
    if run_with_timeout "${SEMANTIC_TIMEOUT}" "$BIN_DIR/euxis.sh" architect "Analyze this structure: a single Python file with no tests." claude > "${resp_file}" 2>/dev/null; then
        RESP=$(cat "${resp_file}")
    else
        RESP=""
        echo "  FAIL: Architect timed out after ${SEMANTIC_TIMEOUT}s."
    fi
    rm -f "${resp_file}"
    if [[ -n "$RESP" ]]; then
        echo "  PASS: Architect produced output."
    else
        echo "  FAIL: Architect returned empty output."
        echo ""
        echo "CERTIFICATION FAILED at Gate 4 (Semantic)."
        exit 1
    fi
else
    echo "  Golden dataset not found at $GOLDEN_DATASET"
    echo "  Skipping semantic verification (Gate 4 is advisory)."
fi

echo ""
echo "=================================================="
echo "  EUXIS IS CERTIFIED."
echo "  All toll gates passed."
echo "=================================================="
exit 0
