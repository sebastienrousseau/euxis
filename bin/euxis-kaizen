#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS KAIZEN: Continuous Self-Improvement Loop
# "Better every day."

set -euo pipefail

EUXIS_HOME="$HOME/.euxis"
BIN_DIR="$EUXIS_HOME/bin"
DATE=$(date +%Y-%m-%d)

# Guard against unbounded recursion
EUXIS_DEPTH="${EUXIS_DEPTH:-0}"
export EUXIS_DEPTH=$((EUXIS_DEPTH + 1))
if [[ "$EUXIS_DEPTH" -gt 3 ]]; then
    echo "ERROR: Recursion depth limit reached (EUXIS_DEPTH=$EUXIS_DEPTH). Aborting."
    exit 1
fi

echo "STARTING KAIZEN SESSION: $DATE"
echo "=================================================="

# STEP 1: THE TOLL GATES (Sanity Check)
echo ""
echo "[GATE 1] Running Certification Suite..."
echo "--------------------------------------------------"
"$BIN_DIR/euxis-certify"
if [ $? -ne 0 ]; then
    echo ""
    echo "CRITICAL: Euxis failed certification. Fix the base system before optimizing."
    exit 1
fi
echo ""
echo "System is stable. Proceeding to optimization."

# STEP 2: THE SELF-REFLECTION (Pre-computed Audit Data → Architect Analysis)
echo ""
echo "[GATE 2] Architectural Self-Reflection..."
echo "--------------------------------------------------"

# Pre-compute audit facts so the architect analyzes real data, not hallucinations
AGENT_COUNT_CORE=$(ls "$EUXIS_HOME/prompts/core/"*.txt 2>/dev/null | wc -l | tr -d ' ')
AGENT_COUNT_FLEET=$(ls "$EUXIS_HOME/prompts/fleet/"*.txt 2>/dev/null | wc -l | tr -d ' ')
AGENT_COUNT_TOTAL=$((AGENT_COUNT_CORE + AGENT_COUNT_FLEET))

# Registry counts from orchestrator
REGISTRY_CORE_HEADER=$(grep -o 'Core Infrastructure ([0-9]*)' "$EUXIS_HOME/prompts/core/orchestrator.txt" 2>/dev/null | grep -o '[0-9]*' || echo 0)
REGISTRY_FLEET_HEADER=$(grep -o 'Fleet Specialists ([0-9]*)' "$EUXIS_HOME/prompts/core/orchestrator.txt" 2>/dev/null | grep -o '[0-9]*' || echo 0)
REGISTRY_TOTAL=$((REGISTRY_CORE_HEADER + REGISTRY_FLEET_HEADER))

# Weak language scan (excluding _common.txt examples and MoSCoW terminology)
WEAK_LANG=$(grep -rn -i '\bshould\b\|\bensure\b\|\btry to\b\|\bplease\b' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" "$EUXIS_HOME/prompts/protocols/_protocol.txt" 2>/dev/null \
    | grep -v '_common.txt' \
    | grep -v 'MoSCoW' \
    | grep -v 'Must Have, Should Have' \
    | grep -v 'MUST | SHOULD | COULD' \
    || echo "NONE FOUND")

# Output format check
AGENTS_WITH_OUTPUT=$(grep -rl '## Output Format' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" 2>/dev/null | wc -l | tr -d ' ')

# Inbound escalation check
AGENTS_WITH_INBOUND=$(grep -rl '## Inbound Escalations' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" 2>/dev/null | wc -l | tr -d ' ')

# Handoff enforcement check
HANDOFF_IN_COMMON=$(grep -c 'EUXIS_HANDOFF' "$EUXIS_HOME/prompts/protocols/_common.txt" 2>/dev/null || echo 0)

# Dispatch protocol check
AGENTS_WITH_DISPATCH=$(grep -rl '## Dispatch Protocol' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" 2>/dev/null | wc -l | tr -d ' ')

# Version consistency
VERSIONS=$(grep -h '^version:' "$EUXIS_HOME/prompts/core/"*.txt "$EUXIS_HOME/prompts/fleet/"*.txt 2>/dev/null | sort -u | tr -d '"' | sed 's/version: //')
VERSION_COUNT=$(echo "$VERSIONS" | wc -l | tr -d ' ')

# Section consistency check
AGENTS_WITH_ESCALATION=$(grep -rl '## Escalation Protocol' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" 2>/dev/null | wc -l | tr -d ' ')
AGENTS_WITH_ERROR=$(grep -rl '## Error Handling' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" 2>/dev/null | wc -l | tr -d ' ')

AUDIT_DATA="PRE-COMPUTED FLEET AUDIT DATA (verified by automated scan — do NOT re-run these checks):

AGENT COUNTS:
- Core agents (filesystem): $AGENT_COUNT_CORE
- Fleet agents (filesystem): $AGENT_COUNT_FLEET
- Total agents (filesystem): $AGENT_COUNT_TOTAL
- Orchestrator registry: $REGISTRY_CORE_HEADER core + $REGISTRY_FLEET_HEADER fleet = $REGISTRY_TOTAL total
- COUNT MATCH: filesystem ($AGENT_COUNT_TOTAL) vs registry ($REGISTRY_TOTAL) — $([ \"$AGENT_COUNT_TOTAL\" = \"$REGISTRY_TOTAL\" ] && echo 'MATCH' || echo 'MISMATCH')

VERSION CONSISTENCY:
- Unique versions found: $VERSION_COUNT
- Version(s): $VERSIONS

WEAK LANGUAGE SCAN (core + fleet + protocol, excluding _common.txt examples and MoSCoW terminology):
$WEAK_LANG

STRUCTURAL COMPLETENESS:
- Agents with '## Output Format': $AGENTS_WITH_OUTPUT / $AGENT_COUNT_TOTAL
- Agents with '## Escalation Protocol': $AGENTS_WITH_ESCALATION / $AGENT_COUNT_TOTAL
- Agents with '## Error Handling': $AGENTS_WITH_ERROR / $AGENT_COUNT_TOTAL
- Agents with '## Inbound Escalations': $AGENTS_WITH_INBOUND (only agents receiving escalations need this)
- Agents with '## Dispatch Protocol': $AGENTS_WITH_DISPATCH (only coordinating agents need this)
- EUXIS_HANDOFF enforced in _common.txt: $HANDOFF_IN_COMMON references"

"$BIN_DIR/euxis.sh" architect "META-AUDIT: Analyze the following pre-computed audit data for the Euxis agent fleet.

$AUDIT_DATA

IMPORTANT: The data above is from automated scans. Do NOT simulate running bash commands. Do NOT fabricate grep results. Analyze ONLY the data provided above.

CRITERIA:
1. Are agent counts consistent between filesystem and registry? The registry separates core and fleet agents. Compare TOTAL filesystem count against TOTAL registry count (core + fleet). If they match, this is PASS.
2. Is weak language present (NONE FOUND = perfect)?
3. Are all mandatory structural sections complete? Mandatory sections are: Output Format, Escalation Protocol, Error Handling. If all three are N/N (denominator equals total agents), this is PASS. Inbound Escalations and Dispatch Protocol are CONDITIONAL — not all agents need them.
4. Is version consistency maintained?

OUTPUT:
- Assess each criterion as PASS or FAIL with evidence from the data above.
- Rate overall fleet consistency 0-100. Scoring rules: 4 PASS = 100. 3 PASS + 1 FAIL = 85. 2 PASS = 70. Fewer = 50.
- List 3 specific enhancement suggestions (not fixes) if all criteria pass." claude
if [ $? -ne 0 ]; then
    echo "WARNING: Architect meta-audit failed (non-zero exit). Continuing."
fi

# STEP 3: THE DOCUMENTATION SYNC (Tech Writer)
echo ""
echo "[GATE 3] Documentation Sync..."
echo "--------------------------------------------------"
"$BIN_DIR/euxis.sh" writer "Read ~/.euxis/prompts/ and verify the ROOT README.md in ~/.euxis/.
VERIFY:
1. Every agent is listed in the README.
2. The version number in the README matches the Protocol (v0.0.7).
3. The 'Installation' instructions are accurate.
4. All CLI tools are documented.

OUTPUT:
- List any gaps found.
- If no gaps, confirm README is in sync." claude
if [ $? -ne 0 ]; then
    echo "WARNING: Tech-writer documentation sync failed (non-zero exit). Continuing."
fi

# STEP 4: THE STRATEGIC UPGRADE (Orchestrator)
echo ""
echo "[GATE 4] The Upgrade Plan..."
echo "--------------------------------------------------"
"$BIN_DIR/euxis.sh" orchestrator "Based on the current state of ~/.euxis/prompts/, propose a 'Next Version Patch'.
TASK:
1. Identify the top 3 marginal improvements across the fleet.
2. If no critical fixes are needed, propose a new capability (e.g., a new agent, script, or protocol enhancement).
3. Format as an Orchestration Plan with phases, agents, and success criteria." claude
if [ $? -ne 0 ]; then
    echo "WARNING: Orchestrator upgrade plan failed (non-zero exit). Continuing."
fi

echo ""
echo "=================================================="
echo "KAIZEN COMPLETE. Review the suggestions above."
echo "=================================================="
