#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# Comprehensive shell script linting and formatting tool
# Enforces the same standards as CI and pre-commit hooks

set -euo pipefail

# Configuration
SCRIPT_NAME="euxis-shell-lint"
EUXIS_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

# Default settings
DEFAULT_SHELLCHECK_OPTS="-S error -o all"
DEFAULT_SHFMT_OPTS="-i 2 -bn -ci -sr"
FIX_MODE=false
QUIET_MODE=false
STRICT_MODE=true

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

log_info() {
    [[ "${QUIET_MODE}" == true ]] && return
    echo -e "${BLUE}[${SCRIPT_NAME}]${NC} $*"
}

log_success() {
    [[ "${QUIET_MODE}" == true ]] && return
    echo -e "${GREEN}[${SCRIPT_NAME}]${NC} $*"
}

log_warning() {
    echo -e "${YELLOW}[${SCRIPT_NAME}]${NC} $*" >&2
}

log_error() {
    echo -e "${RED}[${SCRIPT_NAME}]${NC} $*" >&2
}

# Check required tools
check_dependencies() {
    local missing_tools=()

    if ! command -v shellcheck &>/dev/null; then
        missing_tools+=("shellcheck")
    fi

    if ! command -v shfmt &>/dev/null; then
        missing_tools+=("shfmt")
    fi

    if [[ ${#missing_tools[@]} -gt 0 ]]; then
        log_error "Missing required tools: ${missing_tools[*]}"
        log_error "Install with: brew install ${missing_tools[*]} (macOS)"
        log_error "         or: apt-get install ${missing_tools[*]} (Ubuntu)"
        return 1
    fi

    return 0
}

# Discover shell scripts
find_shell_scripts() {
    local search_paths=("${@:-${EUXIS_ROOT}}")
    local script_list=()

    for path in "${search_paths[@]}"; do
        if [[ -f "${path}" ]]; then
            # Single file provided
            if [[ "${path}" =~ \.sh$ ]] || head -1 "${path}" 2>/dev/null | grep -q '^#!/.*\(bash\|sh\)'; then
                script_list+=("${path}")
            fi
        elif [[ -d "${path}" ]]; then
            # Directory provided, search recursively
            while IFS= read -r -d '' file; do
                if [[ "${file}" =~ \.sh$ ]] || head -1 "${file}" 2>/dev/null | grep -q '^#!/.*\(bash\|sh\)'; then
                    script_list+=("${file}")
                fi
            done < <(find "${path}" -type f -not -path "*/.venv/*" -not -path "*/venv/*" -not -path "*/build/*" -not -path "*/dist/*" -print0)
        fi
    done

    printf '%s\n' "${script_list[@]}" | sort | uniq
}

# Run ShellCheck analysis
run_shellcheck() {
    local file="$1"
    local opts="${2:-${DEFAULT_SHELLCHECK_OPTS}}"

    log_info "ShellCheck: $(basename "${file}")"

    if shellcheck ${opts} "${file}"; then
        return 0
    else
        log_error "ShellCheck failed: ${file}"
        return 1
    fi
}

# Check and optionally fix formatting
check_format() {
    local file="$1"
    local opts="${2:-${DEFAULT_SHFMT_OPTS}}"

    log_info "Format check: $(basename "${file}")"

    if [[ "${FIX_MODE}" == true ]]; then
        if shfmt ${opts} -w "${file}"; then
            log_success "Formatted: ${file}"
            return 0
        else
            log_error "Format fix failed: ${file}"
            return 1
        fi
    else
        if shfmt ${opts} -d "${file}" >/dev/null; then
            return 0
        else
            log_error "Format violation: ${file}"
            echo "  Run: shfmt ${opts} -w ${file}"
            return 1
        fi
    fi
}

# Check strict error handling
check_error_handling() {
    local file="$1"

    log_info "Error handling: $(basename "${file}")"

    # Skip library files
    if [[ "${file}" =~ /lib/ ]]; then
        if ! grep -q "set -euo pipefail\|set -e" "${file}"; then
            log_warning "Library file lacks error handling: ${file} (may be acceptable)"
        fi
        return 0
    fi

    if ! grep -q "set -euo pipefail" "${file}"; then
        log_error "Missing 'set -euo pipefail': ${file}"
        if [[ "${FIX_MODE}" == true ]]; then
            # Insert set -euo pipefail after shebang and copyright
            local temp_file="${file}.tmp"
            awk '
                NR==1 && /^#!/ { print; next }
                NR<=5 && /^#.*[Cc]opyright/ { print; next }
                !inserted && NF>0 && !/^#/ {
                    print "set -euo pipefail"
                    print ""
                    inserted=1
                }
                { print }
            ' "${file}" > "${temp_file}"
            mv "${temp_file}" "${file}"
            log_success "Added error handling: ${file}"
        fi
        return 1
    fi

    return 0
}

# Run security checks
check_security() {
    local file="$1"

    log_info "Security check: $(basename "${file}")"

    local security_issues=0

    # Check for dangerous patterns
    if grep -n "eval\s*\$" "${file}"; then
        log_error "Dangerous eval usage in ${file}"
        ((security_issues++)) || true
    fi

    if grep -n "curl.*|.*sh\|wget.*|.*sh" "${file}"; then
        log_error "Dangerous pipe-to-shell pattern in ${file}"
        ((security_issues++)) || true
    fi

    # Check for unquoted variables in dangerous contexts
    if grep -n '\$[A-Za-z_][A-Za-z0-9_]*[^"'"'"']' "${file}" | grep -v "set \-" | head -3 >/dev/null; then
        log_warning "Potential unquoted variables in ${file} (review manually)"
    fi

    return ${security_issues}
}

# Process a single file
process_file() {
    local file="$1"
    local failed_checks=0

    log_info "Processing: ${file}"

    # ShellCheck analysis
    if ! run_shellcheck "${file}"; then
        ((failed_checks++)) || true
    fi

    # Format checking/fixing
    if ! check_format "${file}"; then
        ((failed_checks++)) || true
    fi

    # Error handling check
    if [[ "${STRICT_MODE}" == true ]]; then
        if ! check_error_handling "${file}"; then
            ((failed_checks++)) || true
        fi

        if ! check_security "${file}"; then
            ((failed_checks++)) || true
        fi
    fi

    return ${failed_checks}
}

# Print usage information
print_usage() {
    cat << EOF
Usage: ${SCRIPT_NAME} [OPTIONS] [FILES|DIRECTORIES...]

Comprehensive shell script linting and formatting tool.

OPTIONS:
    --fix           Fix formatting and simple issues automatically
    --quiet         Reduce output verbosity
    --no-strict     Skip strict error handling and security checks
    --shellcheck-opts OPTS
                    Custom ShellCheck options (default: ${DEFAULT_SHELLCHECK_OPTS})
    --shfmt-opts OPTS
                    Custom shfmt options (default: ${DEFAULT_SHFMT_OPTS})
    --help          Show this help message

EXAMPLES:
    ${SCRIPT_NAME}                          # Lint all scripts in repository
    ${SCRIPT_NAME} --fix bin/               # Fix formatting in bin/ directory
    ${SCRIPT_NAME} script.sh                # Lint single file
    ${SCRIPT_NAME} --quiet --no-strict *.sh # Quick check without strict mode

CHECKS PERFORMED:
    - ShellCheck analysis (all warnings as errors)
    - Format verification/fixing with shfmt
    - Strict error handling verification (set -euo pipefail)
    - Security pattern analysis
    - Executable permissions verification
EOF
}

# Main execution
main() {
    local target_paths=()
    local shellcheck_opts="${DEFAULT_SHELLCHECK_OPTS}"
    local shfmt_opts="${DEFAULT_SHFMT_OPTS}"

    # Parse arguments
    while [[ $# -gt 0 ]]; do
        case $1 in
            --fix)
                FIX_MODE=true
                shift
                ;;
            --quiet)
                QUIET_MODE=true
                shift
                ;;
            --no-strict)
                STRICT_MODE=false
                shift
                ;;
            --shellcheck-opts)
                shellcheck_opts="$2"
                shift 2
                ;;
            --shfmt-opts)
                shfmt_opts="$2"
                shift 2
                ;;
            --help)
                print_usage
                exit 0
                ;;
            --*)
                log_error "Unknown option: $1"
                print_usage
                exit 1
                ;;
            *)
                target_paths+=("$1")
                shift
                ;;
        esac
    done

    # Use repository root if no paths specified
    if [[ ${#target_paths[@]} -eq 0 ]]; then
        target_paths=("${EUXIS_ROOT}")
    fi

    DEFAULT_SHELLCHECK_OPTS="${shellcheck_opts}"
    DEFAULT_SHFMT_OPTS="${shfmt_opts}"

    log_info "Starting shell script linting"
    log_info "Fix mode: ${FIX_MODE}, Strict mode: ${STRICT_MODE}"

    # Check dependencies
    if ! check_dependencies; then
        exit 1
    fi

    # Find and process shell scripts
    local all_scripts
    all_scripts=($(find_shell_scripts "${target_paths[@]}"))

    if [[ ${#all_scripts[@]} -eq 0 ]]; then
        log_warning "No shell scripts found in specified paths"
        exit 0
    fi

    log_info "Found ${#all_scripts[@]} shell scripts"

    local total_failures=0
    local processed_files=0

    for script in "${all_scripts[@]}"; do
        ((processed_files++)) || true
        if ! process_file "${script}"; then
            ((total_failures++)) || true
        fi
    done

    # Summary
    echo ""
    log_info "=========================================="
    log_info "SHELL LINTING SUMMARY"
    log_info "=========================================="
    log_info "Processed files: ${processed_files}"
    log_info "Failed checks: ${total_failures}"

    if [[ ${total_failures} -eq 0 ]]; then
        log_success "All shell scripts pass quality checks"
        exit 0
    else
        log_error "${total_failures} files have quality issues"
        if [[ "${FIX_MODE}" == false ]]; then
            log_info "Run with --fix to automatically resolve formatting issues"
        fi
        exit 1
    fi
}

# Handle command line
if [[ "${BASH_SOURCE[0]}" == "${0}" ]]; then
    main "$@"
fi