#!/usr/bin/env python3
"""
Euxis Cortex — Cross-Platform Semantic Memory (Vector + Graph Hybrid)

Usage:
    euxis-cortex remember "fact to store" [source] [--type episodic|semantic|procedural]
    euxis-cortex recall   "query keywords" [n_results] [--type episodic|semantic|procedural] [--hybrid]
    euxis-cortex relate   "memory query" <entity> --relation <type>
    euxis-cortex stats
    euxis-cortex forget   "exact document text"

Memory Types:
    episodic    — Specific events, outcomes, timestamps (default)
    semantic    — General facts, rules, relationships
    procedural  — Reusable workflows, patterns, contraindications

Graph Integration (v6.0):
    --hybrid    — Combine vector similarity with graph proximity for recall
    relate      — Link a memory to a graph entity via euxis-graph

Requires: pip install chromadb sentence-transformers
Optional: pip install networkx (for graph hybrid recall)

Works on: macOS, Linux, WSL (Ubuntu/Debian)
- macOS:       pip install chromadb sentence-transformers
- Linux/WSL:   sudo apt-get install -y build-essential python3-dev && \
               pip install chromadb sentence-transformers
"""

import sys
import os
import platform
import hashlib
import subprocess
import json

# ============================================================================
# Cross-Platform Configuration
# ============================================================================

# Store in standard user location valid on Mac/Linux/WSL
DB_PATH = os.path.expanduser("~/.euxis/data/cortex/db")
OS_INFO = platform.system()  # Darwin, Linux, or Windows (WSL reports Linux)

# Detect WSL specifically
IS_WSL = False
if OS_INFO == "Linux":
    try:
        with open("/proc/version", "r") as f:
            if "microsoft" in f.read().lower():
                IS_WSL = True
    except (FileNotFoundError, PermissionError):
        pass

PLATFORM_LABEL = "WSL" if IS_WSL else OS_INFO


# ============================================================================
# Auto-activate project venv (ensures chromadb is importable)
# ============================================================================

def _activate_venv():
    """Add project venv site-packages to sys.path if not already active."""
    if os.environ.get("VIRTUAL_ENV"):
        return  # Already in a venv
    euxis_home = os.path.expanduser("~/.euxis")
    for venv_dir in (".venv", "venv", "env"):
        site_pkgs = os.path.join(euxis_home, venv_dir, "lib")
        if os.path.isdir(site_pkgs):
            # Find the python3.x directory inside lib/
            for entry in sorted(os.listdir(site_pkgs)):
                if not entry.startswith("python"):
                    continue
                sp = os.path.join(site_pkgs, entry, "site-packages")
                if os.path.isdir(sp) and sp not in sys.path:
                    sys.path.insert(0, sp)
                    return

_activate_venv()

# ============================================================================
# Lazy Imports (avoid startup lag for --help / no-args)
# ============================================================================

def load_chromadb():
    """Import heavy libraries only when needed."""
    try:
        import chromadb
        from chromadb.utils import embedding_functions
        return chromadb, embedding_functions
    except ImportError:
        print("Critical: chromadb not installed.")
        print("")
        if OS_INFO == "Darwin":
            print("  Install (macOS):")
            print("    pip install chromadb sentence-transformers")
        else:
            print("  Install (Linux/WSL):")
            print("    sudo apt-get install -y build-essential python3-dev")
            print("    pip install chromadb sentence-transformers")
        sys.exit(1)


def get_collection():
    """Initialize vector store with sentence-transformer embeddings."""
    chromadb, embedding_functions = load_chromadb()

    # Use HTTP client when running inside Docker (CHROMA_HOST set),
    # otherwise use local persistent storage
    chroma_host = os.getenv("CHROMA_HOST")
    if chroma_host and chroma_host != "localhost":
        client = chromadb.HttpClient(host=chroma_host, port=8000)
    else:
        os.makedirs(DB_PATH, exist_ok=True)
        client = chromadb.PersistentClient(path=DB_PATH)

    # all-MiniLM-L6-v2: small, fast, CPU-friendly (22M params, ~80MB)
    ef = embedding_functions.SentenceTransformerEmbeddingFunction(
        model_name="all-MiniLM-L6-v2"
    )
    return client.get_or_create_collection(
        name="euxis_memory",
        embedding_function=ef
    )


# ============================================================================
# Commands
# ============================================================================

VALID_MEMORY_TYPES = {"episodic", "semantic", "procedural"}


def cmd_remember(text, source="system", memory_type="episodic"):
    """Store a fact in the Cortex with metadata and memory type."""
    if memory_type not in VALID_MEMORY_TYPES:
        print(f"Error: Invalid memory type '{memory_type}'. Must be one of: {', '.join(sorted(VALID_MEMORY_TYPES))}")
        sys.exit(1)

    collection = get_collection()

    # Deterministic ID from content + source (prevents exact duplicates)
    doc_id = hashlib.sha256((text + source).encode()).hexdigest()[:16]

    print(f"Cortex ({PLATFORM_LABEL}): Storing {memory_type} memory...")
    collection.add(
        documents=[text],
        metadatas=[{"source": source, "os": PLATFORM_LABEL, "type": memory_type}],
        ids=[doc_id]
    )
    print(f"  Saved. (source={source}, type={memory_type}, id={doc_id[:8]}...)")


def cmd_recall(query, n_results=3, memory_type=None):
    """Semantic search against stored memories, optionally filtered by type."""
    collection = get_collection()

    type_label = f" ({memory_type})" if memory_type else ""
    print(f"Cortex ({PLATFORM_LABEL}): Recalling{type_label}...")

    query_kwargs = {"query_texts": [query], "n_results": n_results}
    if memory_type:
        if memory_type not in VALID_MEMORY_TYPES:
            print(f"Error: Invalid memory type '{memory_type}'. Must be one of: {', '.join(sorted(VALID_MEMORY_TYPES))}")
            sys.exit(1)
        query_kwargs["where"] = {"type": memory_type}

    results = collection.query(**query_kwargs)

    if not results["documents"][0]:
        print("  No relevant memories found.")
        return

    for i, doc in enumerate(results["documents"][0]):
        meta = results["metadatas"][0][i]
        dist = results["distances"][0][i] if "distances" in results else None
        source = meta.get("source", "unknown")
        origin_os = meta.get("os", "?")
        mem_type = meta.get("type", "unknown")
        dist_str = f" (dist={dist:.3f})" if dist is not None else ""
        print(f"  [{source}@{origin_os}|{mem_type}]{dist_str} {doc}")


def cmd_stats():
    """Show Cortex database statistics."""
    collection = get_collection()
    count = collection.count()
    db_size = sum(
        os.path.getsize(os.path.join(dp, f))
        for dp, _, filenames in os.walk(DB_PATH)
        for f in filenames
    )
    print(f"Cortex Stats ({PLATFORM_LABEL}):")
    print(f"  Memories:  {count}")
    print(f"  DB size:   {db_size / 1024:.1f} KB")
    print(f"  DB path:   {DB_PATH}")
    print(f"  Platform:  {PLATFORM_LABEL} ({platform.platform()})")


def cmd_relate(memory_query, entity, relation):
    """Link a memory to a graph entity via euxis-graph."""
    VALID_RELATIONS = {"related_to", "produced_by", "depends_on", "contradicts", "references", "part_of"}
    if relation not in VALID_RELATIONS:
        print(f"Error: Invalid relation '{relation}'. Must be one of: {', '.join(sorted(VALID_RELATIONS))}")
        sys.exit(1)

    # Find the memory via vector search
    collection = get_collection()
    results = collection.query(query_texts=[memory_query], n_results=1)
    if not results["documents"][0]:
        print(f"  No memory found matching: {memory_query}")
        return

    memory_text = results["documents"][0][0]
    memory_id = results["ids"][0][0]
    memory_node = f"memory-{memory_id[:8]}"

    # Create memory node in graph
    euxis_graph = os.path.expanduser("~/.euxis/bin/euxis-graph")
    if not os.path.isfile(euxis_graph):
        print("Error: euxis-graph not found. Graph integration requires bin/euxis-graph.")
        sys.exit(1)

    # Add memory as graph node
    meta = json.dumps({"text": memory_text[:100], "full_id": memory_id})
    subprocess.run(
        [euxis_graph, "add-entity", memory_node, "--type", "memory", "--metadata", meta],
        capture_output=True, text=True
    )

    # Add edge from memory to entity
    result = subprocess.run(
        [euxis_graph, "add-edge", memory_node, entity, "--relation", relation],
        capture_output=True, text=True
    )

    if result.returncode == 0:
        print(f"  Linked memory '{memory_query[:40]}...' -> '{entity}' ({relation})")
    else:
        print(f"  Error creating edge: {result.stderr.strip()}")


def cmd_hybrid_recall(query, n_results=3, memory_type=None):
    """Hybrid recall combining vector similarity with graph proximity."""
    # Step 1: Vector search
    collection = get_collection()
    query_kwargs = {"query_texts": [query], "n_results": n_results}
    if memory_type:
        if memory_type not in VALID_MEMORY_TYPES:
            print(f"Error: Invalid memory type '{memory_type}'.")
            sys.exit(1)
        query_kwargs["where"] = {"type": memory_type}

    results = collection.query(**query_kwargs)
    vector_results = []
    if results["documents"][0]:
        for i, doc in enumerate(results["documents"][0]):
            meta = results["metadatas"][0][i]
            dist = results["distances"][0][i] if "distances" in results else 1.0
            vector_results.append({
                "doc": doc,
                "meta": meta,
                "vector_score": max(0, 1 - dist),  # Convert distance to similarity
                "source": "vector"
            })

    # Step 2: Graph neighborhood expansion
    graph_results = []
    euxis_graph = os.path.expanduser("~/.euxis/bin/euxis-graph")
    if os.path.isfile(euxis_graph):
        # Search graph for entities matching the query
        result = subprocess.run(
            [euxis_graph, "query", query],
            capture_output=True, text=True
        )
        if result.returncode == 0:
            try:
                matches = json.loads(result.stdout)
                for match in matches.get("matches", []):
                    entity_name = match.get("name", "")
                    # Get neighbors of matched entities
                    nb_result = subprocess.run(
                        [euxis_graph, "neighbors", entity_name, "--depth", "2"],
                        capture_output=True, text=True
                    )
                    if nb_result.returncode == 0:
                        nb_data = json.loads(nb_result.stdout)
                        for neighbor in nb_data.get("neighbors", []):
                            if neighbor.get("type") == "memory":
                                graph_results.append({
                                    "entity": neighbor.get("name", ""),
                                    "distance": neighbor.get("distance", 1),
                                    "graph_score": 1.0 / (1 + neighbor.get("distance", 1)),
                                    "source": "graph"
                                })
            except (json.JSONDecodeError, KeyError):
                pass

    # Step 3: Output results
    alpha = 0.7  # vector weight
    print(f"Cortex ({PLATFORM_LABEL}): Hybrid recall (alpha={alpha})...")

    if not vector_results and not graph_results:
        print("  No relevant memories found.")
        return

    # Print vector results
    for r in vector_results:
        score = r["vector_score"] * alpha
        meta = r["meta"]
        mem_type = meta.get("type", "unknown")
        source = meta.get("source", "unknown")
        print(f"  [VECTOR {score:.3f}] [{source}|{mem_type}] {r['doc']}")

    # Print graph results
    for r in graph_results:
        score = r["graph_score"] * (1 - alpha)
        print(f"  [GRAPH  {score:.3f}] {r['entity']} (depth={r['distance']})")


def cmd_forget(text):
    """Remove a specific memory by exact document text."""
    collection = get_collection()
    # Find the document ID by searching for exact match
    results = collection.get(where_document={"$contains": text})
    if not results["ids"]:
        print(f"  No memory found containing: {text[:60]}...")
        return

    for doc_id in results["ids"]:
        collection.delete(ids=[doc_id])
    print(f"  Removed {len(results['ids'])} memory/memories.")


def parse_type_flag(args):
    """Extract --type flag from argument list, return (remaining_args, memory_type)."""
    memory_type = None
    remaining = []
    i = 0
    while i < len(args):
        if args[i] == "--type" and i + 1 < len(args):
            memory_type = args[i + 1]
            i += 2
        else:
            remaining.append(args[i])
            i += 1
    return remaining, memory_type


def parse_flag(args, flag_name):
    """Extract a --flag value from argument list, return (remaining_args, value)."""
    value = None
    remaining = []
    i = 0
    while i < len(args):
        if args[i] == flag_name and i + 1 < len(args):
            value = args[i + 1]
            i += 2
        else:
            remaining.append(args[i])
            i += 1
    return remaining, value


def has_flag(args, flag_name):
    """Check if a boolean flag is present, return (remaining_args, present)."""
    present = flag_name in args
    remaining = [a for a in args if a != flag_name]
    return remaining, present


def usage():
    """Print usage and exit."""
    print("Euxis Cortex - Cross-Platform Semantic Memory (Vector + Graph Hybrid)")
    print("")
    print("Usage:")
    print("  euxis-cortex remember 'fact to store' [source_agent] [--type episodic|semantic|procedural]")
    print("  euxis-cortex recall   'query keywords' [n_results] [--type TYPE] [--hybrid]")
    print("  euxis-cortex relate   'memory query' <entity> --relation <type>")
    print("  euxis-cortex stats")
    print("  euxis-cortex forget   'exact document text'")
    print("")
    print("Memory Types:")
    print("  episodic    — Specific events, outcomes, timestamps (default)")
    print("  semantic    — General facts, rules, relationships")
    print("  procedural  — Reusable workflows, patterns, contraindications")
    print("")
    print("Graph Relations:")
    print("  related_to, produced_by, depends_on, contradicts, references, part_of")
    print("")
    print("Flags:")
    print("  --hybrid    Combine vector similarity with graph proximity for recall")
    print("")
    print(f"Platform: {PLATFORM_LABEL} | DB: {DB_PATH}")
    sys.exit(1)


# ============================================================================
# Entry Point
# ============================================================================

if __name__ == "__main__":
    if len(sys.argv) < 2:
        usage()

    command = sys.argv[1]
    remaining_args, memory_type = parse_type_flag(sys.argv[2:])
    remaining_args, hybrid = has_flag(remaining_args, "--hybrid")

    if command == "remember":
        if len(remaining_args) < 1:
            print("Error: 'remember' requires text argument.")
            usage()
        text = remaining_args[0]
        source = remaining_args[1] if len(remaining_args) > 1 else "system"
        cmd_remember(text, source, memory_type or "episodic")

    elif command == "recall":
        if len(remaining_args) < 1:
            print("Error: 'recall' requires a query argument.")
            usage()
        query = remaining_args[0]
        n = int(remaining_args[1]) if len(remaining_args) > 1 else 3
        if hybrid:
            cmd_hybrid_recall(query, n, memory_type)
        else:
            cmd_recall(query, n, memory_type)

    elif command == "relate":
        if len(remaining_args) < 2:
            print("Error: 'relate' requires memory query and entity arguments.")
            print("Usage: euxis-cortex relate 'memory query' <entity> --relation <type>")
            usage()
        mem_query = remaining_args[0]
        entity = remaining_args[1]
        # Parse --relation flag from remaining args
        relation_args, relation = parse_flag(remaining_args[2:], "--relation")
        if not relation:
            print("Error: 'relate' requires --relation flag.")
            usage()
        cmd_relate(mem_query, entity, relation)

    elif command == "stats":
        cmd_stats()

    elif command == "forget":
        if len(remaining_args) < 1:
            print("Error: 'forget' requires text argument.")
            usage()
        cmd_forget(remaining_args[0])

    else:
        print(f"Unknown command: {command}")
        usage()
