#!/usr/bin/env python3
"""Euxis Voice Interface: Record -> Local STT -> Orchestrator -> Butler -> Local TTS"""

import os
import sys
import subprocess
import platform
import threading
import itertools
import time
import json
import urllib.request
import urllib.error

VENV_DIR = os.path.join(os.path.expanduser("~"), ".euxis", ".venv-voice")
VENV_PYTHON = os.path.join(VENV_DIR, "bin", "python3")
DEPS = ["faster-whisper", "piper-tts", "sounddevice", "numpy", "scipy"]


def _ensure_venv():
    """Bootstrap venv and re-exec if not already running inside it."""
    if sys.prefix != os.path.normpath(VENV_DIR):
        if not os.path.isfile(VENV_PYTHON):
            print("First run: creating voice venv...")
            subprocess.run([sys.executable, "-m", "venv", VENV_DIR], check=True)
            pip = os.path.join(VENV_DIR, "bin", "pip")
            subprocess.run([pip, "install", "--quiet"] + DEPS, check=True)
            print("Dependencies installed.")
        os.execv(VENV_PYTHON, [VENV_PYTHON] + sys.argv)


_ensure_venv()

import sounddevice as sd
import numpy as np
import scipy.io.wavfile as wav
from faster_whisper import WhisperModel
from piper import PiperVoice
import wave

# CONFIGURATION
SAMPLE_RATE = 16000  # 16kHz is optimal for Whisper
TMP_INPUT = "/tmp/euxis_input.wav"
TMP_OUTPUT = "/tmp/euxis_output.wav"

# Silence detection settings
CHUNK_DURATION = 0.3       # seconds per chunk
SILENCE_THRESHOLD = 0.005  # RMS below this = silence
SILENCE_CHUNKS = 7         # consecutive silent chunks (~2.1s) to stop
MAX_RECORD_SECONDS = 30    # hard cap
MIN_RECORD_SECONDS = 3     # minimum seconds before silence detection kicks in

PIPER_VOICE = "en_US-lessac-medium"
PIPER_VOICES_DIR = os.path.join(os.path.expanduser("~"), ".euxis", ".piper-voices")

# Lazy-loaded globals
_whisper_model = None
_piper_voice = None
_audio_player = None


def _get_whisper_model():
    """Load faster-whisper model once, reuse across calls."""
    global _whisper_model
    if _whisper_model is None:
        print("Loading Whisper model (first run downloads ~150MB)...")
        _whisper_model = WhisperModel("base.en", device="cpu", compute_type="int8", num_workers=4)
    return _whisper_model


def _get_piper_voice():
    """Load Piper voice model once via Python API, reuse across calls."""
    global _piper_voice
    if _piper_voice is not None:
        return _piper_voice

    model_file = os.path.join(PIPER_VOICES_DIR, f"{PIPER_VOICE}.onnx")
    config_file = os.path.join(PIPER_VOICES_DIR, f"{PIPER_VOICE}.onnx.json")

    if not os.path.isfile(model_file) or not os.path.isfile(config_file):
        print(f"Downloading piper voice model '{PIPER_VOICE}'...")
        os.makedirs(PIPER_VOICES_DIR, exist_ok=True)
        from piper.download_voices import download_voice
        from pathlib import Path
        download_voice(PIPER_VOICE, Path(PIPER_VOICES_DIR))
        print("Voice model downloaded.")

    print("Loading TTS model...")
    _piper_voice = PiperVoice.load(model_file)
    return _piper_voice


def _get_audio_player():
    """Cache and return the audio player command."""
    global _audio_player
    if _audio_player is not None:
        return _audio_player
    if platform.system() == "Darwin":
        _audio_player = "afplay"
    elif subprocess.run(["which", "aplay"], capture_output=True).returncode == 0:
        _audio_player = "aplay"
    return _audio_player


def _synthesize_wav(text):
    """Generate WAV file from text using Piper Python API (model kept in memory)."""
    try:
        voice = _get_piper_voice()
        with wave.open(TMP_OUTPUT, "wb") as wf:
            voice.synthesize_wav(text, wf)
        return True
    except Exception as e:
        print(f"TTS Error: {e}")
        return False


def _play_wav():
    """Play the TMP_OUTPUT wav file."""
    player = _get_audio_player()
    if player is None:
        print("Warning: No WAV player found. Install alsa-utils: sudo apt install alsa-utils")
        return
    if player == "aplay":
        subprocess.run([player, "-q", TMP_OUTPUT], check=False)
    else:
        subprocess.run([player, TMP_OUTPUT], check=False)


def play_sound(text):
    """Generates audio from text via piper TTS and plays it."""
    print(f"    Euxis: {text}")
    try:
        if _synthesize_wav(text):
            _play_wav()
    except Exception as e:
        print(f"Audio Error: {e}")


def record_audio():
    """Records audio with silence-based stop detection."""
    print("Listening... (speak, then pause to finish)")
    try:
        chunk_samples = int(CHUNK_DURATION * SAMPLE_RATE)
        max_chunks = int(MAX_RECORD_SECONDS / CHUNK_DURATION)
        min_chunks = int(MIN_RECORD_SECONDS / CHUNK_DURATION)

        chunks = []
        silent_count = 0

        with sd.InputStream(samplerate=SAMPLE_RATE, channels=1, dtype="float32") as stream:
            for i in range(max_chunks):
                data, _ = stream.read(chunk_samples)
                chunks.append(data.copy())

                rms = np.sqrt(np.mean(data ** 2))
                if i >= min_chunks and rms < SILENCE_THRESHOLD:
                    silent_count += 1
                    if silent_count >= SILENCE_CHUNKS:
                        break
                else:
                    silent_count = 0

        recording = np.concatenate(chunks)
        duration = len(recording) / SAMPLE_RATE
        # Convert float32 [-1,1] to int16 for WAV
        audio_int16 = np.clip(recording * 32767, -32768, 32767).astype(np.int16)
        wav.write(TMP_INPUT, SAMPLE_RATE, audio_int16)
        print(f"Recorded {duration:.1f}s. Processing...")
    except Exception as e:
        print(f"Mic Error: {e}")
        return False
    return True


def transcribe():
    """Converts audio to text using faster-whisper locally."""
    try:
        model = _get_whisper_model()
        segments, _ = model.transcribe(TMP_INPUT, beam_size=1)
        text = " ".join(segment.text for segment in segments).strip()
        return text
    except Exception as e:
        print(f"Transcription Error: {e}")
        return ""


def _spinner(message, stop_event):
    """Show a spinning indicator so the user knows work is happening."""
    chars = itertools.cycle(["⠋", "⠙", "⠹", "⠸", "⠼", "⠴", "⠦", "⠧", "⠇", "⠏"])
    while not stop_event.is_set():
        sys.stdout.write(f"\r{next(chars)} {message}")
        sys.stdout.flush()
        time.sleep(0.1)
    sys.stdout.write(f"\r✓ {message}\n")
    sys.stdout.flush()


VOICE_SYSTEM_PROMPT = (
    "You are a voice assistant. Respond in 1-3 short spoken sentences. "
    "No formatting, no markdown, no bullet points, no code blocks. "
    "Plain text only, suitable for text-to-speech. Be concise and conversational."
)

GROQ_API_URL = "https://api.groq.com/openai/v1/chat/completions"
GROQ_API_KEY = os.environ.get("GROQ_API_KEY", "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")
GROQ_MODEL = "llama-3.3-70b-versatile"

# Keywords that indicate the user wants multi-agent orchestration, not a quick answer.
_ORCHESTRATOR_KEYWORDS = {
    "run", "deploy", "fix", "build", "test", "commit", "push", "refactor",
    "create file", "edit file", "delete", "install", "update code", "debug",
    "scan", "audit", "lint", "dispatch", "execute",
}


def _call_groq(user_message):
    """Call Groq API directly via urllib. Returns response text (~0.3s)."""
    payload = json.dumps({
        "model": GROQ_MODEL,
        "max_tokens": 150,
        "messages": [
            {"role": "system", "content": VOICE_SYSTEM_PROMPT},
            {"role": "user", "content": user_message},
        ],
    }).encode()
    req = urllib.request.Request(
        GROQ_API_URL,
        data=payload,
        headers={
            "Authorization": f"Bearer {GROQ_API_KEY}",
            "Content-Type": "application/json",
            "User-Agent": "euxis-voice/1.0",
        },
        method="POST",
    )
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            data = json.loads(resp.read())
        return data["choices"][0]["message"]["content"].strip()
    except (urllib.error.URLError, json.JSONDecodeError, KeyError, IndexError) as e:
        print(f"Groq API Error: {e}")
        return ""


def _needs_orchestrator(text):
    """Return True if the voice command requires full orchestrator dispatch."""
    lower = text.lower()
    return any(kw in lower for kw in _ORCHESTRATOR_KEYWORDS)


def _query_direct(user_command):
    """Fast path: call Groq for conversational answers (~0.3s)."""
    stop = threading.Event()
    t = threading.Thread(target=_spinner, args=("Thinking...", stop), daemon=True)
    t.start()
    result = _call_groq(user_command)
    stop.set()
    t.join()
    return result


def run_euxis_fleet(user_command):
    """Slow path: full Euxis Orchestrator for engineering tasks."""
    stop = threading.Event()
    t = threading.Thread(target=_spinner, args=("Working on it...", stop), daemon=True)
    t.start()
    cmd = ["euxis", "orchestrator", user_command, "claude"]
    result = subprocess.run(cmd, capture_output=True, text=True)
    stop.set()
    t.join()
    return result.stdout


def synthesize_briefing(raw_output):
    """Summarize orchestrator output into spoken text via Groq."""
    prompt = (
        "Summarize this execution log into 1-2 short sentences suitable for speaking aloud. "
        "No formatting, no markdown. Plain text only:\n" + raw_output
    )
    return _call_groq(prompt)


def _warmup():
    """Pre-load models and cache lookups before user interaction."""
    _get_whisper_model()
    _get_piper_voice()
    _get_audio_player()
    print("Ready.\n")


def main():
    _warmup()
    conversation_history = []

    try:
        while True:
            # 1. Record
            if not record_audio():
                continue

            # 2. Transcribe
            user_text = transcribe()
            if not user_text:
                print("No speech detected. Try again.\n")
                continue

            print(f"You said: '{user_text}'")

            if user_text.lower().strip() in ("exit", "stop", "quit"):
                play_sound("Goodbye.")
                break

            conversation_history.append(f"User: {user_text}")

            # 3. Build context-aware command
            if len(conversation_history) > 1:
                context = "\n".join(conversation_history)
                full_command = (
                    f"Conversation so far:\n{context}\n\n"
                    f"Respond to the latest message. Use the conversation history for context."
                )
            else:
                full_command = user_text

            # 4. Route: fast direct answer vs full orchestrator
            if _needs_orchestrator(user_text):
                # Engineering task — full pipeline with "On it" acknowledgment
                print("    Euxis: On it.")
                tts_thread = threading.Thread(target=_synthesize_wav, args=("On it.",), daemon=True)
                tts_thread.start()
                tts_thread.join()
                _play_wav()

                raw_output = run_euxis_fleet(full_command)
                briefing = synthesize_briefing(raw_output).strip()
            else:
                # Conversational question — fast direct path
                print("    Euxis: ...")
                briefing = _query_direct(full_command)

            # 5. Speak the response
            conversation_history.append(f"Euxis: {briefing}")
            tts_ready = threading.Thread(target=_synthesize_wav, args=(briefing,), daemon=True)
            tts_ready.start()
            print(f"    Euxis: {briefing}")
            tts_ready.join()
            _play_wav()
            print()  # blank line before next round

    except KeyboardInterrupt:
        print("\nGoodbye.")


if __name__ == "__main__":
    main()
