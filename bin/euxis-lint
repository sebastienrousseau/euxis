#!/bin/bash
# EUXIS LINT: Static Analysis for Agent Fleet
# Enforces Protocol v0.0.7 Compliance

set -uo pipefail

EUXIS_HOME="$HOME/.euxis"
FAILURES=0

echo "STARTING STATIC ANALYSIS..."

# CHECK 1: Agent Registry Integrity
echo "[1/8] Checking Registry..."
AGENTS=("architect" "automation-engineer" "brand-evangelist" "bug-fixer" "butler" "cli-ui-artisan" "compliance-officer" "crash-investigator" "crypto-cryptography-auditor" "data-steward" "deep-researcher" "devrel-advocate" "edge-hunter" "globalization-lead" "growth-marketer" "incident-commander" "interaction-and-input-specialist" "language-specialist" "legacy-maintainer" "librarian" "orchestrator" "payments-domain-steward" "perf-optimizer" "product-manager" "qa-coordinator" "realtime-audio-engineer" "regression-analyst" "release-manager" "reviewer" "rust-crate-steward" "security-lead" "social-manager" "system-critic" "tech-writer" "theming-and-motion-engineer" "unit-tester" "ux-sentinel" "web-ui-architect")

for agent in "${AGENTS[@]}"; do
    FOUND=false
    for dir in "$EUXIS_HOME/prompts/core" "$EUXIS_HOME/prompts/fleet"; do
        if [[ -f "$dir/${agent}.txt" ]]; then
            FOUND=true
            break
        fi
    done
    if [[ "$FOUND" == false ]]; then
        echo "  MISSING: ${agent}.txt"
        ((FAILURES++))
    fi
done

if [[ $FAILURES -eq 0 ]]; then
    echo "  All ${#AGENTS[@]} agents present."
fi

# CHECK 2: Protocol File Exists
echo "[2/8] Checking Protocol..."
PROTOCOL_FILE="$EUXIS_HOME/prompts/protocols/_protocol.txt"
if [[ ! -f "$PROTOCOL_FILE" ]]; then
    echo "  MISSING: _protocol.txt"
    ((FAILURES++))
else
    # Verify protocol contains key sections
    for section in "EUXIS MANDATORY PROTOCOL" "AUDIT_FILE_PATH" "MEMORY_FILE_PATH" "SESSION_ID" "MODEL_NAME" "AUTHORIZED TOOL BELT" "FALLBACK BEHAVIOR" "CORTEX" "ReAct REASONING LOOP" "INTER-AGENT MESSAGE SCHEMA"; do
        if ! grep -q "$section" "$PROTOCOL_FILE"; then
            echo "  PROTOCOL GAP: Missing section — $section"
            ((FAILURES++))
        fi
    done
    if [[ $FAILURES -eq 0 ]]; then
        echo "  Protocol contains all required sections."
    fi
fi

# CHECK 3: Version Synchronization
echo "[3/8] Checking Versions..."
VERSION_COUNT=$(grep -rh 'version:' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" "$EUXIS_HOME/prompts/protocols/" | grep -oE '"[0-9]+\.[0-9]+(\.[0-9]+)?"' | sort -u | wc -l | tr -d ' ')
VERSIONS=$(grep -rh 'version:' "$EUXIS_HOME/prompts/core/" "$EUXIS_HOME/prompts/fleet/" "$EUXIS_HOME/prompts/protocols/" | grep -oE '"[0-9]+\.[0-9]+(\.[0-9]+)?"' | sort -u | tr -d '"')

if [[ "$VERSION_COUNT" -ne 1 ]]; then
    echo "  VERSION MISMATCH: Found multiple versions: $VERSIONS"
    ((FAILURES++))
else
    echo "  All agents at version: $VERSIONS"
fi

# CHECK 4: Permissions
echo "[4/8] Checking Script Permissions..."
for script in "$EUXIS_HOME/bin/"*; do
    # Skip directories (e.g., lib/)
    [[ -f "$script" ]] || continue
    PERMS=$(stat -c "%a" "$script" 2>/dev/null || stat -f "%Lp" "$script" 2>/dev/null)
    if [[ "$PERMS" != "755" && "$PERMS" != "700" && "$PERMS" != "775" ]]; then
        echo "  BAD PERMS: $(basename "$script") is $PERMS (expected 755, 775, or 700)"
        ((FAILURES++))
    fi
done
echo "  Script permissions verified."

# CHECK 5: Prompt YAML Header Validation
echo "[5/8] Checking Prompt Headers..."
HEADER_FAILURES=0

for dir in "$EUXIS_HOME/prompts/core" "$EUXIS_HOME/prompts/fleet"; do
    for prompt_file in "$dir"/*.txt; do
        [[ -f "$prompt_file" ]] || continue
        local_name=$(basename "$prompt_file" .txt)

        # Skip protocol/internal files
        [[ "$local_name" == _* ]] && continue

        # 1. File starts with --- (YAML frontmatter present)
        first_line=$(head -n 1 "$prompt_file")
        if [[ "$first_line" != "---" ]]; then
            echo "  NO FRONTMATTER: ${local_name}.txt (missing opening ---)"
            ((HEADER_FAILURES++))
            continue
        fi

        # Extract frontmatter (between first and second ---)
        frontmatter=$(awk 'NR==1 && /^---$/{next} /^---$/{exit} {print}' "$prompt_file")

        # 2. Required fields: agent_id, role, version, tags, last_updated
        for field in agent_id role version tags last_updated; do
            if ! echo "$frontmatter" | grep -q "^${field}:"; then
                echo "  MISSING FIELD: ${local_name}.txt — ${field}"
                ((HEADER_FAILURES++))
            fi
        done

        # 3. agent_id matches filename
        declared_id=$(echo "$frontmatter" | grep '^agent_id:' | sed 's/^agent_id:[[:space:]]*//' | tr -d '"' | tr -d "'")
        if [[ -n "$declared_id" && "$declared_id" != "$local_name" ]]; then
            echo "  ID MISMATCH: ${local_name}.txt declares agent_id: ${declared_id}"
            ((HEADER_FAILURES++))
        fi

        # 4. Required sections: Mandate, (Scope Boundaries or Primary Directives), Output Format
        body=$(sed -n '/^---$/,$ p' "$prompt_file" | tail -n +2)

        has_mandate=false
        has_scope=false
        has_output=false

        echo "$body" | grep -qi 'mandate' && has_mandate=true
        echo "$body" | grep -qiE 'scope boundaries|primary directives' && has_scope=true
        echo "$body" | grep -qi 'output format' && has_output=true

        if [[ "$has_mandate" == false ]]; then
            echo "  MISSING SECTION: ${local_name}.txt — Mandate"
            ((HEADER_FAILURES++))
        fi
        if [[ "$has_scope" == false ]]; then
            echo "  MISSING SECTION: ${local_name}.txt — Scope Boundaries / Primary Directives"
            ((HEADER_FAILURES++))
        fi
        if [[ "$has_output" == false ]]; then
            echo "  MISSING SECTION: ${local_name}.txt — Output Format"
            ((HEADER_FAILURES++))
        fi

        # 5. Delegation targets in Scope Boundaries exist in registry
        if echo "$body" | grep -qi 'scope boundaries'; then
            # Extract agent names from delegation table rows (| agent-name |)
            delegation_targets=$(echo "$body" | sed -n '/[Ss]cope [Bb]oundaries/,/^#/p' | \
                grep -oE '\b[a-z]+-[a-z]+(-[a-z]+)*\b' | sort -u)

            for target in $delegation_targets; do
                # Check if target is a known agent file
                target_found=false
                for tdir in "$EUXIS_HOME/prompts/core" "$EUXIS_HOME/prompts/fleet"; do
                    if [[ -f "$tdir/${target}.txt" ]]; then
                        target_found=true
                        break
                    fi
                done
                if [[ "$target_found" == false ]]; then
                    # Skip known non-agent compound phrases
                    case "$target" in
                        engineer-to-engineer|end-to-end|out-of-scope|up-to-date|day-to-day|one-to-one|peer-to-peer|real-time|step-by-step|line-by-line)
                            continue ;;
                    esac
                    # Only warn for names that look like agent references (contain hyphen)
                    case "$target" in
                        *-agent|*-engineer|*-manager|*-lead|*-officer|*-writer|*-hunter|*-tester|*-fixer|*-optimizer|*-coordinator|*-commander|*-maintainer|*-sentinel|*-artisan|*-specialist|*-architect|*-evangelist|*-advocate|*-researcher|*-steward|*-critic)
                            echo "  UNKNOWN DELEGATE: ${local_name}.txt references '${target}' (not in registry)"
                            ((HEADER_FAILURES++))
                            ;;
                    esac
                fi
            done
        fi
    done
done

if [[ $HEADER_FAILURES -eq 0 ]]; then
    echo "  All prompt headers valid."
else
    FAILURES=$((FAILURES + HEADER_FAILURES))
fi

# CHECK 6: Pattern File Validation
echo "[6/8] Checking Validation Patterns..."
PATTERN_FAILURES=0
PATTERN_COUNT=0
TOTAL_RULES=0

PATTERNS_DIR="$EUXIS_HOME/config/patterns"
if [[ -d "$PATTERNS_DIR" ]]; then
    for pattern_file in "$PATTERNS_DIR"/*.md; do
        [[ -f "$pattern_file" ]] || continue
        local_name=$(basename "$pattern_file")

        # Skip README
        [[ "$local_name" == "README.md" ]] && continue

        ((PATTERN_COUNT++))

        # Validate naming: CATEGORY-NNN.md
        if ! echo "$local_name" | grep -qE '^[A-Z]+-[0-9]{3}\.md$'; then
            echo "  BAD NAME: ${local_name} (expected FORMAT-NNN.md)"
            ((PATTERN_FAILURES++))
        fi

        # Required sections
        for section in "## Pattern" "## Severity" "## Detection Rules" "## Validation" "## Remediation"; do
            if ! grep -q "$section" "$pattern_file"; then
                echo "  MISSING SECTION: ${local_name} — ${section}"
                ((PATTERN_FAILURES++))
            fi
        done

        # Validate severity
        severity=$(grep '^## Severity' -A 1 "$pattern_file" | tail -1 | tr -d ' ')
        case "$severity" in
            CRITICAL|HIGH|MEDIUM|LOW) ;;
            *)
                echo "  BAD SEVERITY: ${local_name} — '${severity}' (expected CRITICAL|HIGH|MEDIUM|LOW)"
                ((PATTERN_FAILURES++))
                ;;
        esac

        # Count detection rules (lines starting with number. under Detection Rules)
        # Use awk for portability (BSD/GNU sed have incompatible range syntax)
        rules_count=$(awk '/^## Detection Rules/{found=1;next} /^## /{found=0} found && /^[0-9]+\./' "$pattern_file" | wc -l | tr -d ' ')
        TOTAL_RULES=$((TOTAL_RULES + rules_count))
    done

    if [[ $PATTERN_FAILURES -eq 0 ]]; then
        echo "  All ${PATTERN_COUNT} patterns validated (${TOTAL_RULES} total detection rules)."
    else
        FAILURES=$((FAILURES + PATTERN_FAILURES))
    fi
else
    echo "  WARNING: No patterns directory found at ${PATTERNS_DIR}"
fi

# CHECK 7: Automated Pattern Compliance Verification
echo "[7/8] Checking Pattern Compliance..."
COMPLIANCE_FAILURES=0

PATTERNS_DIR="$EUXIS_HOME/config/patterns"
if [[ -d "$PATTERNS_DIR" ]]; then
    # Verify every pattern has automated detection rules (not just descriptions)
    for pattern_file in "$PATTERNS_DIR"/*.md; do
        [[ -f "$pattern_file" ]] || continue
        local_name=$(basename "$pattern_file")
        [[ "$local_name" == "README.md" ]] && continue

        # Check that Detection Rules section has numbered rules
        # Use awk for portability (BSD/GNU sed have incompatible range syntax)
        rule_count=$(awk '/^## Detection Rules/{found=1;next} /^## /{found=0} found && /^[0-9]+\./' "$pattern_file" | wc -l | tr -d ' ')
        if [[ "$rule_count" -lt 1 ]]; then
            echo "  NO DETECTION RULES: ${local_name}"
            ((COMPLIANCE_FAILURES++))
        fi

        # Check that each pattern has a Validation checklist
        if ! grep -q '\- \[ \]' "$pattern_file"; then
            echo "  NO VALIDATION CHECKLIST: ${local_name}"
            ((COMPLIANCE_FAILURES++))
        fi

        # Check that Remediation section is non-empty
        # Use awk for portability (BSD/GNU sed have incompatible range syntax)
        remediation=$(awk '/^## Remediation/{found=1;next} /^## /{found=0} found && !/^$/' "$pattern_file" | wc -l | tr -d ' ')
        if [[ "$remediation" -lt 1 ]]; then
            echo "  EMPTY REMEDIATION: ${local_name}"
            ((COMPLIANCE_FAILURES++))
        fi
    done

    # Cross-reference: protocol references patterns that exist
    PROTOCOL_FILE="$EUXIS_HOME/prompts/protocols/_protocol.txt"
    if [[ -f "$PROTOCOL_FILE" ]]; then
        for ref_pattern in $(grep -oE '[A-Z]+-[0-9]{3}' "$PROTOCOL_FILE" | sort -u); do
            if [[ ! -f "$PATTERNS_DIR/${ref_pattern}.md" ]]; then
                echo "  DANGLING REFERENCE: Protocol references ${ref_pattern} but file missing"
                ((COMPLIANCE_FAILURES++))
            fi
        done
    fi

    if [[ $COMPLIANCE_FAILURES -eq 0 ]]; then
        echo "  All patterns have detection rules, validation checklists, and remediation."
    else
        FAILURES=$((FAILURES + COMPLIANCE_FAILURES))
    fi
else
    echo "  WARNING: No patterns directory."
fi

# CHECK 8: Cross-Module Dependency Validation
echo "[8/8] Checking Module Dependencies..."
DEP_FAILURES=0

# Verify no circular sourcing in lib files
LIB_DIR="$EUXIS_HOME/bin/lib"
if [[ -d "$LIB_DIR" ]]; then
    for lib_file in "$LIB_DIR"/*.sh; do
        [[ -f "$lib_file" ]] || continue
        lib_name=$(basename "$lib_file" .sh)

        # Check that every source'd file exists
        while IFS= read -r sourced; do
            # Resolve the path
            sourced_resolved=$(echo "$sourced" | sed "s|\${EUXIS_HOME}|$EUXIS_HOME|g" | sed "s|\"\${EUXIS_HOME}\"|$EUXIS_HOME|g")
            # Extract just the filename from the source line
            sourced_file=$(echo "$sourced" | grep -oE '[a-z-]+\.sh' | head -1)
            if [[ -n "$sourced_file" && ! -f "$LIB_DIR/$sourced_file" ]]; then
                echo "  MISSING DEP: ${lib_name}.sh sources ${sourced_file} (not found)"
                ((DEP_FAILURES++))
            fi
        done < <(grep -E '^source ' "$lib_file" 2>/dev/null || true)

        # Verify source guard is present
        if ! grep -q '_EUXIS_LIB_' "$lib_file"; then
            echo "  NO SOURCE GUARD: ${lib_name}.sh"
            ((DEP_FAILURES++))
        fi
    done

    if [[ $DEP_FAILURES -eq 0 ]]; then
        echo "  All module dependencies valid, source guards present."
    else
        FAILURES=$((FAILURES + DEP_FAILURES))
    fi
fi

echo "---------------------------------------------------"
if [[ $FAILURES -eq 0 ]]; then
    echo "LINT PASSED. Fleet integrity: 100%."
    exit 0
else
    echo "LINT FAILED with $FAILURES error(s)."
    exit 1
fi
