#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
VENV_PY="${ROOT_DIR}/.venv-euxis/bin/python"
CONFIG_PATH="${ROOT_DIR}/euxis-gateway/config/gateway-e2e.json"
PORT="${EUXIS_GATEWAY_PORT:-18789}"
URL="${EUXIS_GATEWAY_URL:-http://127.0.0.2:${PORT}}"
TOKEN="${EUXIS_GATEWAY_TOKEN:-e2e-token}"

usage() {
  cat <<'EOF'
euxis-gateway-e2e — Run WebChat Playwright tests against a local gateway

Usage:
  bin/euxis-gateway-e2e [--port PORT] [--url URL] [--token TOKEN] [--no-kill]
  bin/euxis-gateway-e2e --help
EOF
}

NO_KILL=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --port) PORT="$2"; shift 2 ;;
    --url) URL="$2"; shift 2 ;;
    --token) TOKEN="$2"; shift 2 ;;
    --no-kill) NO_KILL=1; shift ;;
    -h|--help) usage; exit 0 ;;
    *) echo "Unknown option: $1" >&2; usage; exit 1 ;;
  esac
done

if [[ ! -x "${VENV_PY}" ]]; then
  echo "Error: ${VENV_PY} not found. Create .venv-euxis first." >&2
  exit 1
fi

if [[ ! -f "${CONFIG_PATH}" ]]; then
  echo "Error: gateway e2e config not found at ${CONFIG_PATH}" >&2
  exit 1
fi

cleanup() {
  if [[ -n "${GATEWAY_PID:-}" ]]; then
    kill "${GATEWAY_PID}" >/dev/null 2>&1 || true
    wait "${GATEWAY_PID}" >/dev/null 2>&1 || true
  fi
}

trap cleanup EXIT INT TERM

if [[ "${NO_KILL}" -eq 0 ]]; then
  if command -v lsof >/dev/null 2>&1; then
    if lsof -ti "tcp:${PORT}" >/dev/null 2>&1; then
      echo "Stopping stale gateway on port ${PORT}..."
      kill -9 $(lsof -ti "tcp:${PORT}") || true
    fi
  fi
else
  echo "Skipping stale gateway cleanup (--no-kill)."
fi

echo "Starting gateway on ${URL}..."
"${VENV_PY}" -m gateway.server run --config "${CONFIG_PATH}" >/tmp/euxis-gateway-e2e.log 2>&1 &
GATEWAY_PID=$!

sleep 1

echo "Running Playwright e2e tests..."
set +e
EUXIS_GATEWAY_URL="${URL}" \
EUXIS_GATEWAY_TOKEN="${TOKEN}" \
"${VENV_PY}" -m pytest -q "${ROOT_DIR}/euxis-gateway/tests/test_webchat_playwright.py" -m e2e -o addopts=
exit_code=$?
set -e

if [[ "${exit_code}" -ne 0 ]]; then
  echo "E2E failed. Gateway log: /tmp/euxis-gateway-e2e.log" >&2
fi
exit "${exit_code}"
