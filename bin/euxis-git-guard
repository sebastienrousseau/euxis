#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS GIT GUARD: Enforce Feature Branch Workflow (Smart Mode)
# Standalone script — callable from any Euxis entry point.
# Exits 0 if safe to proceed, 1 if on a protected branch and user declines.
set -uo pipefail

usage() {
    cat <<'EOF'
euxis-git-guard — Feature branch workflow enforcer

Usage:
  euxis-git-guard

Validates the current Git branch and enforces feature branch workflow.
Exits 0 if safe to proceed, 1 if on a protected branch.

Options:
  -h, --help  Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

# 0. Skip in non-interactive contexts (CI, tests, pipes)
[[ -t 0 ]] || exit 0

# 1. Get current branch
CURRENT_BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)
if [[ -z "$CURRENT_BRANCH" ]]; then
    # Not a git repo — passive mode
    exit 0
fi

# 2. Short circuit: already on a compliant branch
if [[ "$CURRENT_BRANCH" == feat/* ]] || \
   [[ "$CURRENT_BRANCH" == fix/* ]] || \
   [[ "$CURRENT_BRANCH" == refactor/* ]] || \
   [[ "$CURRENT_BRANCH" == chore/* ]]; then
    exit 0
fi

# 3. Protected branch — block and propose upgrade
PROTECTED_BRANCHES="main master develop production staging"
if [[ " $PROTECTED_BRANCHES " == *" $CURRENT_BRANCH "* ]]; then
    echo "[euxis-git-guard] SAFETY STOP: You are on a protected branch ('$CURRENT_BRANCH')."

    LATEST_TAG=$(git describe --tags --abbrev=0 2>/dev/null || echo "v0.0.0")
    BASE_VER="${LATEST_TAG#v}"
    IFS='.' read -r MAJOR MINOR PATCH <<< "$BASE_VER"
    MAJOR="${MAJOR:-0}"; MINOR="${MINOR:-0}"; PATCH="${PATCH:-0}"
    NEXT_PATCH=$((PATCH + 1))
    NEXT_VER="v${MAJOR}.${MINOR}.${NEXT_PATCH}"
    NEW_BRANCH="feat/${NEXT_VER}"

    echo "   Euxis must work in a feature branch."
    echo "   Proposed Branch: $NEW_BRANCH (derived from $LATEST_TAG)"

    read -p "   Create and switch to '$NEW_BRANCH'? (y/n) " -n 1 -r
    echo
    if [[ $REPLY =~ ^[Yy]$ ]]; then
        git checkout -b "$NEW_BRANCH"
        echo "[euxis-git-guard] Switched to $NEW_BRANCH. Proceeding..."
    else
        echo "[euxis-git-guard] Aborted. Switch branches manually before running Euxis."
        exit 1
    fi
else
    # 4. Gray zone — non-standard branch name, warn but allow
    echo "[euxis-git-guard] Warning: Non-standard branch name '$CURRENT_BRANCH'. Proceeding..."
fi
