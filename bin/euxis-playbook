#!/usr/bin/env bash
set -uo pipefail

EUXIS_DIR="$HOME/.euxis"
SQUADS_FILE="$EUXIS_DIR/squads.json"
PLAYBOOKS_DIR="$EUXIS_DIR/playbooks"
SESSION_DIR="/tmp/euxis_playbook_sessions"

usage() {
  cat <<'EOF'
euxis-playbook — Phased squad deployment via playbooks

Usage:
  euxis-playbook list
  euxis-playbook info <playbook-id>
  euxis-playbook run <playbook-id> "<goal>" [--project NAME] [--dry-run]
  euxis-playbook status [session-id]

Commands:
  list      Available playbooks from playbooks/*.json
  info      Phase breakdown with squads and checkpoints
  run       Execute phases sequentially via squad dispatch
  status    Show session log

Options:
  --project   Project name for dispatch manifests (default: playbook-<id>)
  --dry-run   Print dispatch manifests without executing
  -h, --help  Show this help text
EOF
}

require_jq() {
  if ! command -v jq &>/dev/null; then
    echo "Error: jq is required but not installed." >&2
    exit 1
  fi
}

require_squads_file() {
  if [[ ! -f "$SQUADS_FILE" ]]; then
    echo "Error: squads.json not found at $SQUADS_FILE" >&2
    exit 1
  fi
}

find_playbook() {
  local id="$1"
  local file="$PLAYBOOKS_DIR/${id}.json"
  if [[ ! -f "$file" ]]; then
    echo "Error: Playbook '$id' not found at $file" >&2
    exit 1
  fi
  echo "$file"
}

cmd_list() {
  require_jq

  if [[ ! -d "$PLAYBOOKS_DIR" ]] || [[ -z "$(ls -A "$PLAYBOOKS_DIR"/*.json 2>/dev/null)" ]]; then
    echo "No playbooks found in $PLAYBOOKS_DIR"
    return
  fi

  printf "%-20s %-24s %-50s %s\n" "ID" "NAME" "DESCRIPTION" "PHASES"
  printf "%-20s %-24s %-50s %s\n" "---" "---" "---" "---"

  for file in "$PLAYBOOKS_DIR"/*.json; do
    local id name desc phase_count
    id=$(jq -r '.id' "$file")
    name=$(jq -r '.name' "$file")
    desc=$(jq -r '.description' "$file")
    phase_count=$(jq -r '.phases | length' "$file")
    printf "%-20s %-24s %-50s %s\n" "$id" "$name" "$desc" "$phase_count"
  done
}

cmd_info() {
  local id="$1"
  require_jq

  local file
  file=$(find_playbook "$id")

  local playbook
  playbook=$(cat "$file")

  echo "Playbook: $(echo "$playbook" | jq -r '.name')"
  echo "ID:          $(echo "$playbook" | jq -r '.id')"
  echo "Description: $(echo "$playbook" | jq -r '.description')"
  echo ""
  echo "Phases:"

  echo "$playbook" | jq -r '.phases[] | "  Phase \(.phase): \(.name)\n    Squad: \(.squad)\n    Mode: \(.mode)\n    Checkpoint: \(.checkpoint)\n    Abort on failure: \(.abort_on_failure)\n"'
}

cmd_run() {
  local id="$1"; shift
  local goal="$1"; shift
  local project="playbook-${id}"
  local dry_run=false

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --project) project="$2"; shift 2 ;;
      --dry-run) dry_run=true; shift ;;
      *) echo "Error: Unknown option '$1'" >&2; return 1 ;;
    esac
  done

  require_jq
  require_squads_file

  local file
  file=$(find_playbook "$id")

  local playbook
  playbook=$(cat "$file")
  local playbook_name
  playbook_name=$(echo "$playbook" | jq -r '.name')
  local phase_count
  phase_count=$(echo "$playbook" | jq -r '.phases | length')

  # Create session
  mkdir -p "$SESSION_DIR"
  local session_id
  session_id="$(date +%Y%m%d-%H%M%S)-${id}-$$"
  local session_log="$SESSION_DIR/${session_id}.log"

  log_session() {
    echo "[$(date '+%Y-%m-%dT%H:%M:%S')] $*" | tee -a "$session_log"
  }

  echo "═══════════════════════════════════════════════════════"
  echo "  Playbook: $playbook_name"
  echo "  Goal: $goal"
  echo "  Session: $session_id"
  if [[ "$dry_run" == true ]]; then
    echo "  Mode: DRY RUN"
  fi
  echo "═══════════════════════════════════════════════════════"
  echo ""

  log_session "START playbook=$id goal=\"$goal\" project=$project dry_run=$dry_run"

  local phase_idx=0
  while [[ $phase_idx -lt $phase_count ]]; do
    local phase
    phase=$(echo "$playbook" | jq ".phases[$phase_idx]")
    local phase_num phase_name squad_id mode task_template checkpoint abort_on_failure
    phase_num=$(echo "$phase" | jq -r '.phase')
    phase_name=$(echo "$phase" | jq -r '.name')
    squad_id=$(echo "$phase" | jq -r '.squad')
    mode=$(echo "$phase" | jq -r '.mode')
    task_template=$(echo "$phase" | jq -r '.task_template')
    checkpoint=$(echo "$phase" | jq -r '.checkpoint')
    abort_on_failure=$(echo "$phase" | jq -r '.abort_on_failure')

    # Substitute ${goal} in task_template
    local task="${task_template//\$\{goal\}/$goal}"

    echo "──────────────────────────────────────────────────────"
    echo "  Phase $phase_num: $phase_name (squad: $squad_id)"
    echo "  Task: $task"
    echo "  Checkpoint: $checkpoint"
    echo "──────────────────────────────────────────────────────"

    log_session "PHASE $phase_num ($phase_name) squad=$squad_id mode=$mode"

    # Resolve squad members
    local squad
    squad=$(jq --arg id "$squad_id" '.squads[] | select(.id == $id)' "$SQUADS_FILE")

    if [[ -z "$squad" ]]; then
      echo "Error: Squad '$squad_id' not found in squads.json" >&2
      log_session "ERROR squad '$squad_id' not found"
      exit 1
    fi

    local lead
    lead=$(echo "$squad" | jq -r '.lead')

    # Build dispatch manifest
    local dispatches="[]"
    while IFS= read -r member; do
      local priority="P1"
      if [[ "$member" == "$lead" ]]; then
        priority="P0"
      fi
      dispatches=$(echo "$dispatches" | jq \
        --arg agent "$member" \
        --arg priority "$priority" \
        --arg task "$task" \
        '. + [{"agent": $agent, "priority": $priority, "task": $task, "verify_cmd": "true"}]')
    done < <(echo "$squad" | jq -r '.members[]')

    local manifest_file
    manifest_file=$(mktemp /tmp/euxis_playbook_manifest_XXXXXX)

    jq -n \
      --arg project "$project" \
      --arg mode "$mode" \
      --argjson dispatches "$dispatches" \
      '{"project": $project, "mode": $mode, "dispatches": $dispatches}' > "$manifest_file"

    if [[ "$dry_run" == true ]]; then
      echo ""
      echo "  [DRY RUN] Dispatch manifest:"
      jq '.' "$manifest_file"
      echo ""
      log_session "DRY_RUN manifest=$manifest_file"
    else
      echo ""

      # Invoke dispatch
      local exit_code=0
      if command -v euxis-dispatch &>/dev/null; then
        euxis-dispatch "$manifest_file" --mode "$mode" || exit_code=$?
      else
        echo "Error: euxis-dispatch not found." >&2
        log_session "ERROR euxis-dispatch not found"
        exit 1
      fi

      if [[ $exit_code -ne 0 ]]; then
        log_session "FAILED phase=$phase_num exit_code=$exit_code"
        echo "  Phase $phase_num FAILED (exit code: $exit_code)"

        if [[ "$abort_on_failure" == "true" ]]; then
          echo "  Aborting playbook (abort_on_failure=true)"
          log_session "ABORT playbook aborted at phase $phase_num"

          # Publish failure event
          if command -v euxis-bus &>/dev/null; then
            euxis-bus publish playbook-events "Playbook '$id' aborted at phase $phase_num ($phase_name)" --sender "euxis-playbook" --priority P0
          fi
          exit 1
        else
          echo "  Continuing despite failure (abort_on_failure=false)"
        fi
      else
        log_session "COMPLETED phase=$phase_num"
        echo "  Phase $phase_num completed."
      fi

      # Publish phase event
      if command -v euxis-bus &>/dev/null; then
        euxis-bus publish playbook-events "Playbook '$id' phase $phase_num ($phase_name) completed" --sender "euxis-playbook" --priority P2
      fi
    fi

    echo ""
    ((phase_idx++))
  done

  echo "═══════════════════════════════════════════════════════"
  echo "  Playbook '$playbook_name' complete."
  echo "  Session log: $session_log"
  echo "═══════════════════════════════════════════════════════"

  log_session "END playbook=$id"

  # Publish completion event
  if [[ "$dry_run" != true ]] && command -v euxis-bus &>/dev/null; then
    euxis-bus publish playbook-events "Playbook '$id' completed for: $goal" --sender "euxis-playbook" --priority P1
  fi
}

cmd_status() {
  local session_id="${1:-}"

  mkdir -p "$SESSION_DIR"

  if [[ -n "$session_id" ]]; then
    local log_file="$SESSION_DIR/${session_id}.log"
    if [[ ! -f "$log_file" ]]; then
      echo "Error: Session '$session_id' not found." >&2
      exit 1
    fi
    cat "$log_file"
  else
    echo "Playbook sessions:"
    echo ""

    local found=false
    shopt -s nullglob
    for log_file in "$SESSION_DIR"/*.log; do
      found=true
      local name
      name=$(basename "$log_file" .log)
      local last_line
      last_line=$(tail -1 "$log_file")
      printf "  %-40s %s\n" "$name" "$last_line"
    done
    shopt -u nullglob

    if [[ "$found" != true ]]; then
      echo "  No sessions found."
    fi
  fi
}

# Main
case "${1:-}" in
  list)       cmd_list ;;
  info)
    if [[ -z "${2:-}" ]]; then echo "Error: info requires <playbook-id>" >&2; usage >&2; exit 1; fi
    cmd_info "$2" ;;
  run)
    if [[ -z "${2:-}" || -z "${3:-}" ]]; then echo "Error: run requires <playbook-id> and <goal>" >&2; usage >&2; exit 1; fi
    cmd_run "$2" "$3" "${@:4}" ;;
  status)     cmd_status "${2:-}" ;;
  -h|--help)  usage ;;
  *)          usage >&2; exit 1 ;;
esac
