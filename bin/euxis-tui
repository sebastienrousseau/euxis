#!/usr/bin/env bash
# EUXIS ETX: Modern Terminal Experience
# (c) 2026 Euxis Fleet. All rights reserved.
#
# Launch the ETX terminal interface for the Euxis agent fleet.
# Built on Python Textual for rich, accessible TUI rendering.

set -euo pipefail

EUXIS_HOME="${EUXIS_HOME:-${HOME}/.euxis}"
VENV_PYTHON="${EUXIS_HOME}/.venv/bin/python"

# Verify Python venv exists
if [[ ! -x "${VENV_PYTHON}" ]]; then
    echo "[euxis] ERROR: Python venv not found at ${EUXIS_HOME}/.venv"
    echo "[euxis] Run: ${EUXIS_HOME}/setup.sh to initialize"
    exit 1
fi

# Verify Textual is installed
if ! "${VENV_PYTHON}" -c "import textual" 2>/dev/null; then
    echo "[euxis] Installing ETX dependencies..."
    "${EUXIS_HOME}/.venv/bin/pip" install textual textual-dev 2>/dev/null
fi

# Launch ETX
cd "${EUXIS_HOME}"
exec "${VENV_PYTHON}" -m tui "$@"
