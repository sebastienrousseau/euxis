#!/usr/bin/env bash
# (c) 2026 Euxis Fleet. All rights reserved.
# EUXIS LOOP: Autonomous Try-Catch-Retry with Reflexion & Checkpoints
# Usage: euxis-loop <agent> <task> <verify_cmd> [max_retries]
#        euxis-loop --checkpoints <agent> <task> <max_retries> <cmd1> <cmd2> ... <cmdN>
#
# Implements the Reflexion pattern (Shinn et al., NeurIPS 2023):
#   1. Execute the agent
#   2. Verify with environment feedback (single or multi-checkpoint)
#   3. On failure, extract the agent's REFLECTION entries from memory
#   4. Inject both the error log AND prior reflections into the retry prompt
#   5. The agent learns from structured self-critique, not just raw errors
#
# Checkpoint mode (--checkpoints):
#   Runs multiple verification commands in sequence. On first failure,
#   reports which checkpoint failed and feeds that context back to the agent.
#   This catches errors at intermediate steps rather than only at the end.
#
# Human-in-the-loop (--confirm):
#   Pauses for user confirmation before each retry attempt.

set -euo pipefail

usage() {
    cat <<'EOF'
euxis-loop — Autonomous try-catch-retry with reflexion

Usage:
  euxis-loop <agent> <task> <verify_cmd> [max_retries]
  euxis-loop --checkpoints <agent> <task> <max_retries> <cmd1> ... <cmdN>

Implements the Reflexion pattern with optional checkpoint mode
and human-in-the-loop confirmation.

Options:
  --checkpoints  Multi-checkpoint verification mode
  --confirm      Pause for user confirmation before each retry
  -h, --help     Show this help text
EOF
}

[[ "${1:-}" == "-h" || "${1:-}" == "--help" ]] && { usage; exit 0; }

EUXIS_HOME="${HOME}/.euxis"
PROJECTS_DIR="${EUXIS_HOME}/data/projects"

MODE="single"
CONFIRM_MODE=false

# Parse flags
while [[ "${1:-}" == --* ]]; do
    case "$1" in
        --checkpoints) MODE="checkpoints"; shift ;;
        --confirm) CONFIRM_MODE=true; shift ;;
        *) echo "Unknown flag: $1"; exit 1 ;;
    esac
done

if [[ "$MODE" == "checkpoints" ]]; then
    AGENT="${1:-}"
    TASK="${2:-}"
    MAX_RETRIES="${3:-3}"
    shift 3 2>/dev/null || true
    CHECKPOINT_CMDS=("$@")

    if [[ -z "$AGENT" || -z "$TASK" || ${#CHECKPOINT_CMDS[@]} -eq 0 ]]; then
        echo "Usage: euxis-loop --checkpoints <agent> <task> <max_retries> <cmd1> <cmd2> ..."
        echo "  Example: euxis-loop --checkpoints debugger \"Fix parser\" 3 \\"
        echo "    \"python -c 'import parser'\" \\"
        echo "    \"pytest tests/test_parser.py\" \\"
        echo "    \"mypy parser.py\""
        exit 1
    fi
else
    AGENT="${1:-}"
    TASK="${2:-}"
    VERIFY_CMD="${3:-}"
    MAX_RETRIES="${4:-3}"

    if [[ -z "$AGENT" || -z "$TASK" || -z "$VERIFY_CMD" ]]; then
        echo "Usage: euxis-loop <agent> <task> <verification_command> [max_retries]"
        echo "       euxis-loop --checkpoints <agent> <task> <max_retries> <cmd1> <cmd2> ..."
        echo "       euxis-loop --confirm <agent> <task> <verify_cmd> [max_retries]"
        echo ""
        echo "  Example: euxis-loop debugger \"Fix parser.py\" \"pytest tests/test_parser.py\" 3"
        exit 1
    fi

    CHECKPOINT_CMDS=("$VERIFY_CMD")
fi

ATTEMPT=1
ORIGINAL_TASK="$TASK"

# Auto-activate project virtualenv if present
for venv_dir in .venv venv env; do
    if [[ -f "$venv_dir/bin/activate" ]]; then
        # shellcheck disable=SC1091
        source "$venv_dir/bin/activate"
        break
    fi
done

# Validate checkpoint commands: reject known-dangerous patterns (defense-in-depth)
validate_checkpoint_cmd() {
    local cmd="$1"
    local dangerous_patterns=(
        # Reverse shells
        '/dev/tcp/'
        '/dev/udp/'
        'bash -i'
        'nc -e'
        'ncat -e'
        'mkfifo'
        # Destructive commands
        'rm -rf /'
        'mkfs\.'
        'dd if='
        ':(){:|:&};:'
        '> /dev/sd'
        # Data exfiltration
        'curl.*|.*sh'
        'wget.*|.*sh'
        'curl.*POST.*@'
        # Code injection / obfuscation
        'base64.*decode.*|.*sh'
        'base64.*-d.*|.*sh'
        'python.*-c.*exec'
        'perl.*-e.*system'
        'ruby.*-e.*exec'
    )

    for pattern in "${dangerous_patterns[@]}"; do
        if [[ "$cmd" =~ $pattern ]]; then
            echo ""
            echo "  ✘ SECURITY: checkpoint command rejected — matches dangerous pattern: $pattern"
            echo "    Command: $cmd"
            echo ""
            exit 1
        fi
    done
}

# Pre-flight: verify that each checkpoint command's binary exists
for cmd in "${CHECKPOINT_CMDS[@]}"; do
    validate_checkpoint_cmd "$cmd"
    # Extract the first word (the binary) from the command, ignoring leading '!'
    binary=$(echo "$cmd" | sed 's/^[[:space:]]*!*[[:space:]]*//' | awk '{print $1}')
    if ! command -v "$binary" &>/dev/null; then
        echo ""
        echo "  ✘ PRE-FLIGHT FAILED: command not found: $binary"
        echo "    Verify command: $cmd"
        echo "    Install '$binary' or update the manifest with a verify_cmd that uses available tools."
        echo ""
        echo "  Available alternatives:"
        echo "    python3 -c 'import module'    — import check"
        echo "    python3 -m py_compile file.py — syntax check"
        echo "    test -f path/to/file          — file exists"
        echo "    grep -q 'pattern' file        — pattern search"
        exit 1
    fi
done

# Resolve the project name (same logic as euxis.sh)
PROJECT="${EUXIS_PROJECT:-$(basename "$(pwd)")}"

# Locate the agent's memory file for reflection extraction
MEMORY_FILE="${PROJECTS_DIR}/${PROJECT}/${AGENT}/memory.md"

# Extract REFLECTION entries from the agent's memory
get_reflections() {
    if [[ -f "$MEMORY_FILE" ]]; then
        grep -E '^\[.*\] REFLECTION:' "$MEMORY_FILE" 2>/dev/null | tail -n 5 || true
    fi
}

# Run all checkpoint commands in sequence, return on first failure
run_checkpoints() {
    local i=1
    local total=${#CHECKPOINT_CMDS[@]}

    for cmd in "${CHECKPOINT_CMDS[@]}"; do
        validate_checkpoint_cmd "$cmd"
        echo "  [Checkpoint $i/$total] $cmd"
        local output
        output=$(eval "$cmd" 2>&1)
        local exit_code=$?

        if [[ $exit_code -ne 0 ]]; then
            echo "  ✘ Checkpoint $i FAILED (Exit Code $exit_code)"
            FAILED_CHECKPOINT_NUM=$i
            FAILED_CHECKPOINT_CMD="$cmd"
            FAILED_CHECKPOINT_OUTPUT=$(echo "$output" | tail -n 20)
            return 1
        else
            echo "  ✔ Checkpoint $i passed"
        fi
        ((i++)) || true
    done

    return 0
}

while [ $ATTEMPT -le $MAX_RETRIES ]; do
    echo ""
    echo "═══════════════════════════════════════════════════"
    echo "  Loop Attempt $ATTEMPT/$MAX_RETRIES"
    echo "═══════════════════════════════════════════════════"

    # Human-in-the-loop confirmation gate
    if [[ "$CONFIRM_MODE" == true && $ATTEMPT -gt 1 ]]; then
        echo ""
        echo "  [CHECKPOINT GATE] Review the task before retry:"
        echo "  Task: $TASK"
        echo ""
        read -rp "  Continue with retry? [y/N] " confirm
        if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
            echo "  Aborted by user."
            exit 1
        fi
    fi

    # 1. Run the Agent
    euxis "$AGENT" "$TASK" claude

    # 2. Run Verification (Checkpoint sequence)
    echo ""
    echo "  Running verification checkpoints..."

    FAILED_CHECKPOINT_NUM=""
    FAILED_CHECKPOINT_CMD=""
    FAILED_CHECKPOINT_OUTPUT=""

    if run_checkpoints; then
        echo ""
        echo "  ✔ ALL CHECKPOINTS PASSED on attempt $ATTEMPT."
        exit 0
    else
        echo ""

        # 3. Extract prior reflections from memory (the Reflexion step)
        PRIOR_REFLECTIONS=$(get_reflections)

        # 4. Build the enriched retry prompt with checkpoint context
        TASK="PREVIOUS ATTEMPT FAILED (attempt $ATTEMPT of $MAX_RETRIES).

## Failed Checkpoint
Checkpoint $FAILED_CHECKPOINT_NUM of ${#CHECKPOINT_CMDS[@]} failed.
Command: $FAILED_CHECKPOINT_CMD

## Error Log (last 20 lines)
$FAILED_CHECKPOINT_OUTPUT

## Prior Reflections from Memory
${PRIOR_REFLECTIONS:-No prior reflections found. You MUST generate a REFLECTION entry in memory before retrying.}

## Original Task
$ORIGINAL_TASK

## Instructions for This Retry
1. Read your REFLECTION entries above. Do NOT repeat the same strategy that failed.
2. If no reflection exists yet, STOP and write one to memory first.
3. Apply a DIFFERENT approach based on your reflection's STRATEGY field.
4. The failure occurred at checkpoint $FAILED_CHECKPOINT_NUM — focus your fix on what that checkpoint validates.
5. This is retry attempt $((ATTEMPT + 1)) of $MAX_RETRIES."

        ((ATTEMPT++)) || true
    fi
done

echo ""
echo "Max retries ($MAX_RETRIES) reached. Loop failed."
echo ""
echo "Final reflections from memory:"
get_reflections
exit 1
