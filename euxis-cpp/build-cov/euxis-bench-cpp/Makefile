	cd /home/seb/.euxis/euxis-cpp/build-cov && $(MAKE) $(MAKESILENT) -f euxis-bench-cpp/CMakeFiles/euxis-bench-cpp_tests.dir/build.make euxis-bench-cpp/CMakeFiles/euxis-bench-cpp_tests.dir/tests/test_runner.cpp.i
.PHONY : tests/test_runner.cpp.i

tests/test_runner.s: tests/test_runner.cpp.s
.PHONY : tests/test_runner.s

# target to generate assembly for a file
tests/test_runner.cpp.s:
	cd /home/seb/.euxis/euxis-cpp/build-cov && $(MAKE) $(MAKESILENT) -f euxis-bench-cpp/CMakeFiles/euxis-bench-cpp_tests.dir/build.make euxis-bench-cpp/CMakeFiles/euxis-bench-cpp_tests.dir/tests/test_runner.cpp.s
.PHONY : tests/test_runner.cpp.s

