{
  "schema_version": "2026.1",
  "package": "euxis-docs",
  "kind": "docs",
  "module": "euxis_docs",
  "required_files": [
    "README.md",
    "pyproject.toml"
  ],
  "test_paths": [
    "euxis-docs/tests"
  ],
  "docs_path": "euxis-docs/docs/modules/euxis-docs.md",
  "platform_support": [
    "macos",
    "linux",
    "wsl"
  ],
  "core_platform_separation": {
    "required": false,
    "core_paths": [
      "src/euxis_docs/core"
    ],
    "platform_paths": [
      "src/euxis_docs/platform"
    ],
    "platform_targets": [
      "macos",
      "linux",
      "wsl"
    ],
    "notes": "Core logic should depend only on platform contracts/interfaces."
  },
  "consistency_contract": {
    "docs_required": true,
    "tests_required": true,
    "strict_naming": true
  }
}
