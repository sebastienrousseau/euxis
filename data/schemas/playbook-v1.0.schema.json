{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://euxis.dev/schemas/playbook-v1.0.schema.json",
  "title": "Euxis Playbook",
  "description": "Schema for euxis playbook manifest files",
  "type": "object",
  "properties": {
    "schema_version": {"type": "string", "pattern": "^1\\."},
    "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
    "name": {"type": "string"},
    "description": {"type": "string"},
    "task": {"type": "string"},
    "steps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {"type": "string"},
          "agent": {"type": "string"},
          "task": {"type": "string"},
          "task_template": {"type": "string"},
          "pillar": {"type": "string"},
          "depends": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "phases": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "sequence": {"type": "integer"},
          "phase": {"type": "integer"},
          "gate": {"type": "string"},
          "name": {"type": "string"},
          "principle": {"type": "string"},
          "mode": {"type": "string", "enum": ["hierarchical", "parallel"]},
          "delegates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "agent": {"type": "string"},
                "task_template": {"type": "string"},
                "task": {"type": "string"},
                "pillar": {"type": "string"},
                "verifies": {"type": "array", "items": {"type": "string"}}
              },
              "required": ["agent"]
            }
          },
          "checkpoint": {"type": "string"},
          "abort_on_failure": {"type": "boolean"},
          "failure_message": {"type": "string"}
        }
      }
    },
    "restart_policy": {"type": "string"},
    "crisis_management": {
      "type": "object",
      "properties": {
        "kill_switch_enabled": {"type": "boolean"},
        "rollback_threshold_ms": {"type": "integer"},
        "max_retries": {"type": "integer"},
        "nhi_iam_scope": {"type": "string"}
      }
    },
    "optional_sub_gates": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "trigger": {"type": "string"},
          "delegates": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "agent": {"type": "string"},
                "task_template": {"type": "string"}
              },
              "required": ["agent"]
            }
          }
        }
      }
    }
  },
  "anyOf": [
    {"required": ["steps"]},
    {"required": ["phases"]}
  ]
}
